Public Sub 新ファイル基準表生成()

    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean
    Dim oldCalculation As XlCalculation

    On Error GoTo ErrorHandler

    ' 実行前のExcel設定を退避
    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents
    oldCalculation = Application.Calculation

    ' 実行高速化のため一時的に設定変更
    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.Calculation = xlCalculationManual

    ' 手順2 -> 手順3 の順で既存マクロをそのまま呼び出す
    Call 手順2_新ファイル基準表を作成する
    Call 手順3_コード管理CSVを作成する

    MsgBox "新ファイル基準表とコード管理CSVの作成が完了しました。", vbInformation
    GoTo Cleanup

ErrorHandler:
    MsgBox "エラーが発生しました: " & Err.Description, vbExclamation

Cleanup:
    ' 例外時を含め、必ず元の設定へ戻す
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Application.Calculation = oldCalculation

End Sub

'========================================================
' 行移動モード開始／確定
' - 初回実行: 現在選択行（連続行のみ）を移動対象として記憶
' - モード中実行: 現在の挿入予定位置へ切り取り挿入して確定
'========================================================
Public Sub 行移動モード開始_または確定()

    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean
    Dim ws As Worksheet
    Dim selectedStartRow As Long
    Dim selectedEndRow As Long
    Dim lastDataRow As Long

    On Error GoTo ErrorHandler

    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents
    Application.ScreenUpdating = False
    Application.EnableEvents = False

    Set ws = GetRowMoveTargetSheet()
    If ws Is Nothing Then GoTo SafeExit

    If gRowMoveClickModeActive Then
        CancelRowMoveClickDestinationModeInternal
    End If

    If gRowMoveModeActive Then
        ConfirmRowMove ws
        GoTo SafeExit
    End If

    If Not TryGetContinuousDataRowSelection(ws, selectedStartRow, selectedEndRow) Then GoTo SafeExit

    ' Undo情報が残っている場合:
    ' - 直前に移動した同じブロックを続けて動かすなら開始基準は維持
    ' - それ以外の新しい移動開始なら基準をリセットして取り違えを防ぐ
    If gRowMoveUndoAvailable Then
        If Not (selectedStartRow = gRowMoveUndoMovedStartRow And selectedEndRow = gRowMoveUndoMovedEndRow) Then
            ClearRowMoveUndoState
        End If
    End If

    gRowMoveModeActive = True
    gRowMoveStartRow = selectedStartRow
    gRowMoveEndRow = selectedEndRow
    gRowMoveInsertRow = selectedStartRow ' Initial insert row = selected top row
    gRowMoveSelectionAssistActive = True
    gRowMoveSelectionAnchorRow = selectedStartRow

    If Not gRowMoveUndoAvailable Then
        gRowMoveUndoOriginalStartRow = selectedStartRow
        gRowMoveUndoOriginalEndRow = selectedEndRow
        gRowMoveUndoRowCount = selectedEndRow - selectedStartRow + 1
    End If

    lastDataRow = GetLastUsedRow(ws)
    If lastDataRow < 2 Then
        MsgBox "データ行がありません。", vbExclamation
        CancelRowMoveModeInternal
        GoTo SafeExit
    End If

    DrawRowMoveInsertionMarker ws, gRowMoveInsertRow
    UpdateRowMoveStatusBar

SafeExit:
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Exit Sub

ErrorHandler:
    MsgBox "行移動モード開始/確定でエラーが発生しました: " & Err.Description, vbExclamation
    CancelRowMoveModeInternal
    Resume SafeExit

End Sub

