'========================================================
' 指定行へ移動（選択ブロックの先頭を指定行に合わせる）
'========================================================
Public Sub 行移動_指定行へ()

    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean
    Dim ws As Worksheet
    Dim selectedStartRow As Long
    Dim selectedEndRow As Long
    Dim targetRowText As String
    Dim targetRow As Long
    Dim maxTargetRow As Long
    Dim blockRows As Long
    Dim lastDataRow As Long

    On Error GoTo ErrorHandler

    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents

    Set ws = GetRowMoveTargetSheet()
    If ws Is Nothing Then Exit Sub

    If gRowMoveClickModeActive Then
        CancelRowMoveClickDestinationModeInternal
    End If

    If gRowMoveModeActive Then
        selectedStartRow = gRowMoveStartRow
        selectedEndRow = gRowMoveEndRow
        If selectedStartRow < 2 Or selectedEndRow < selectedStartRow Then
            If Not TryGetContinuousDataRowSelection(ws, selectedStartRow, selectedEndRow) Then Exit Sub
        End If
    Else
        If Not TryGetContinuousDataRowSelection(ws, selectedStartRow, selectedEndRow) Then Exit Sub
    End If

    blockRows = selectedEndRow - selectedStartRow + 1
    If blockRows <= 0 Then
        MsgBox "移動対象行の情報が不正です。", vbExclamation
        Exit Sub
    End If

    lastDataRow = GetLastUsedRow(ws)
    If lastDataRow < 2 Then
        MsgBox "データ行がありません。", vbExclamation
        Exit Sub
    End If

    maxTargetRow = lastDataRow - blockRows + 1
    If maxTargetRow < 2 Then maxTargetRow = 2

    targetRowText = InputBox( _
        Prompt:="移動先の先頭行を入力してください。（2～" & CStr(maxTargetRow) & "）", _
        Title:="指定行へ移動", _
        Default:=CStr(selectedStartRow))
    If Len(Trim$(targetRowText)) = 0 Then Exit Sub

    If Not TryParseRowNumber(targetRowText, targetRow) Then
        MsgBox "行番号は整数で入力してください。", vbExclamation
        Exit Sub
    End If

    If targetRow < 2 Or targetRow > maxTargetRow Then
        MsgBox "移動先は 2～" & CStr(maxTargetRow) & " 行の範囲で入力してください。", vbExclamation
        Exit Sub
    End If

    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.StatusBar = False
    Application.CutCopyMode = False

    Call ExecuteRowMoveToTargetRow(ws, selectedStartRow, selectedEndRow, targetRow, True)

SafeExit:
    Application.CutCopyMode = False
    Application.StatusBar = False
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Exit Sub

ErrorHandler:
    Application.CutCopyMode = False
    MsgBox "指定行への移動でエラーが発生しました: " & Err.Description, vbExclamation
    Resume SafeExit

End Sub

