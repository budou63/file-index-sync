Public Sub 新ファイル基準表_色名から2色名同期(ByVal Target As Range, ByVal wsEdit As Worksheet)

    Dim lastCol As Long
    Dim colorCol As Long
    Dim color2Col As Long
    Dim workRange As Range
    Dim changedCell As Range

    If Target Is Nothing Then Exit Sub
