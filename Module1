Public Sub 行移動_移動先クリック開始()

    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean
    Dim ws As Worksheet
    Dim selectedStartRow As Long
    Dim selectedEndRow As Long

    On Error GoTo ErrorHandler

    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents
    Application.ScreenUpdating = False
    Application.EnableEvents = False

    Set ws = GetRowMoveTargetSheet()
    If ws Is Nothing Then GoTo SafeExit

    If gRowMoveModeActive Then
        MsgBox "行移動モード中です。先に移動終了/キャンセルしてください。", vbExclamation
        GoTo SafeExit
    End If

    If Not TryGetContinuousDataRowSelection(ws, selectedStartRow, selectedEndRow) Then GoTo SafeExit

    If gRowMoveUndoAvailable Then
        If Not (selectedStartRow = gRowMoveUndoMovedStartRow And selectedEndRow = gRowMoveUndoMovedEndRow) Then
            ClearRowMoveUndoState
        End If
    End If

    gRowMoveClickModeActive = True
    gRowMoveClickStartRow = selectedStartRow
    gRowMoveClickEndRow = selectedEndRow

    ws.Rows(selectedStartRow & ":" & selectedEndRow).Select
    Application.StatusBar = "移動先クリック待ち: " & selectedStartRow & "～" & selectedEndRow & "行を移動します。移動先の先頭行をクリックしてください。"

SafeExit:
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Exit Sub

ErrorHandler:
    MsgBox "移動先クリックモード開始でエラーが発生しました: " & Err.Description, vbExclamation
    CancelRowMoveClickDestinationModeInternal
