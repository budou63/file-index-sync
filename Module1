Private Function NormalizeSheetNameForMatch(ByVal sheetName As String) As String
    NormalizeSheetNameForMatch = NormalizeTextForMatch(sheetName)
End Function

Private Function NormalizeTextForMatch(ByVal valueText As String) As String

    Dim s As String

    s = CStr(valueText)
    s = Replace(s, vbCr, "")
    s = Replace(s, vbLf, "")
    s = Replace(s, vbTab, "")
    s = Replace(s, ChrW(&H3000), "")
    s = Trim$(s)

    NormalizeTextForMatch = s

End Function

Private Function GetRawCellMerged(ByVal ws As Worksheet, ByVal rowNo As Long, ByVal colNo As Long) As String

    Dim targetCell As Range

    Set targetCell = ws.Cells(rowNo, colNo)
    If targetCell.MergeCells Then
        GetRawCellMerged = CStr(targetCell.MergeArea.Cells(1, 1).Value)
    Else
        GetRawCellMerged = CStr(targetCell.Value)
    End If

End Function

Private Function IsContinuousDocument(ByVal rawValue As String) As Boolean

    Dim normalized As String

    normalized = NormalizeTextForMatch(rawValue)
    IsContinuousDocument = (StrComp(normalized, "継", vbBinaryCompare) = 0 Or StrComp(normalized, "継続", vbBinaryCompare) = 0)

End Function

Private Function NormalizeMediaValue(ByVal rawValue As String) As String
    NormalizeMediaValue = NormalizeTextForMatch(rawValue)
End Function

Private Function IsPaperMedia(ByVal rawValue As String) As Boolean

    IsPaperMedia = (StrComp(NormalizeMediaValue(rawValue), "紙", vbBinaryCompare) = 0)

End Function
