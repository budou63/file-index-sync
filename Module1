    ' ② 新ファイル基準表を1行ずつ処理
    For r = 2 To editLastRow
        ' 備考列が存在し、値が「マクロ差込」の行は差分判定対象外
        If bikoColEdit > 0 Then
            bikoVal = Trim(CStr(wsEdit.Cells(r, bikoColEdit).Value))
