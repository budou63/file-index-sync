Option Explicit

Private Const SHEET_MOKUROKU_CSV As String = "目録CSV"
Private Const SHEET_NEW_FILE_STANDARD As String = "新ファイル基準表"
Private Const SHEET_CODE_MANAGEMENT As String = "コード管理CSV"
Private Const SHEET_DIFF_IMPORT As String = "差分インポートCSV"

Public Sub 新ファイル基準表生成()

    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean
    Dim oldDisplayAlerts As Boolean

    On Error GoTo ErrorHandler

    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents
    oldDisplayAlerts = Application.DisplayAlerts

    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.DisplayAlerts = False

    Call CSV取込_シンプル版
    Call 手順2_新ファイル基準表を作成する
    Call 手順3_コード管理CSVを作成する

    MsgBox "完了しました"
    GoTo Cleanup

ErrorHandler:
    MsgBox "エラーが発生しました: " & Err.Description, vbExclamation

Cleanup:
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Application.DisplayAlerts = oldDisplayAlerts

End Sub

Public Sub CSV取込_シンプル版()

    Dim ws As Worksheet
    Dim filePath As Variant
    Dim wbCSV As Workbook
    Dim wsCSV As Worksheet
    Dim dstLastRow As Long
    Dim dstLastCol As Long
    Dim srcLastRow As Long
    Dim srcLastCol As Long
    Dim appendRow As Long
    Dim srcRow As Long
    Dim appendedCount As Long
    Dim deletedCount As Long
    Dim skippedBlankYearCount As Long
    Dim existingHasHeader As Boolean
    Dim srcWarekiCol As Long
    Dim dstWarekiCol As Long
    Dim targetFiscalYear As String
    Dim rowYear As String

    On Error GoTo ErrorHandler

    ' ファイル選択
    filePath = Application.GetOpenFilename("CSV Files (*.csv), *.csv")
    
    If filePath = False Then Exit Sub
    
    ' 目録CSVシート
    Set ws = ThisWorkbook.Worksheets("目録CSV")
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' CSVを開く
    Set wbCSV = Workbooks.Open(filePath)
    Set wsCSV = wbCSV.Sheets(1)

    srcLastRow = GetLastUsedRow(wsCSV)
    srcLastCol = GetLastUsedCol(wsCSV)
    dstLastRow = GetLastUsedRow(ws)
    dstLastCol = GetLastUsedCol(ws)
    existingHasHeader = (dstLastRow >= 1 And dstLastCol > 0 And Len(Trim$(CStr(ws.Cells(1, 1).Value))) > 0)

    If srcLastCol <= 0 Then Err.Raise vbObjectError + 2101, , "選択したCSVの見出し行が見つかりません。"

    ' 取込CSV側の「年度（和暦）」列を特定
    srcWarekiCol = FindHeaderColumn(wsCSV, srcLastCol, Array("年度（和暦）", "年度(和暦)"))
    If srcWarekiCol <= 0 Then
        Err.Raise vbObjectError + 2102, , "取込CSVに「年度（和暦）」列が見つかりません。"
    End If

    ' 2行目以降の最初の非空欄値を「今回取込対象年度」とする
    For srcRow = 2 To srcLastRow
        rowYear = GetTrimmedCell(wsCSV, srcRow, srcWarekiCol)
        If rowYear <> "" Then
            targetFiscalYear = rowYear
            Exit For
        End If
    Next srcRow
    If targetFiscalYear = "" Then
        Err.Raise vbObjectError + 2103, , "取込CSVの「年度（和暦）」列から対象年度を取得できません。"
    End If

    ' 単年CSV前提のため、対象年度以外が混在していないか事前検証
    For srcRow = 2 To srcLastRow
        rowYear = GetTrimmedCell(wsCSV, srcRow, srcWarekiCol)
        If rowYear <> "" And rowYear <> targetFiscalYear Then
            Err.Raise vbObjectError + 2104, , _
                "取込CSVに複数年度が混在しています。行" & srcRow & _
                " の年度（和暦）=""" & rowYear & """（対象年度: " & targetFiscalYear & "）"
        End If
    Next srcRow

    If Not existingHasHeader Then
        ' 初回取込: 見出しはそのまま取り込む
        ws.Range(ws.Cells(1, 1), ws.Cells(1, srcLastCol)).Value = _
            wsCSV.Range(wsCSV.Cells(1, 1), wsCSV.Cells(1, srcLastCol)).Value
        NormalizeHeaderLineBreaks ws
        appendRow = 2
    Else
        ' 追記取込: 既存見出しを維持
        NormalizeHeaderLineBreaks ws

        ' 目録CSVシート側の「年度（和暦）」列を特定
        dstWarekiCol = FindHeaderColumn(ws, dstLastCol, Array("年度（和暦）", "年度(和暦)"))
        If dstWarekiCol <= 0 Then
            Err.Raise vbObjectError + 2105, , "目録CSVシートに「年度（和暦）」列が見つかりません。"
        End If

        ' 対象年度と一致する既存行のみ下から削除（他年度は残す）
        For srcRow = dstLastRow To 2 Step -1
            rowYear = GetTrimmedCell(ws, srcRow, dstWarekiCol)
            If rowYear = targetFiscalYear Then
                ws.Rows(srcRow).Delete
                deletedCount = deletedCount + 1
            End If
        Next srcRow

        dstLastRow = GetLastUsedRow(ws)
        appendRow = dstLastRow + 1
    End If

    ' データ部（2行目以降）を重複判定なしで追記
    For srcRow = 2 To srcLastRow
        rowYear = GetTrimmedCell(wsCSV, srcRow, srcWarekiCol)

        If rowYear = "" Then
            skippedBlankYearCount = skippedBlankYearCount + 1
        Else
            ws.Range(ws.Cells(appendRow, 1), ws.Cells(appendRow, srcLastCol)).Value = _
                wsCSV.Range(wsCSV.Cells(srcRow, 1), wsCSV.Cells(srcRow, srcLastCol)).Value
            appendRow = appendRow + 1
            appendedCount = appendedCount + 1
        End If
    Next srcRow
    
    wbCSV.Close False
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    
    MsgBox "CSV取込完了" & vbCrLf & _
           "対象年度: " & targetFiscalYear & vbCrLf & _
           "削除件数: " & deletedCount & " 件" & vbCrLf & _
           "取込件数: " & appendedCount & " 件" & vbCrLf & _
           "年度空欄スキップ件数: " & skippedBlankYearCount & " 件", vbInformation
    Exit Sub

ErrorHandler:
    On Error Resume Next
    If Not wbCSV Is Nothing Then wbCSV.Close False
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    On Error GoTo 0
    MsgBox "CSV取込中にエラーが発生しました: " & Err.Description, vbExclamation

End Sub

Private Sub NormalizeHeaderLineBreaks(ByVal ws As Worksheet)

    Dim lastCol As Long
    Dim c As Range

    On Error GoTo SafeExit

    lastCol = GetLastUsedCol(ws)
    If lastCol <= 0 Then Exit Sub

    For Each c In ws.Range(ws.Cells(1, 1), ws.Cells(1, lastCol))
        If Not IsEmpty(c.value) Then
            c.value = Replace(CStr(c.value), vbCrLf, "")
            c.value = Replace(CStr(c.value), vbCr, "")
            c.value = Replace(CStr(c.value), vbLf, "")
        End If
    Next c

SafeExit:
    ' 改行除去は補助処理のため、失敗しても取込本体を止めない

End Sub

Public Sub 手順5_差分インポートCSVを外部出力する()

    Dim wsOut As Worksheet
    Dim wbExport As Workbook
    Dim wsExport As Worksheet
    Dim usedRng As Range
    Dim savePath As Variant
    Dim finalPath As String
    Dim defaultFileName As String
    Dim oldDisplayAlerts As Boolean
    Dim srcCol As Long
    Dim dstCol As Long
    Dim absCol As Long
    Dim headerName As String
    Dim lastRow As Long

    On Error GoTo ErrorHandler

    On Error Resume Next
    Set wsOut = ThisWorkbook.Worksheets(SHEET_DIFF_IMPORT)
    On Error GoTo ErrorHandler

    If wsOut Is Nothing Then
        MsgBox "「差分インポートCSV」シートが見つかりません。", vbExclamation
        Exit Sub
    End If

    If Application.WorksheetFunction.CountA(wsOut.UsedRange) = 0 Then
        MsgBox "「差分インポートCSV」シートに出力対象データがありません。", vbInformation
        Exit Sub
    End If

    defaultFileName = "差分インポートCSV_" & Format(Now, "yyyymmdd_hhnnss") & ".csv"
    savePath = Application.GetSaveAsFilename( _
        InitialFileName:=defaultFileName, _
        FileFilter:="CSV UTF-8 (*.csv),*.csv,CSV (Comma delimited) (*.csv),*.csv", _
        Title:="差分インポートCSV の保存先を選択してください")

    If VarType(savePath) = vbBoolean Then
        If savePath = False Then Exit Sub
    End If

    finalPath = EnsureCsvExtension(CStr(savePath))

    Set wbExport = Workbooks.Add(xlWBATWorksheet)
    Set wsExport = wbExport.Worksheets(1)
    Set usedRng = wsOut.UsedRange

    lastRow = usedRng.Rows.Count
    dstCol = 1

    ' ヘッダー名ベースで「通し番号」列を除外してCSV出力する（シート上の列は保持）
    For srcCol = 1 To usedRng.Columns.Count
        absCol = usedRng.Column + srcCol - 1
        headerName = Trim$(CStr(wsOut.Cells(1, absCol).Value))

        If headerName <> "通し番号" Then
            wsExport.Cells(1, dstCol).Resize(lastRow, 1).Value = _
                wsOut.Cells(usedRng.Row, absCol).Resize(lastRow, 1).Value
            dstCol = dstCol + 1
        End If
    Next srcCol

    If dstCol = 1 Then
        Err.Raise vbObjectError + 2401, , "出力対象列がありません（すべて「通し番号」列の可能性があります）。"
    End If

    oldDisplayAlerts = Application.DisplayAlerts
    Application.DisplayAlerts = False

    On Error Resume Next
    wbExport.SaveAs Filename:=finalPath, FileFormat:=62, Local:=True ' xlCSVUTF8
    If Err.Number <> 0 Then
        Err.Clear
        wbExport.SaveAs Filename:=finalPath, FileFormat:=xlCSV, Local:=True
    End If
    On Error GoTo ErrorHandler

    wbExport.Close SaveChanges:=False
    Application.DisplayAlerts = oldDisplayAlerts

    MsgBox "差分インポートCSV を外部出力しました。" & vbCrLf & _
           finalPath, vbInformation
    Exit Sub

ErrorHandler:
    On Error Resume Next
    If Not wbExport Is Nothing Then wbExport.Close SaveChanges:=False
    Application.DisplayAlerts = oldDisplayAlerts
    On Error GoTo 0
    MsgBox "差分インポートCSV の外部出力中にエラーが発生しました: " & Err.Description, vbExclamation

End Sub

Private Function EnsureCsvExtension(ByVal path As String) As String

    If LCase$(Right$(Trim$(path), 4)) <> ".csv" Then
        EnsureCsvExtension = Trim$(path) & ".csv"
    Else
        EnsureCsvExtension = Trim$(path)
    End If

End Function

Public Sub 手順4_差分インポートCSVを作成する()

    Dim wsSrc As Worksheet
    Dim wsEdit As Worksheet
    Dim wsOut As Worksheet
    Dim srcLastRow As Long
    Dim srcLastCol As Long
    Dim editLastRow As Long
    Dim editLastCol As Long
    Dim r As Long
    Dim outRow As Long
    Dim keyYearSrc As Long, keyTitleSrc As Long, keyCategory2Src As Long, keyMediaSrc As Long, keyPeriodSrc As Long
    Dim keyYearEdit As Long, keyTitleEdit As Long, keyCategory2Edit As Long, keyMediaEdit As Long, keyPeriodEdit As Long
    Dim compareDefs As Variant
    Dim fixedHeaders As Variant
    Dim compareSrcCols() As Long
    Dim compareEditCols() As Long
    Dim i As Long
    Dim srcDict As Object
    Dim usedSrcRows As Object
    Dim editHeaderMap As Object
    Dim outputSourceMap As Object
    Dim key As String
    Dim isDifferent As Boolean
    Dim srcRow As Long
    Dim yearVal As String, titleVal As String, category2Val As String, mediaVal As String, periodVal As String
    Dim isKeyBlank As Boolean

    On Error GoTo ErrorHandler

    Set wsSrc = ThisWorkbook.Worksheets(SHEET_MOKUROKU_CSV)
    Set wsEdit = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    Set wsOut = ThisWorkbook.Worksheets(SHEET_DIFF_IMPORT)
    Set srcDict = CreateObject("Scripting.Dictionary")
    Set usedSrcRows = CreateObject("Scripting.Dictionary")
    Set editHeaderMap = CreateObject("Scripting.Dictionary")
    Set outputSourceMap = CreateObject("Scripting.Dictionary")

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    srcLastRow = GetLastUsedRow(wsSrc)
    srcLastCol = GetLastUsedCol(wsSrc)
    editLastRow = GetLastUsedRow(wsEdit)
    editLastCol = GetLastUsedCol(wsEdit)

    keyYearSrc = FindHeaderColumn(wsSrc, srcLastCol, GetStep2HeaderCandidates("年度（和暦）"))
    keyTitleSrc = FindHeaderColumn(wsSrc, srcLastCol, GetStep2HeaderCandidates("タイトル"))
    keyCategory2Src = FindHeaderColumn(wsSrc, srcLastCol, GetStep2HeaderCandidates("分類名２"))
    keyMediaSrc = FindHeaderColumn(wsSrc, srcLastCol, GetStep2HeaderCandidates("媒体種別"))
    keyPeriodSrc = FindHeaderColumn(wsSrc, srcLastCol, GetStep2HeaderCandidates("保存期間"))

    keyYearEdit = FindHeaderColumn(wsEdit, editLastCol, GetStep2HeaderCandidates("年度（和暦）"))
    keyTitleEdit = FindHeaderColumn(wsEdit, editLastCol, GetStep2HeaderCandidates("タイトル"))
    keyCategory2Edit = FindHeaderColumn(wsEdit, editLastCol, GetStep2HeaderCandidates("分類名２"))
    keyMediaEdit = FindHeaderColumn(wsEdit, editLastCol, GetStep2HeaderCandidates("媒体種別"))
    keyPeriodEdit = FindHeaderColumn(wsEdit, editLastCol, GetStep2HeaderCandidates("保存期間"))

    If keyYearSrc = 0 Or keyTitleSrc = 0 Or keyCategory2Src = 0 Or keyMediaSrc = 0 Or keyPeriodSrc = 0 Then
        Err.Raise vbObjectError + 2301, , "目録CSV の差分キー列（年度（和暦）/タイトル/分類名２/媒体種別/保存期間）が見つかりません。"
    End If
    If keyYearEdit = 0 Or keyTitleEdit = 0 Or keyCategory2Edit = 0 Or keyMediaEdit = 0 Or keyPeriodEdit = 0 Then
        Err.Raise vbObjectError + 2302, , "新ファイル基準表 の差分キー列（年度（和暦）/タイトル/分類名２/媒体種別/保存期間）が見つかりません。"
    End If

    compareDefs = Array("分類名１", "分類名３", "保存期間", "媒体種別")
    ReDim compareSrcCols(LBound(compareDefs) To UBound(compareDefs))
    ReDim compareEditCols(LBound(compareDefs) To UBound(compareDefs))

    For i = LBound(compareDefs) To UBound(compareDefs)
        compareSrcCols(i) = FindHeaderColumn(wsSrc, srcLastCol, GetStep2HeaderCandidates(CStr(compareDefs(i))))
        compareEditCols(i) = FindHeaderColumn(wsEdit, editLastCol, GetStep2HeaderCandidates(CStr(compareDefs(i))))
    Next i

    fixedHeaders = Array( _
        "通し番号", "年度", "所管所属", "所管所属名称", "タイトル", "サブタイトル", "保存期間", "保存期間満了時の措置", "保管期間", "保管期間完了予定年", _
        "分類コード１", "分類名１", "分類コード２", "分類名２", "分類コード３", "分類名３", "分類コード４", "分類名４", "分類コード５", "分類名５", _
        "毎年度利用区分", "年度暦年区分", "色", "保管媒体区分", "保存場所・箱コード１", "保存場所・箱名１", "箱サイン１", "保存場所・箱コード２", "保存場所・箱名２", "箱サイン２", _
        "保存場所・箱コード３", "保存場所・箱名３", "箱サイン３", "保存場所・箱コード４", "保存場所・箱名４", "箱サイン４", "保存場所・箱コード５", "保存場所・箱名５", "箱サイン５", _
        "ラベル種類", "背表紙用タイトル", "背表紙用サブタイトル", "公開用タイトル", "公開用サブタイトル", "公開区分", "歴史資料区分", "内容・取扱い", "備考", _
        "作成所属", "作成年度", "作成者", "機密レベル", "汎用項目１", "汎用項目２", "汎用項目３", "汎用項目４", "汎用項目５", "汎用項目６", "汎用項目７", "汎用項目８", "汎用項目９", "汎用項目１０", _
        "汎用日付項目１", "汎用日付項目２", "汎用日付項目３", "汎用日付項目４", "汎用日付項目５", _
        "汎用数値項目１", "汎用数値項目２", "汎用数値項目３", "汎用数値項目４", "汎用数値項目５", _
        "汎用選択項目１", "汎用選択項目２", "汎用選択項目３", "汎用選択項目４", "汎用選択項目５", _
        "汎用チェック項目１", "汎用チェック項目２", "汎用チェック項目３", "汎用チェック項目４", "汎用チェック項目５", _
        "ファイルラベル区分名", "ファイルラベル区分サイズ", "場所内のファイルのソート")

    ' 新ファイル基準表の見出しを辞書化（固定見出しとの同名照合で使用）
    For i = 1 To editLastCol
        If Len(Trim(CStr(wsEdit.Cells(1, i).value))) > 0 Then
            If Not editHeaderMap.Exists(Trim(CStr(wsEdit.Cells(1, i).value))) Then
                editHeaderMap.Add Trim(CStr(wsEdit.Cells(1, i).value)), i
            End If
        End If
    Next i

    ' 出力見出し -> 取得元見出し のマッピング定義
    outputSourceMap.Add "通し番号", "通し番号"
    ' 固定見出し「所管所属」は新ファイル基準表の「原課ID」から取得する
    outputSourceMap.Add "所管所属", "原課ID"
    ' 固定見出し「毎年度利用区分」は新ファイル基準表の正式見出しから取得する
    outputSourceMap.Add "毎年度利用区分", "毎年度利用区分1:毎年作成 2:単年のみ"

    ' ① 目録CSVをキー（年度（和暦）+タイトル+分類名２+媒体種別+保存期間）で辞書化
    '    年度またぎ比較を防ぐため、年度（和暦）を必ずキーに含める。
    '    年度空欄行は比較対象外とする。
    For r = 2 To srcLastRow
        yearVal = GetTrimmedCell(wsSrc, r, keyYearSrc)
        titleVal = GetTrimmedCell(wsSrc, r, keyTitleSrc)
        category2Val = GetTrimmedCell(wsSrc, r, keyCategory2Src)
        mediaVal = GetTrimmedCell(wsSrc, r, keyMediaSrc)
        periodVal = GetTrimmedCell(wsSrc, r, keyPeriodSrc)
        ' キー一意性を高めるため媒体種別・保存期間も含める
        key = BuildHeaderBasedKey(yearVal, titleVal, category2Val, mediaVal, periodVal)

        isKeyBlank = (yearVal = "" And titleVal = "" And category2Val = "")
        If Not isKeyBlank And yearVal <> "" And titleVal <> "" Then
            AddRowToKeyBucket srcDict, key, r
        End If
    Next r

    wsOut.Cells.Clear
    ' 1行目に固定見出しを厳密順で出力
    For i = LBound(fixedHeaders) To UBound(fixedHeaders)
        wsOut.Cells(1, i - LBound(fixedHeaders) + 1).value = fixedHeaders(i)
    Next i
    outRow = 2

    ' ② 新ファイル基準表を1行ずつ処理
    For r = 2 To editLastRow
        yearVal = GetTrimmedCell(wsEdit, r, keyYearEdit)
        titleVal = GetTrimmedCell(wsEdit, r, keyTitleEdit)
        category2Val = GetTrimmedCell(wsEdit, r, keyCategory2Edit)
        mediaVal = GetTrimmedCell(wsEdit, r, keyMediaEdit)
        periodVal = GetTrimmedCell(wsEdit, r, keyPeriodEdit)
        ' キー一意性を高めるため媒体種別・保存期間も含める
        key = BuildHeaderBasedKey(yearVal, titleVal, category2Val, mediaVal, periodVal)
        isKeyBlank = (yearVal = "" And titleVal = "" And category2Val = "")

        ' A. キー3項目がすべて空白 / 年度空欄 / タイトル空欄 -> 無視
        '    同一年度内比較を徹底するため、年度空欄は比較対象外にする。
        If isKeyBlank Or yearVal = "" Or titleVal = "" Then
            ' 何もしない

        ' B. キー一致する行が存在 -> 比較列に差異があれば更新行として出力
        ElseIf srcDict.Exists(key) Then
            ' 同一キーの複数行に対応するため、1キー1行ではなく候補行一覧を保持する
            ' 誤突合を防ぐため、候補の中から比較列の一致数が最大の行を採用する
            srcRow = GetBestMatchedSourceRow( _
                wsSrc, _
                wsEdit, _
                srcDict(key), _
                usedSrcRows, _
                compareSrcCols, _
                compareEditCols, _
                r)

            If srcRow > 0 Then
                ' 採用済み候補行は再利用しない
                MarkSourceRowAsUsed usedSrcRows, srcRow

                isDifferent = False
                For i = LBound(compareDefs) To UBound(compareDefs)
                    If compareSrcCols(i) > 0 And compareEditCols(i) > 0 Then
                        If NormalizeForDiffCompare(wsSrc.Cells(srcRow, compareSrcCols(i)).Value) <> _
                           NormalizeForDiffCompare(wsEdit.Cells(r, compareEditCols(i)).Value) Then
                            isDifferent = True
                            Exit For
                        End If
                    End If
                Next i
            Else
                isDifferent = True
            End If

            If isDifferent Then
                WriteRowByFixedLayout wsEdit, wsOut, r, outRow, fixedHeaders, editHeaderMap, outputSourceMap
                outRow = outRow + 1
            End If

        ' C. キー一致なし -> 新規行として出力
        Else
            WriteRowByFixedLayout wsEdit, wsOut, r, outRow, fixedHeaders, editHeaderMap, outputSourceMap
            outRow = outRow + 1
        End If
    Next r

    With wsOut.Range(wsOut.Cells(1, 1), wsOut.Cells(1, UBound(fixedHeaders) - LBound(fixedHeaders) + 1))
        .Font.Bold = True
        .Interior.Color = RGB(242, 242, 242)
        .AutoFilter
    End With
    wsOut.Columns(1).Resize(, UBound(fixedHeaders) - LBound(fixedHeaders) + 1).EntireColumn.AutoFit

    MsgBox "差分インポートCSV の作成が完了しました。" & vbCrLf & _
           "出力件数: " & outRow - 2 & " 件", vbInformation

SafeExit:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Exit Sub

ErrorHandler:
    MsgBox "差分インポートCSV の作成中にエラーが発生しました: " & Err.Description, vbExclamation
    Resume SafeExit

End Sub

Private Sub AddRowToKeyBucket(ByVal bucketDict As Object, ByVal key As String, ByVal rowNumber As Long)

    Dim rows As Collection

    If Not bucketDict.Exists(key) Then
        Set rows = New Collection
        bucketDict.Add key, rows
    End If

    Set rows = bucketDict(key)
    rows.Add rowNumber

End Sub

Private Function GetBestMatchedSourceRow( _
    wsSrc As Worksheet, _
    wsEdit As Worksheet, _
    candidates As Collection, _
    usedRows As Object, _
    compareSrcCols() As Long, _
    compareEditCols() As Long, _
    editRow As Long) As Long

    Dim bestRow As Long
    Dim bestScore As Long
    Dim r As Variant
    Dim score As Long
    Dim i As Long

    bestRow = 0
    bestScore = -1

    For Each r In candidates

        ' すでに使用済みの行はスキップ
        If usedRows.Exists(CStr(r)) Then GoTo ContinueLoop

        score = 0

        ' 一致数カウント
        For i = LBound(compareSrcCols) To UBound(compareSrcCols)

            If compareSrcCols(i) > 0 And compareEditCols(i) > 0 Then

                If NormalizeForDiffCompare(wsSrc.Cells(CLng(r), compareSrcCols(i)).Value) = _
                   NormalizeForDiffCompare(wsEdit.Cells(editRow, compareEditCols(i)).Value) Then

                    score = score + 1

                End If

            End If

        Next i

        ' ベスト候補更新
        If score > bestScore Then
            bestScore = score
            bestRow = CLng(r)
        End If

ContinueLoop:
    Next r

    GetBestMatchedSourceRow = bestRow

End Function

Private Sub MarkSourceRowAsUsed(usedRows As Object, rowNum As Long)
    usedRows(CStr(rowNum)) = True
End Sub

Private Function BuildHeaderBasedKey(ByVal yearValue As String, ByVal titleValue As String, ByVal category2Value As String, ByVal mediaValue As String, ByVal periodValue As String) As String

    ' 差分キーも比較用正規化を通して、表記ゆれによる誤差分を抑制する
    BuildHeaderBasedKey = NormalizeForDiffCompare(yearValue) & "|" & _
                          NormalizeForDiffCompare(titleValue) & "|" & _
                          NormalizeForDiffCompare(category2Value) & "|" & _
                          NormalizeForDiffCompare(mediaValue) & "|" & _
                          NormalizeForDiffCompare(periodValue)

End Function

Private Function NormalizeForDiffCompare(ByVal v As Variant) As String

    Dim s As String

    If IsError(v) Or IsNull(v) Or IsEmpty(v) Then
        NormalizeForDiffCompare = ""
        Exit Function
    End If

    s = CStr(v)

    ' 改行/タブ/不可視制御文字を除去
    s = Replace(s, vbCrLf, " ")
    s = Replace(s, vbCr, " ")
    s = Replace(s, vbLf, " ")
    s = Replace(s, vbTab, " ")
    s = Application.WorksheetFunction.Clean(s)

    ' 全角英数・カナを半角へ寄せる（可能な範囲）
    On Error Resume Next
    s = StrConv(s, vbNarrow)
    On Error GoTo 0

    ' 代表的な記号揺れの統一
    s = Replace(s, "･", "・")
    s = Replace(s, "／", "/")
    s = Replace(s, "（", "(")
    s = Replace(s, "）", ")")
    s = Replace(s, "：", ":")
    s = NormalizeHyphenChars(s)

    ' 全角スペースを半角へ寄せる
    s = Replace(s, ChrW(&H3000), " ")

    ' 連続スペースを1つに圧縮
    s = CollapseSpaces(s)

    NormalizeForDiffCompare = Trim$(s)

End Function

Private Function NormalizeHyphenChars(ByVal s As String) As String

    s = Replace(s, "－", "-")
    s = Replace(s, "―", "-")
    s = Replace(s, "ｰ", "-")
    s = Replace(s, "ー", "-")
    s = Replace(s, "‐", "-")
    s = Replace(s, "−", "-")
    NormalizeHyphenChars = s

End Function

Private Function CollapseSpaces(ByVal s As String) As String

    Do While InStr(s, "  ") > 0
        s = Replace(s, "  ", " ")
    Loop

    CollapseSpaces = s

End Function

Public Sub 手順2_新ファイル基準表を作成する()

    Dim wsSrc As Worksheet
    Dim wsDst As Worksheet
    Dim srcLastRow As Long
    Dim srcLastCol As Long
    Dim dstLastCol As Long
    Dim displayHeaders As Variant
    Dim baselineUserManagedHeaders As Variant
    Dim additionalLeftDisplayHeaders As Variant
    Dim srcToDstMap As Object
    Dim srcHeaderMap As Object
    Dim existingDstHeaders As Object
    Dim existingRowMap As Object
    Dim sourceKeyMap As Object
    Dim srcCol As Long
    Dim dstCol As Long
    Dim headerText As String
    Dim canonical As String
    Dim i As Long
    Dim targetCol As Long
    Dim foundCol As Long
    Dim leftFixedCount As Long
    Dim missingHeadersText As String
    Dim validationTemplateMap As Object
    Dim formatTemplateMap As Object
    Dim columnWidthMap As Object
    Dim wsValidationTemplate As Worksheet
    Dim wsFormatTemplate As Worksheet
    Dim dstLastRow As Long
    Dim srcRow As Long
    Dim targetRow As Long
    Dim appendRow As Long
    Dim key As String
    Dim appendedCount As Long
    Dim updatedCount As Long
    Dim skippedNoKeyCount As Long
    Dim updateStartRow As Long
    Dim updateEndRow As Long
    Dim didUpdateRows As Boolean

    On Error GoTo ErrorHandler

    Set wsSrc = ThisWorkbook.Worksheets(SHEET_MOKUROKU_CSV)
    Set wsDst = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    Set srcToDstMap = CreateObject("Scripting.Dictionary")
    Set srcHeaderMap = CreateObject("Scripting.Dictionary")
    Set existingDstHeaders = CreateObject("Scripting.Dictionary")
    Set existingRowMap = CreateObject("Scripting.Dictionary")
    Set sourceKeyMap = CreateObject("Scripting.Dictionary")
    Set validationTemplateMap = CreateObject("Scripting.Dictionary")
    Set formatTemplateMap = CreateObject("Scripting.Dictionary")
    Set columnWidthMap = CreateObject("Scripting.Dictionary")

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    srcLastCol = GetLastUsedCol(wsSrc)
    srcLastRow = GetLastUsedRow(wsSrc)
    dstLastCol = GetLastUsedCol(wsDst)

    If srcLastCol <= 0 Then Err.Raise vbObjectError + 2001, , "目録CSV の見出し行が見つかりません。"

    ' 並び替え前に既存入力規則のテンプレートを退避（見出し名ベースで復元するため）
    CreateValidationTemplateSheet wsDst, dstLastCol, validationTemplateMap, wsValidationTemplate
    ' 並び替え前に既存書式/列幅を退避（条件付き書式・列幅の崩れ防止）
    CreateFormatAndWidthTemplate wsDst, dstLastCol, formatTemplateMap, columnWidthMap, wsFormatTemplate

    ' 主要表示列（左側に寄せる列）
    displayHeaders = Array( _
        "通し番号", _
        "キャビネット番号", _
        "ｎ＋1", _
        "毎年度利用区分1:毎年作成 2:単年のみ", _
        "原課", _
        "年度（和暦）", _
        "分類名１", _
        "分類名２", _
        "2色名", _
        "分類名３", _
        "色名", _
        "作成年度（和暦）", _
        "タイトル", _
        "保存期間", _
        "媒体種別", _
        "保存番号", _
        "廃棄年月日", _
        "同期状態", _
        "ファイルID")

    ' ユーザー管理列（CSV上書き対象外）
    baselineUserManagedHeaders = Array("通し番号", "キャビネット番号", "ｎ＋1", "保存番号", "廃棄年月日", "同期状態")

    ' 左側に追加したい独自列（必要時にここへ追記）
    additionalLeftDisplayHeaders = Array()

    ' 1) 既存「新ファイル基準表」の見出しを辞書化（追加列保持のため）
    BuildHeaderMap wsDst, dstLastCol, existingDstHeaders

    ' 2) ユーザー管理列を確保
    For i = LBound(baselineUserManagedHeaders) To UBound(baselineUserManagedHeaders)
        EnsureColumnByHeader wsDst, existingDstHeaders, CStr(baselineUserManagedHeaders(i))
    Next i

    ' 3) 目録CSVの見出し辞書を作成し、CSV由来列の転記マップを組み立てる
    BuildSourceHeaderMap wsSrc, srcLastCol, srcHeaderMap
    For srcCol = 1 To srcLastCol
        headerText = Trim$(CStr(wsSrc.Cells(1, srcCol).Value))
        If headerText <> "" Then
            canonical = CanonicalHeaderName(headerText)
            dstCol = EnsureColumnByHeader(wsDst, existingDstHeaders, headerText)

            ' 目録CSVにある列は基本的に更新対象だが、ユーザー管理列は除外する
            If Not IsUserManagedHeader(canonical, srcHeaderMap, baselineUserManagedHeaders) Then
                srcToDstMap(canonical) = dstCol
            End If
        End If
    Next srcCol

    ' 4) 既存行マップを作成し、「更新＋新規追加」で反映する
    dstLastRow = GetLastUsedRow(wsDst)
    If dstLastRow < 1 Then dstLastRow = 1
    appendRow = dstLastRow + 1

    BuildExistingRowMap wsDst, dstLastRow, existingRowMap

    If srcLastRow >= 2 Then
        For srcRow = 2 To srcLastRow
            key = BuildFileKeyFromSheetRow(wsSrc, srcRow, srcHeaderMap)

            If key = "" Then
                ' キー（ファイルID/ファイル番号/バーコード番号）不足行は更新不可のためスキップ
                skippedNoKeyCount = skippedNoKeyCount + 1
                GoTo ContinueNextSourceRow
            End If

            ' 今回の目録CSVに存在するキーとして記録（同期状態判定で利用）
            If Not sourceKeyMap.Exists(key) Then
                sourceKeyMap.Add key, True
            End If

            If existingRowMap.Exists(key) Then
                targetRow = CLng(existingRowMap(key))
                UpdateRowFromSourceByHeader wsSrc, wsDst, srcRow, targetRow, srcHeaderMap, srcToDstMap
                updatedCount = updatedCount + 1

                If Not didUpdateRows Then
                    updateStartRow = targetRow
                    updateEndRow = targetRow
                    didUpdateRows = True
                Else
                    If targetRow < updateStartRow Then updateStartRow = targetRow
                    If targetRow > updateEndRow Then updateEndRow = targetRow
                End If
            Else
                AppendRowFromSourceByHeader wsSrc, wsDst, srcRow, appendRow, srcHeaderMap, srcToDstMap
                existingRowMap.Add key, appendRow
                appendedCount = appendedCount + 1
                appendRow = appendRow + 1
            End If

ContinueNextSourceRow:
        Next srcRow
    End If

    ' 5) 主要列だけ左側へ並べ直し（それ以外は削除せず後ろに残す）
    targetCol = 1
    For i = LBound(displayHeaders) To UBound(displayHeaders)
        srcLastCol = GetLastUsedCol(wsDst)
        foundCol = FindHeaderColumn(wsDst, srcLastCol, GetStep2HeaderCandidates(CStr(displayHeaders(i))))

        If foundCol > 0 Then
            If foundCol <> targetCol Then
                wsDst.Columns(foundCol).Cut
                wsDst.Columns(targetCol).Insert Shift:=xlToRight
                Application.CutCopyMode = False
            End If
            targetCol = targetCol + 1
        End If
    Next i

    ' 拡張独自列を左側表示に追加しやすくする（見つかった列だけ移動）
    If HasArrayElements(additionalLeftDisplayHeaders) Then
        For i = LBound(additionalLeftDisplayHeaders) To UBound(additionalLeftDisplayHeaders)
            srcLastCol = GetLastUsedCol(wsDst)
            foundCol = FindHeaderColumn(wsDst, srcLastCol, GetStep2HeaderCandidates(CStr(additionalLeftDisplayHeaders(i))))

            If foundCol > 0 Then
                If foundCol <> targetCol Then
                    wsDst.Columns(foundCol).Cut
                    wsDst.Columns(targetCol).Insert Shift:=xlToRight
                    Application.CutCopyMode = False
                End If
                targetCol = targetCol + 1
            End If
        Next i
    End If

    leftFixedCount = targetCol - 1

    ' 6) 同期状態列を更新（現行 / 削除候補 / 未登録）
    UpdateSyncStatusColumn wsDst, sourceKeyMap

    ' 7) 「毎年度利用区分」表示値変換と2色名同期（更新行＋新規行）
    If didUpdateRows Then
        ConvertAnnualUseDivisionValues wsDst, updateEndRow, updateStartRow
        SyncSecondColorNameFromColor wsDst, updateStartRow, updateEndRow
    End If

    If appendRow > dstLastRow + 1 Then
        ConvertAnnualUseDivisionValues wsDst, appendRow - 1, dstLastRow + 1
        SyncSecondColorNameFromColor wsDst, dstLastRow + 1, appendRow - 1
    End If

    ' 8) 主要列の見た目のみ整える（既存追加列の表示/非表示状態は壊さない）
    If leftFixedCount > 0 Then
        With wsDst.Range(wsDst.Cells(1, 1), wsDst.Cells(1, leftFixedCount))
            .Font.Bold = True
            .Interior.Color = RGB(242, 242, 242)
        End With
        wsDst.Range(wsDst.Columns(1), wsDst.Columns(leftFixedCount)).EntireColumn.AutoFit
    End If

    srcLastCol = GetLastUsedCol(wsDst)
    wsDst.Range(wsDst.Cells(1, 1), wsDst.Cells(1, srcLastCol)).AutoFilter

    ' 9) 左側固定対象の不足見出しを通知用に収集（列の表示状態は変更しない）
    HideKeyColumnsForStep2 wsDst, displayHeaders, missingHeadersText

    ' 10) タイトルがある行だけ通し番号を再採番
    ReindexSerial_NewFileStandard wsDst

    ' 11) 入力規則を見出し名ベースで再適用（列挿入/並び替え後の列位置へ追従）
    ReapplyValidationFromTemplate wsDst, validationTemplateMap, wsValidationTemplate
    ' 条件付き書式/列幅を見出し名ベースで再適用
    ReapplyFormatAndWidthFromTemplate wsDst, formatTemplateMap, columnWidthMap, wsFormatTemplate

    If Len(missingHeadersText) > 0 Then
        MsgBox "新ファイル基準表の作成が完了しました。" & vbCrLf & _
               "更新件数: " & updatedCount & " 件" & vbCrLf & _
               "追加件数: " & appendedCount & " 件" & vbCrLf & _
               "キー不足スキップ件数: " & skippedNoKeyCount & " 件" & vbCrLf & _
               "左側に固定した主要列数: " & leftFixedCount & " 列" & vbCrLf & vbCrLf & _
               "以下の見出しが見つからないため、左側固定対象から除外しました:" & vbCrLf & _
               missingHeadersText, vbExclamation
    Else
        MsgBox "新ファイル基準表の作成が完了しました。" & vbCrLf & _
               "更新件数: " & updatedCount & " 件" & vbCrLf & _
               "追加件数: " & appendedCount & " 件" & vbCrLf & _
               "キー不足スキップ件数: " & skippedNoKeyCount & " 件" & vbCrLf & _
               "左側に固定した主要列数: " & leftFixedCount & " 列", vbInformation
    End If

SafeExit:
    On Error Resume Next
    If Not wsValidationTemplate Is Nothing Then
        Application.DisplayAlerts = False
        wsValidationTemplate.Delete
        Application.DisplayAlerts = True
    End If
    If Not wsFormatTemplate Is Nothing Then
        Application.DisplayAlerts = False
        wsFormatTemplate.Delete
        Application.DisplayAlerts = True
    End If
    On Error GoTo 0

    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Exit Sub

ErrorHandler:
    MsgBox "新ファイル基準表の作成中にエラーが発生しました: " & Err.Description, vbCritical
    Resume SafeExit

End Sub

