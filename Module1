SafeExit:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Exit Sub

ErrorHandler:
    MsgBox "差分インポートCSV の作成中にエラーが発生しました: " & Err.Description, vbExclamation
    Resume SafeExit

End Sub

Private Sub AddRowToKeyBucket(ByVal bucketDict As Object, ByVal key As String, ByVal rowNumber As Long)

    Dim rows As Collection

    If Not bucketDict.Exists(key) Then
        Set rows = New Collection
        bucketDict.Add key, rows
    End If

    Set rows = bucketDict(key)
    rows.Add rowNumber

End Sub

Private Function GetBestMatchedSourceRow( _
    wsSrc As Worksheet, _
    wsEdit As Worksheet, _
    candidates As Collection, _
    usedRows As Object, _
    compareSrcCols() As Long, _
    compareEditCols() As Long, _
    editRow As Long) As Long

    Dim bestRow As Long
    Dim bestScore As Long
    Dim r As Variant
    Dim score As Long
    Dim i As Long

    bestRow = 0
    bestScore = -1

    For Each r In candidates

        ' すでに使用済みの行はスキップ
        If usedRows.Exists(CStr(r)) Then GoTo ContinueLoop

        score = 0

        ' 一致数カウント
        For i = LBound(compareSrcCols) To UBound(compareSrcCols)

            If compareSrcCols(i) > 0 And compareEditCols(i) > 0 Then

                If NormalizeForDiffCompare(wsSrc.Cells(CLng(r), compareSrcCols(i)).Value) = _
                   NormalizeForDiffCompare(wsEdit.Cells(editRow, compareEditCols(i)).Value) Then

                    score = score + 1

                End If

            End If

        Next i

        ' ベスト候補更新
        If score > bestScore Then
            bestScore = score
            bestRow = CLng(r)
        End If

ContinueLoop:
    Next r

    GetBestMatchedSourceRow = bestRow

End Function

Private Sub MarkSourceRowAsUsed(usedRows As Object, rowNum As Long)
    usedRows(CStr(rowNum)) = True
End Sub

Private Function BuildHeaderBasedKey(ByVal yearValue As String, ByVal titleValue As String, ByVal category2Value As String, ByVal mediaValue As String, ByVal periodValue As String) As String

    ' 差分キーも比較用正規化を通して、表記ゆれによる誤差分を抑制する
    BuildHeaderBasedKey = NormalizeForDiffCompare(yearValue) & "|" & _
                          NormalizeForDiffCompare(titleValue) & "|" & _
                          NormalizeForDiffCompare(category2Value) & "|" & _
                          NormalizeForDiffCompare(mediaValue) & "|" & _
                          NormalizeForDiffCompare(periodValue)

End Function

Private Function NormalizeForDiffCompare(ByVal v As Variant) As String

    Dim s As String

    If IsError(v) Or IsNull(v) Or IsEmpty(v) Then
        NormalizeForDiffCompare = ""
        Exit Function
    End If

    s = CStr(v)

    ' 改行/タブ/不可視制御文字を除去
    s = Replace(s, vbCrLf, " ")
    s = Replace(s, vbCr, " ")
    s = Replace(s, vbLf, " ")
    s = Replace(s, vbTab, " ")
    s = Application.WorksheetFunction.Clean(s)

    ' 全角英数・カナを半角へ寄せる（可能な範囲）
    On Error Resume Next
    s = StrConv(s, vbNarrow)
    On Error GoTo 0

    ' 代表的な記号揺れの統一
    s = Replace(s, "･", "・")
    s = Replace(s, "／", "/")
    s = Replace(s, "（", "(")
    s = Replace(s, "）", ")")
    s = Replace(s, "：", ":")
    s = NormalizeHyphenChars(s)

    ' 全角スペースを半角へ寄せる
    s = Replace(s, ChrW(&H3000), " ")

    ' 連続スペースを1つに圧縮
    s = CollapseSpaces(s)

    NormalizeForDiffCompare = Trim$(s)

End Function

Private Function NormalizeHyphenChars(ByVal s As String) As String

    s = Replace(s, "－", "-")
    s = Replace(s, "―", "-")
    s = Replace(s, "ｰ", "-")
    s = Replace(s, "ー", "-")
    s = Replace(s, "‐", "-")
    s = Replace(s, "−", "-")
    NormalizeHyphenChars = s

End Function

Private Function CollapseSpaces(ByVal s As String) As String

    Do While InStr(s, "  ") > 0
        s = Replace(s, "  ", " ")
    Loop

    CollapseSpaces = s

End Function

