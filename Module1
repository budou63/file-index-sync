' 高速化対応: 表示見出し順から列並びマップを作成
'========================================================
Private Function BuildColumnOrderMap( _
    ByVal ws As Worksheet, _
    ByVal displayHeaders As Variant, _
    ByVal additionalLeftDisplayHeaders As Variant, _
    ByRef leftFixedCount As Long, _
    ByRef shouldReorder As Boolean) As Variant

    Dim lastCol As Long
    Dim colMap() As Long
    Dim usedCols As Object
    Dim headerValues As Variant
    Dim headerCandidates As Variant
    Dim i As Long
    Dim c As Long
    Dim found As Long
    Dim writePos As Long

    lastCol = GetLastUsedCol(ws)
    ReDim colMap(1 To lastCol)
    Set usedCols = CreateObject("Scripting.Dictionary")

    headerValues = ws.Range(ws.Cells(1, 1), ws.Cells(1, lastCol)).Value2
    writePos = 1

    For i = LBound(displayHeaders) To UBound(displayHeaders)
        headerCandidates = GetStep2HeaderCandidates(CStr(displayHeaders(i)))
        found = FindColumnIndexFromHeaderArray(headerValues, headerCandidates, usedCols)
        If found > 0 Then
            colMap(writePos) = found
            usedCols(CStr(found)) = True
            writePos = writePos + 1
        End If
    Next i

    If HasArrayElements(additionalLeftDisplayHeaders) Then
        For i = LBound(additionalLeftDisplayHeaders) To UBound(additionalLeftDisplayHeaders)
            headerCandidates = GetStep2HeaderCandidates(CStr(additionalLeftDisplayHeaders(i)))
            found = FindColumnIndexFromHeaderArray(headerValues, headerCandidates, usedCols)
            If found > 0 Then
                colMap(writePos) = found
                usedCols(CStr(found)) = True
                writePos = writePos + 1
            End If
        Next i
    End If

    leftFixedCount = writePos - 1

    For c = 1 To lastCol
        If Not usedCols.Exists(CStr(c)) Then
            colMap(writePos) = c
            writePos = writePos + 1
        End If
    Next c

    shouldReorder = False
    For c = 1 To lastCol
        If colMap(c) <> c Then
            shouldReorder = True
            Exit For
        End If
    Next c

    BuildColumnOrderMap = colMap

End Function

'========================================================
' 高速化対応: 列並びを配列一括で反映（Cut/Insert廃止）
'========================================================
Private Sub ReorderSheetColumnsByMap(ByVal ws As Worksheet, ByVal colMap As Variant)

    Dim lastRow As Long
    Dim lastCol As Long
    Dim src As Variant
    Dim dst As Variant
    Dim r As Long
    Dim c As Long

    lastCol = UBound(colMap)
    lastRow = GetLastUsedRow(ws)
    If lastCol <= 0 Or lastRow <= 0 Then Exit Sub

    src = ws.Range(ws.Cells(1, 1), ws.Cells(lastRow, lastCol)).Value2
    ReDim dst(1 To UBound(src, 1), 1 To UBound(src, 2))

    For c = 1 To lastCol
        For r = 1 To lastRow
            dst(r, c) = src(r, CLng(colMap(c)))
        Next r
    Next c

    ws.Range(ws.Cells(1, 1), ws.Cells(lastRow, lastCol)).Value = dst

End Sub

Private Function FindColumnIndexFromHeaderArray( _
    ByVal headerValues As Variant, _
    ByVal candidates As Variant, _
    ByVal usedCols As Object) As Long

    Dim c As Long
    Dim i As Long
    Dim headerValue As String

    For c = 1 To UBound(headerValues, 2)
        If Not usedCols.Exists(CStr(c)) Then
            headerValue = Trim$(CStr(headerValues(1, c)))
            For i = LBound(candidates) To UBound(candidates)
                If StrComp(headerValue, CStr(candidates(i)), vbTextCompare) = 0 Then
                    FindColumnIndexFromHeaderArray = c
                    Exit Function
                End If
            Next i
        End If
    Next c

End Function

Private Function HasArrayElements(ByVal values As Variant) As Boolean

    On Error GoTo SafeExit
    If IsArray(values) Then
        HasArrayElements = (LBound(values) <= UBound(values))
    End If
    Exit Function

SafeExit:
    HasArrayElements = False

End Function

Private Sub CreateFormatAndWidthTemplate( _
    ByVal wsDst As Worksheet, _
    ByVal lastCol As Long, _
    ByVal formatTemplateMap As Object, _
    ByVal columnWidthMap As Object, _
    ByRef wsTemplate As Worksheet)

    Dim c As Long
    Dim templateCol As Long
    Dim headerText As String
    Dim canonical As String

    If lastCol <= 0 Then Exit Sub

    Set wsTemplate = ThisWorkbook.Worksheets.Add(After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count))
    wsTemplate.Visible = xlSheetVeryHidden
    wsTemplate.Name = "__FMTTMP_" & Format(Now, "hhnnss")
    templateCol = 1

    For c = 1 To lastCol
        headerText = Trim$(CStr(wsDst.Cells(1, c).Value))
        If Len(headerText) > 0 Then
            canonical = CanonicalHeaderName(headerText)
            If Not columnWidthMap.Exists(canonical) Then
                columnWidthMap.Add canonical, wsDst.Columns(c).ColumnWidth
            End If

            wsDst.Cells(2, c).Copy
            wsTemplate.Cells(1, templateCol).PasteSpecial xlPasteFormats
            Application.CutCopyMode = False
            If Not formatTemplateMap.Exists(canonical) Then
                formatTemplateMap.Add canonical, templateCol
                templateCol = templateCol + 1
            End If
        End If
    Next c

End Sub

Private Sub ReapplyFormatAndWidthFromTemplate( _
    ByVal wsDst As Worksheet, _
    ByVal formatTemplateMap As Object, _
    ByVal columnWidthMap As Object, _
    ByVal wsTemplate As Worksheet)

    Dim key As Variant
    Dim lastCol As Long
    Dim dstCol As Long
    Dim templateCol As Long
    Dim applyLastRow As Long

    If wsDst Is Nothing Then Exit Sub

    lastCol = GetLastUsedCol(wsDst)
    If lastCol <= 0 Then Exit Sub

    applyLastRow = GetLastUsedRow(wsDst)
    If applyLastRow < 2 Then applyLastRow = 2

    If Not columnWidthMap Is Nothing Then
        For Each key In columnWidthMap.Keys
            dstCol = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates(CStr(key)))
            If dstCol > 0 Then
                wsDst.Columns(dstCol).ColumnWidth = CDbl(columnWidthMap(CStr(key)))
            End If
        Next key
    End If

    If formatTemplateMap Is Nothing Then Exit Sub
    If wsTemplate Is Nothing Then Exit Sub
    If formatTemplateMap.Count = 0 Then Exit Sub

    For Each key In formatTemplateMap.Keys
        dstCol = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates(CStr(key)))
        If dstCol > 0 Then
            templateCol = CLng(formatTemplateMap(CStr(key)))
            wsTemplate.Cells(1, templateCol).Copy
            wsDst.Range(wsDst.Cells(2, dstCol), wsDst.Cells(applyLastRow, dstCol)).PasteSpecial xlPasteFormats
            Application.CutCopyMode = False
        End If
    Next key

End Sub

