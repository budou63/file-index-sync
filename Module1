Public Sub UpdateRowMoveSelectionRange(ByVal startRow As Long, ByVal endRow As Long)

    Dim ws As Worksheet
    Dim tmp As Long
    Dim lastDataRow As Long

    If Not gRowMoveModeActive Then Exit Sub

    If startRow > endRow Then
        tmp = startRow
        startRow = endRow
        endRow = tmp
    End If

    If startRow < 2 Then startRow = 2

    Set ws = GetRowMoveTargetSheet()
    If ws Is Nothing Then Exit Sub

    lastDataRow = GetLastUsedRow(ws)
    If lastDataRow < 2 Then Exit Sub
    If endRow > lastDataRow Then endRow = lastDataRow
    If endRow < startRow Then Exit Sub

    gRowMoveStartRow = startRow
    gRowMoveEndRow = endRow

    If gRowMoveInsertRow < startRow Or gRowMoveInsertRow > endRow + 1 Then
        gRowMoveInsertRow = startRow
        DrawRowMoveInsertionMarker ws, gRowMoveInsertRow
    End If

    If Not gRowMoveUndoAvailable Then
        gRowMoveUndoOriginalStartRow = startRow
        gRowMoveUndoOriginalEndRow = endRow
        gRowMoveUndoRowCount = endRow - startRow + 1
    End If

    UpdateRowMoveStatusBar

End Sub

Public Sub 行移動_元に戻す()

    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean
    Dim ws As Worksheet
    Dim rowCount As Long
    Dim originalStart As Long
    Dim currentStart As Long
    Dim currentEnd As Long
    Dim insertRow As Long

    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents

    On Error GoTo ErrorHandler

    If gRowMoveModeActive Then
        MsgBox "移動モード中は元に戻せません。先に移動終了/キャンセルしてください。", vbExclamation
        Exit Sub
    End If
    If gRowMoveClickModeActive Then
        CancelRowMoveClickDestinationModeInternal
    End If

    If Not gRowMoveUndoAvailable Then
        MsgBox "元に戻せる行移動はありません。", vbInformation
        Exit Sub
    End If

    Set ws = GetRowMoveTargetSheet()
    If ws Is Nothing Then Exit Sub

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    currentStart = gRowMoveUndoMovedStartRow
    currentEnd = gRowMoveUndoMovedEndRow
    originalStart = gRowMoveUndoOriginalStartRow
    rowCount = gRowMoveUndoRowCount

    If rowCount <= 0 Or currentStart < 2 Or currentEnd < currentStart Or originalStart < 2 Or (currentEnd - currentStart + 1) <> rowCount Then
        ClearRowMoveUndoState
        MsgBox "元に戻し情報が不正なため、Undo情報をクリアしました。", vbExclamation
        GoTo SafeExit
    End If

    currentStart = ResolveRowMoveUndoCurrentStartRow(ws, currentStart, rowCount)
    currentEnd = currentStart + rowCount - 1
    If currentStart < 2 Or currentEnd < currentStart Then
        ClearRowMoveUndoState
        MsgBox "元に戻し対象の行を特定できないため、Undo情報をクリアしました。", vbExclamation
        GoTo SafeExit
    End If

    insertRow = originalStart
    ' Cutで上側の行を抜いた場合、下側の挿入先はrowCount分だけ繰り上がるため補正
    If currentEnd < originalStart Then
        insertRow = insertRow + rowCount
    End If
    If insertRow < 2 Then insertRow = 2

    Application.StatusBar = False
    Application.CutCopyMode = False

    ws.Rows(currentStart & ":" & currentEnd).Cut
    ws.Rows(insertRow).Insert Shift:=xlDown
    Application.CutCopyMode = False

    ws.Rows(insertRow & ":" & insertRow + rowCount - 1).Select
    ClearRowMoveUndoState
    SyncFrmSealMoveButtonsIfLoaded

SafeExit:
    Application.StatusBar = False
    Application.CutCopyMode = False
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Exit Sub

ErrorHandler:
    MsgBox "行移動の元に戻す処理でエラーが発生しました: " & Err.Description, vbExclamation
    ClearRowMoveUndoState
    Resume SafeExit

End Sub

Private Function ExecuteRowMoveToTargetRow( _
    ByVal ws As Worksheet, _
    ByVal selectedStartRow As Long, _
    ByVal selectedEndRow As Long, _
    ByVal targetRow As Long, _
    ByVal cancelArrowMoveMode As Boolean) As Boolean

    Dim blockRows As Long
    Dim movedStartRow As Long
    Dim insertRow As Long
    Dim movedSerial As String
    Dim lastDataRow As Long
    Dim maxTargetRow As Long

    ExecuteRowMoveToTargetRow = False
    If ws Is Nothing Then Exit Function
    If selectedStartRow < 2 Or selectedEndRow < selectedStartRow Then Exit Function

    blockRows = selectedEndRow - selectedStartRow + 1
    If blockRows <= 0 Then Exit Function

    lastDataRow = GetLastUsedRow(ws)
    maxTargetRow = lastDataRow - blockRows + 1
    If maxTargetRow < 2 Then maxTargetRow = 2
    If targetRow < 2 Or targetRow > maxTargetRow Then
        MsgBox "移動先は 2～" & CStr(maxTargetRow) & " 行の範囲で指定してください。", vbExclamation
        Exit Function
    End If

    If targetRow >= selectedStartRow And targetRow <= selectedEndRow Then
        MsgBox "移動先が現在の選択範囲内です。別の行を指定してください。", vbInformation
        Exit Function
    End If

    movedStartRow = targetRow
    insertRow = targetRow
    If targetRow > selectedEndRow Then
        insertRow = targetRow + blockRows
    End If

    If gRowMoveUndoAvailable Then
        If Not (selectedStartRow = gRowMoveUndoMovedStartRow And selectedEndRow = gRowMoveUndoMovedEndRow) Then
            ClearRowMoveUndoState
        End If
    End If

    movedSerial = GetRowMoveUndoSerialValue(ws, selectedStartRow)

    If cancelArrowMoveMode And gRowMoveModeActive Then
        CancelRowMoveModeInternal
    End If

    If Not gRowMoveUndoAvailable Then
        gRowMoveUndoOriginalStartRow = selectedStartRow
        gRowMoveUndoOriginalEndRow = selectedEndRow
        gRowMoveUndoRowCount = blockRows
    End If

    ws.Rows(selectedStartRow & ":" & selectedEndRow).Cut
    ws.Rows(insertRow).Insert Shift:=xlDown
    Application.CutCopyMode = False

    SaveRowMoveUndoState movedStartRow, blockRows, movedSerial
    ws.Rows(movedStartRow & ":" & movedStartRow + blockRows - 1).Select
    Call 後処理_行移動後
    SyncFrmSealMoveButtonsIfLoaded

    ExecuteRowMoveToTargetRow = True

End Function

Private Sub ShiftRowMoveInsertPointer(ByVal delta As Long)

    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean
    Dim ws As Worksheet
    Dim lastDataRow As Long
    Dim nextRow As Long

    On Error GoTo ErrorHandler

    If Not gRowMoveModeActive Then
        MsgBox "行移動モードが開始されていません。", vbInformation
        Exit Sub
    End If

    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents
    Application.ScreenUpdating = False
    Application.EnableEvents = False

    Set ws = GetRowMoveTargetSheet()
    If ws Is Nothing Then GoTo SafeExit

    lastDataRow = GetLastUsedRow(ws)
    If lastDataRow < 2 Then
        MsgBox "データ行がありません。", vbExclamation
        CancelRowMoveModeInternal
        GoTo SafeExit
    End If

    nextRow = gRowMoveInsertRow + delta
    If nextRow < 2 Then nextRow = 2
    If nextRow > lastDataRow Then nextRow = lastDataRow

    If nextRow <> gRowMoveInsertRow Then
        gRowMoveInsertRow = nextRow
        gRowMoveSelectionAssistActive = False
        DrawRowMoveInsertionMarker ws, gRowMoveInsertRow
        UpdateRowMoveStatusBar
    End If

SafeExit:
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Exit Sub

ErrorHandler:
    MsgBox "挿入予定位置の移動中にエラーが発生しました: " & Err.Description, vbExclamation
    CancelRowMoveModeInternal
    Resume SafeExit

End Sub

Private Sub ConfirmRowMove(ByVal ws As Worksheet)

    Dim blockRows As Long
    Dim destinationRow As Long
    Dim movedSerial As String
    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean

    On Error GoTo ErrorHandler

    If Not gRowMoveModeActive Then Exit Sub
    If ws Is Nothing Then Exit Sub

    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents
    Application.ScreenUpdating = False
    Application.EnableEvents = False

    blockRows = gRowMoveEndRow - gRowMoveStartRow + 1
    If blockRows <= 0 Then Err.Raise vbObjectError + 3101, , "移動対象行の情報が不正です。"

    ' 移動対象範囲内（および直下）への挿入指定は確定不可
    If gRowMoveInsertRow >= gRowMoveStartRow And gRowMoveInsertRow <= gRowMoveEndRow + 1 Then
        MsgBox "移動対象範囲内には挿入できません。▲/▼で挿入予定位置を調整してください。", vbExclamation
        GoTo SafeExit
    End If

    If gRowMoveInsertRow > gRowMoveEndRow + 1 Then
        destinationRow = gRowMoveInsertRow - blockRows
    Else
        destinationRow = gRowMoveInsertRow
    End If

    If destinationRow < 2 Then destinationRow = 2

    ClearRowMoveInsertionMarker ws

    ' 実データ移動は確定時のみ1回実行
    movedSerial = GetRowMoveUndoSerialValue(ws, gRowMoveStartRow)
    ws.Rows(gRowMoveStartRow & ":" & gRowMoveEndRow).Cut
    ws.Rows(destinationRow).Insert Shift:=xlDown
    Application.CutCopyMode = False

    SaveRowMoveUndoState destinationRow, blockRows, movedSerial

    ws.Rows(destinationRow & ":" & destinationRow + blockRows - 1).Select

    CancelRowMoveModeInternal
    Call 後処理_行移動後

SafeExit:
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Exit Sub

ErrorHandler:
    Application.CutCopyMode = False
    MsgBox "行移動の確定中にエラーが発生しました: " & Err.Description, vbExclamation
    CancelRowMoveModeInternal
    Resume SafeExit

End Sub

Private Function TryGetContinuousDataRowSelection( _
    ByVal ws As Worksheet, _
    ByRef startRow As Long, _
    ByRef endRow As Long) As Boolean

    Dim sel As Range
    Dim r As Range
    Dim minRow As Long
    Dim maxRow As Long

    TryGetContinuousDataRowSelection = False
    If ws Is Nothing Then Exit Function
    If Not ws Is ActiveSheet Then
        MsgBox "「新ファイル基準表」シートを表示してから実行してください。", vbExclamation
        Exit Function
    End If

    If TypeName(Selection) <> "Range" Then
        MsgBox "行を選択してから実行してください。", vbExclamation
        Exit Function
    End If

    Set sel = Selection
    If sel.Areas.Count <> 1 Then
        MsgBox "飛び飛び選択には対応していません。連続した行を選択してください。", vbExclamation
        Exit Function
    End If

    minRow = sel.Row
    maxRow = sel.Row + sel.Rows.Count - 1
    If minRow < 2 Then
        MsgBox "見出し行（1行目）は移動対象にできません。2行目以降を選択してください。", vbExclamation
        Exit Function
    End If

    For Each r In sel.Rows
        If r.Row < minRow Then minRow = r.Row
        If r.Row > maxRow Then maxRow = r.Row
    Next r

    startRow = minRow
    endRow = maxRow
    TryGetContinuousDataRowSelection = True

End Function

Private Function TryParseRowNumber(ByVal textValue As String, ByRef outValue As Long) As Boolean

    Dim normalized As String
    Dim d As Double

    normalized = Trim$(textValue)
    If Len(normalized) = 0 Then Exit Function
    If Not IsNumeric(normalized) Then Exit Function

    d = CDbl(normalized)
    If d <> Fix(d) Then Exit Function
    If d < -2147483648# Or d > 2147483647# Then Exit Function

    outValue = CLng(d)
    TryParseRowNumber = True

End Function

Private Function GetRowMoveTargetSheet() As Worksheet

    On Error Resume Next
    Set GetRowMoveTargetSheet = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    On Error GoTo 0

    If GetRowMoveTargetSheet Is Nothing Then
        MsgBox "「新ファイル基準表」シートが見つかりません。", vbExclamation
    End If

End Function

Private Sub DrawRowMoveInsertionMarker(ByVal ws As Worksheet, ByVal markerRow As Long)

    Dim lastCol As Long
    Dim c As Long
    Dim targetCell As Range
    Dim edgeTop As Border

    If ws Is Nothing Then Exit Sub
    If markerRow < 2 Then Exit Sub

    ClearRowMoveInsertionMarker ws

    lastCol = GetLastUsedCol(ws)
    If lastCol <= 0 Then lastCol = 1
    gRowMoveMarkerLastCol = lastCol

    ReDim gRowMoveMarkerLineStyle(1 To lastCol)
    ReDim gRowMoveMarkerWeight(1 To lastCol)
    ReDim gRowMoveMarkerColor(1 To lastCol)
    ReDim gRowMoveMarkerColorIndex(1 To lastCol)

    For c = 1 To lastCol
        Set targetCell = ws.Cells(markerRow, c)
        Set edgeTop = targetCell.Borders(xlEdgeTop)
        gRowMoveMarkerLineStyle(c) = edgeTop.LineStyle
        gRowMoveMarkerWeight(c) = edgeTop.Weight
        gRowMoveMarkerColor(c) = edgeTop.Color
        gRowMoveMarkerColorIndex(c) = edgeTop.ColorIndex
    Next c

    With ws.Range(ws.Cells(markerRow, 1), ws.Cells(markerRow, lastCol)).Borders(xlEdgeTop)
        .LineStyle = xlContinuous
        .Weight = xlThick
        .Color = RGB(0, 0, 0)
    End With

    gRowMoveMarkerRow = markerRow

End Sub

Private Sub ClearRowMoveInsertionMarker(ByVal ws As Worksheet)

    Dim c As Long
    Dim targetCell As Range
    Dim edgeTop As Border

    If ws Is Nothing Then Exit Sub
    If gRowMoveMarkerRow < 2 Then Exit Sub
    If gRowMoveMarkerLastCol <= 0 Then Exit Sub
    If Not IsArrayAllocated(gRowMoveMarkerLineStyle) Then Exit Sub

    For c = 1 To gRowMoveMarkerLastCol
        Set targetCell = ws.Cells(gRowMoveMarkerRow, c)
        Set edgeTop = targetCell.Borders(xlEdgeTop)
        edgeTop.LineStyle = gRowMoveMarkerLineStyle(c)
        edgeTop.Weight = gRowMoveMarkerWeight(c)
        edgeTop.Color = gRowMoveMarkerColor(c)
        edgeTop.ColorIndex = gRowMoveMarkerColorIndex(c)
    Next c

    Erase gRowMoveMarkerLineStyle
    Erase gRowMoveMarkerWeight
    Erase gRowMoveMarkerColor
    Erase gRowMoveMarkerColorIndex
    gRowMoveMarkerRow = 0
    gRowMoveMarkerLastCol = 0

End Sub

Private Function IsArrayAllocated(ByRef arr As Variant) As Boolean

    On Error GoTo NotAllocated
    If IsArray(arr) Then
        Dim lb As Long
        lb = LBound(arr)
        IsArrayAllocated = (lb <= UBound(arr))
    End If
    Exit Function

NotAllocated:
    IsArrayAllocated = False

End Function

