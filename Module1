Public Sub 通し番号_再採番_新ファイル基準表()

    On Error GoTo ErrorHandler

    ReindexSerial_NewFileStandard ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    MsgBox "新ファイル基準表の通し番号を再採番しました。", vbInformation
    Exit Sub

ErrorHandler:
    MsgBox "通し番号の再採番中にエラーが発生しました: " & Err.Description, vbExclamation

End Sub

Public Sub ReindexSerial_NewFileStandard(Optional ByVal ws As Worksheet)

    Dim targetWs As Worksheet
    Dim lastCol As Long
    Dim lastRow As Long
    Dim serialCol As Long
    Dim titleCol As Long
    Dim rowNo As Long
    Dim nextSerial As Long
    Dim titleValue As String
    Dim prevEnableEvents As Boolean
    Dim prevScreenUpdating As Boolean

    On Error GoTo SafeExit

    prevEnableEvents = Application.EnableEvents
    prevScreenUpdating = Application.ScreenUpdating
    Application.EnableEvents = False
    Application.ScreenUpdating = False

    If ws Is Nothing Then
        Set targetWs = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    Else
        Set targetWs = ws
    End If

    lastCol = GetLastUsedCol(targetWs)
    If lastCol <= 0 Then Exit Sub

    serialCol = FindHeaderColumn(targetWs, lastCol, Array("通し番号"))
    titleCol = FindHeaderColumn(targetWs, lastCol, Array("タイトル"))

    If serialCol = 0 Then Err.Raise vbObjectError + 2101, , "通し番号 列が見つかりません。"
    If titleCol = 0 Then Err.Raise vbObjectError + 2102, , "タイトル 列が見つかりません。"

    lastRow = GetLastUsedRow(targetWs)
    If lastRow < 2 Then Exit Sub

    nextSerial = 0
    For rowNo = 2 To lastRow
        titleValue = Trim(CStr(targetWs.Cells(rowNo, titleCol).value))
        If titleValue <> "" Then
            nextSerial = nextSerial + 1
            targetWs.Cells(rowNo, serialCol).value = nextSerial
        Else
            targetWs.Cells(rowNo, serialCol).ClearContents
        End If
    Next rowNo

SafeExit:
    Application.EnableEvents = prevEnableEvents
    Application.ScreenUpdating = prevScreenUpdating

End Sub

Private Sub BuildHeaderMap(ByVal ws As Worksheet, ByVal lastCol As Long, ByVal headerMap As Object)

    Dim c As Long
    Dim rawHeader As String
    Dim canonical As String

    For c = 1 To lastCol
        rawHeader = Trim(CStr(ws.Cells(1, c).value))
        If rawHeader <> "" Then
            canonical = CanonicalHeaderName(rawHeader)
            If Not headerMap.Exists(canonical) Then
                headerMap.Add canonical, c
            End If
        End If
    Next c

End Sub

' BuildSourceHeaderMap の宣言/終端が壊れると以降で
' 「名前が適切ではありません」系エラーになりやすいため、
' ここで明示的に正しい形を維持する。
Private Sub BuildSourceHeaderMap(ByVal wsSrc As Worksheet, ByVal srcLastCol As Long, ByVal srcHeaderMap As Object)

    Dim srcCol As Long
    Dim headerText As String
    Dim canonical As String

    srcHeaderMap.RemoveAll

    For srcCol = 1 To srcLastCol
        headerText = Trim$(CStr(wsSrc.Cells(1, srcCol).Value))
        If headerText <> "" Then
            canonical = CanonicalHeaderName(headerText)
            If Not srcHeaderMap.Exists(canonical) Then
                srcHeaderMap.Add canonical, srcCol
            End If
        End If
    Next srcCol

End Sub

Private Function IsUserManagedHeader( _
    ByVal canonicalHeader As String, _
    ByVal srcHeaderMap As Object, _
    ByVal baselineUserManagedHeaders As Variant) As Boolean

    Dim i As Long
    Dim baseCanonical As String

    ' 指定された固定ユーザー管理列は常にユーザー管理とみなす
    For i = LBound(baselineUserManagedHeaders) To UBound(baselineUserManagedHeaders)
        baseCanonical = CanonicalHeaderName(CStr(baselineUserManagedHeaders(i)))
        If StrComp(canonicalHeader, baseCanonical, vbTextCompare) = 0 Then
            IsUserManagedHeader = True
            Exit Function
        End If
    Next i

    ' それ以外はCSVに存在する列をCSV管理列として扱う
    ' （新ファイル基準表だけに存在する列は転記マップに乗らないため、結果として保護される）
    IsUserManagedHeader = Not srcHeaderMap.Exists(canonicalHeader)

End Function

Private Sub BuildExistingRowMap(ByVal wsDst As Worksheet, ByVal dstLastRow As Long, ByVal existingRowMap As Object)

    Dim headerMap As Object
    Dim rowNo As Long
    Dim key As String

    existingRowMap.RemoveAll
    Set headerMap = CreateObject("Scripting.Dictionary")

    BuildSourceHeaderMap wsDst, GetLastUsedCol(wsDst), headerMap
    If Not headerMap.Exists(CanonicalHeaderName("ファイルID")) _
       Or Not headerMap.Exists(CanonicalHeaderName("ファイル番号")) _
       Or Not headerMap.Exists(CanonicalHeaderName("バーコード番号")) Then
        Err.Raise vbObjectError + 2201, , "新ファイル基準表にキー列（ファイルID/ファイル番号/バーコード番号）が見つかりません。"
    End If

    For rowNo = 2 To dstLastRow
        key = BuildFileKeyFromSheetRow(wsDst, rowNo, headerMap)
        If key <> "" Then
            If Not existingRowMap.Exists(key) Then
                existingRowMap.Add key, rowNo
            End If
        End If
    Next rowNo

End Sub

Private Sub UpdateRowFromSourceByHeader( _
    ByVal wsSrc As Worksheet, _
    ByVal wsDst As Worksheet, _
    ByVal srcRow As Long, _
    ByVal dstRow As Long, _
    ByVal srcHeaderMap As Object, _
    ByVal srcToDstMap As Object)

    Dim key As Variant
    Dim srcCol As Long
    Dim dstCol As Long
    Dim beforeValue As Variant
    Dim afterValue As Variant
    Dim beforeCompare As String
    Dim afterCompare As String
    Dim targetCell As Range

    ' CSV由来列だけを上書きし、ユーザー管理列は触らない
    ' さらに、実際に差分があるセルだけ赤字＋コメントを付与する
    For Each key In srcToDstMap.Keys
        If srcHeaderMap.Exists(CStr(key)) Then
            srcCol = CLng(srcHeaderMap(CStr(key)))
            dstCol = CLng(srcToDstMap(CStr(key)))

            Set targetCell = wsDst.Cells(dstRow, dstCol)
            beforeValue = targetCell.Value
            afterValue = wsSrc.Cells(srcRow, srcCol).Value

            ' 見出しごとの意味正規化を適用して差分判定する
            ' （毎年度利用区分は 1/2 と 毎年作成/単年のみ を同値として扱う）
            beforeCompare = NormalizeValueForUpdateCompare(CStr(key), beforeValue)
            afterCompare = NormalizeValueForUpdateCompare(CStr(key), afterValue)

            If StrComp(beforeCompare, afterCompare, vbTextCompare) <> 0 Then
                targetCell.Value = afterValue
                ApplyChangedCellHighlightAndComment targetCell, beforeValue, afterValue
            Else
                targetCell.Value = afterValue
                ClearChangedCellHighlightAndComment targetCell
            End If
        End If
    Next key

End Sub

Private Sub AppendRowFromSourceByHeader( _
    ByVal wsSrc As Worksheet, _
    ByVal wsDst As Worksheet, _
    ByVal srcRow As Long, _
    ByVal dstRow As Long, _
    ByVal srcHeaderMap As Object, _
    ByVal srcToDstMap As Object)

    Dim key As Variant
    Dim srcCol As Long
    Dim dstCol As Long

    ' 追加時は通常書式のまま値を書き込む（赤字・コメントは付与しない）
    For Each key In srcToDstMap.Keys
        If srcHeaderMap.Exists(CStr(key)) Then
            srcCol = CLng(srcHeaderMap(CStr(key)))
            dstCol = CLng(srcToDstMap(CStr(key)))
            wsDst.Cells(dstRow, dstCol).Value = wsSrc.Cells(srcRow, srcCol).Value
        End If
    Next key

End Sub

'--------------------------------------------------------
' 更新判定用の見出し別正規化
' - 通常列: NormalizeForDiffCompare
' - 毎年度利用区分: 1/2 と 毎年作成/単年のみ を同値化
'--------------------------------------------------------
Private Function NormalizeValueForUpdateCompare(ByVal headerName As String, ByVal rawValue As Variant) As String

    Dim normalized As String
    Dim compact As String

    normalized = NormalizeForDiffCompare(rawValue)

    If IsAnnualUseDivisionHeader(headerName) Then
        compact = Replace(normalized, " ", "")
        compact = Replace(compact, "　", "")

        Select Case compact
            Case "1", "毎年作成"
                NormalizeValueForUpdateCompare = "毎年作成"
                Exit Function
            Case "2", "単年のみ"
                NormalizeValueForUpdateCompare = "単年のみ"
                Exit Function
        End Select
    End If

    NormalizeValueForUpdateCompare = normalized

End Function

Private Function IsAnnualUseDivisionHeader(ByVal headerName As String) As Boolean

    Dim canonical As String

    canonical = CanonicalHeaderName(headerName)

    If canonical = CanonicalHeaderName("毎年度利用区分1:毎年作成 2:単年のみ") Then
        IsAnnualUseDivisionHeader = True
    ElseIf canonical = CanonicalHeaderName("毎年度利用区分") Then
        IsAnnualUseDivisionHeader = True
    Else
        IsAnnualUseDivisionHeader = False
    End If

End Function

'--------------------------------------------------------
' 差分ありセルへ「赤字＋コメント」を適用する
'--------------------------------------------------------
Private Sub ApplyChangedCellHighlightAndComment(ByVal targetCell As Range, ByVal beforeValue As Variant, ByVal afterValue As Variant)

    Dim commentText As String

    If targetCell Is Nothing Then Exit Sub

    targetCell.Font.Color = RGB(255, 0, 0)

    commentText = "更新前: " & CStr(beforeValue) & vbCrLf & _
                  "更新後: " & CStr(afterValue) & vbCrLf & _
                  "更新日時: " & Format$(Now, "yyyy/mm/dd hh:nn:ss")

    SafeDeleteComment targetCell
    SafeAddComment targetCell, commentText

End Sub

'--------------------------------------------------------
' 差分なしセルの赤字・コメントを通常状態へ戻す
'--------------------------------------------------------
Private Sub ClearChangedCellHighlightAndComment(ByVal targetCell As Range)

    If targetCell Is Nothing Then Exit Sub

    targetCell.Font.ColorIndex = xlColorIndexAutomatic
    SafeDeleteComment targetCell

End Sub

'--------------------------------------------------------
' コメントを安全に削除する（存在しない場合は無視）
'--------------------------------------------------------
Private Sub SafeDeleteComment(ByVal targetCell As Range)

    On Error Resume Next
    If Not targetCell.Comment Is Nothing Then targetCell.Comment.Delete
    On Error GoTo 0

End Sub

'--------------------------------------------------------
' コメントを安全に追加する
'--------------------------------------------------------
Private Sub SafeAddComment(ByVal targetCell As Range, ByVal commentText As String)

    On Error Resume Next
    targetCell.AddComment commentText
    On Error GoTo 0

End Sub

Private Function BuildFileKeyFromSheetRow(ByVal ws As Worksheet, ByVal rowNo As Long, ByVal headerMap As Object) As String

    Dim fileId As String
    Dim fileNo As String
    Dim barcodeNo As String
    Dim keyFileId As String
    Dim keyFileNo As String
    Dim keyBarcode As String

    keyFileId = CanonicalHeaderName("ファイルID")
    keyFileNo = CanonicalHeaderName("ファイル番号")
    keyBarcode = CanonicalHeaderName("バーコード番号")

    If Not headerMap.Exists(keyFileId) _
       Or Not headerMap.Exists(keyFileNo) _
       Or Not headerMap.Exists(keyBarcode) Then
        BuildFileKeyFromSheetRow = ""
        Exit Function
    End If

    fileId = GetTrimmedCell(ws, rowNo, CLng(headerMap(keyFileId)))
    fileNo = GetTrimmedCell(ws, rowNo, CLng(headerMap(keyFileNo)))
    barcodeNo = GetTrimmedCell(ws, rowNo, CLng(headerMap(keyBarcode)))

    If fileId = "" And fileNo = "" And barcodeNo = "" Then
        BuildFileKeyFromSheetRow = ""
    Else
        BuildFileKeyFromSheetRow = BuildFileKey(fileId, fileNo, barcodeNo)
    End If

End Function

'--------------------------------------------------------
' 新ファイル基準表の「同期状態」列を更新する
' 判定:
' - 現行: 今回の目録CSVキー一覧に存在
' - 削除候補: キー一致なし かつ ID系のいずれか入力あり
' - 未登録: ID系すべて空欄
'--------------------------------------------------------
Private Sub UpdateSyncStatusColumn(ByVal wsDst As Worksheet, ByVal sourceKeyMap As Object)

    Dim headerMap As Object
    Dim lastRow As Long
    Dim rowNo As Long
    Dim syncCol As Long
    Dim key As String

    If wsDst Is Nothing Then Exit Sub
    If sourceKeyMap Is Nothing Then Exit Sub

    Set headerMap = CreateObject("Scripting.Dictionary")
    BuildHeaderMap wsDst, GetLastUsedCol(wsDst), headerMap

    ' 「同期状態」列は必須列として確保
    syncCol = EnsureColumnByHeader(wsDst, headerMap, "同期状態")

    lastRow = GetLastUsedRow(wsDst)
    If lastRow < 2 Then Exit Sub

    For rowNo = 2 To lastRow
        key = BuildFileKeyFromSheetRow(wsDst, rowNo, headerMap)

        If key <> "" And sourceKeyMap.Exists(key) Then
            wsDst.Cells(rowNo, syncCol).Value = "現行"
        ElseIf HasAnyFileIdentity(wsDst, rowNo, headerMap) Then
            wsDst.Cells(rowNo, syncCol).Value = "削除候補"
        Else
            wsDst.Cells(rowNo, syncCol).Value = "未登録"
        End If
    Next rowNo

End Sub

'--------------------------------------------------------
' ファイルID / ファイル番号 / バーコード番号 のいずれかが入っているか
'--------------------------------------------------------
Private Function HasAnyFileIdentity(ByVal ws As Worksheet, ByVal rowNo As Long, ByVal headerMap As Object) As Boolean

    HasAnyFileIdentity = Not IsFileIdentityBlank(ws, rowNo, headerMap)

End Function

'--------------------------------------------------------
' ファイルID / ファイル番号 / バーコード番号 がすべて空欄か
'--------------------------------------------------------
Private Function IsFileIdentityBlank(ByVal ws As Worksheet, ByVal rowNo As Long, ByVal headerMap As Object) As Boolean

    Dim keyFileId As String
    Dim keyFileNo As String
    Dim keyBarcode As String
    Dim fileId As String
    Dim fileNo As String
    Dim barcodeNo As String

    keyFileId = CanonicalHeaderName("ファイルID")
    keyFileNo = CanonicalHeaderName("ファイル番号")
    keyBarcode = CanonicalHeaderName("バーコード番号")

    If Not headerMap.Exists(keyFileId) _
       Or Not headerMap.Exists(keyFileNo) _
       Or Not headerMap.Exists(keyBarcode) Then
        ' キー列不足時は誤判定防止のため「空欄扱い」に倒す
        IsFileIdentityBlank = True
        Exit Function
    End If

    fileId = GetTrimmedCell(ws, rowNo, CLng(headerMap(keyFileId)))
    fileNo = GetTrimmedCell(ws, rowNo, CLng(headerMap(keyFileNo)))
    barcodeNo = GetTrimmedCell(ws, rowNo, CLng(headerMap(keyBarcode)))

    IsFileIdentityBlank = (fileId = "" And fileNo = "" And barcodeNo = "")

End Function

Private Function EnsureColumnByHeader(ByVal ws As Worksheet, ByVal headerMap As Object, ByVal headerName As String) As Long

    Dim canonical As String
    Dim addCol As Long

    canonical = CanonicalHeaderName(headerName)

    If headerMap.Exists(canonical) Then
        EnsureColumnByHeader = CLng(headerMap(canonical))
    Else
        addCol = GetLastUsedCol(ws) + 1
        If addCol < 1 Then addCol = 1
        ws.Cells(1, addCol).value = headerName
        headerMap.Add canonical, addCol
        EnsureColumnByHeader = addCol
    End If

End Function

Private Function CanonicalHeaderName(ByVal headerName As String) As String

    Dim normalized As String

    normalized = Trim(CStr(headerName))
    normalized = Replace(normalized, " ", "")
    normalized = Replace(normalized, "　", "")

    Select Case normalized
        Case "分類名1", "分類名１"
            CanonicalHeaderName = "分類名１"
        Case "分類名2", "分類名２"
            CanonicalHeaderName = "分類名２"
        Case "分類名3", "分類名３"
            CanonicalHeaderName = "分類名３"
        Case "n+1", "N+1", "ｎ+1", "Ｎ+1", "n＋1", "N＋1", "Ｎ＋1", "ｎ＋1"
            CanonicalHeaderName = "ｎ＋1"
        Case Else
            CanonicalHeaderName = normalized
    End Select

End Function

Private Function FindHeaderColumn(ByVal ws As Worksheet, ByVal lastCol As Long, ByVal candidates As Variant) As Long

    Dim c As Long
    Dim i As Long
    Dim headerValue As String

    FindHeaderColumn = 0

    If lastCol <= 0 Then Exit Function

    For c = 1 To lastCol
        headerValue = Trim(CStr(ws.Cells(1, c).value))
        For i = LBound(candidates) To UBound(candidates)
            If StrComp(headerValue, CStr(candidates(i)), vbTextCompare) = 0 Then
                FindHeaderColumn = c
                Exit Function
            End If
        Next i
    Next c

End Function

Private Function GetStep2HeaderCandidates(ByVal targetHeader As String) As Variant

    Select Case targetHeader
        Case "分類名１"
            GetStep2HeaderCandidates = Array("分類名１", "分類名1")
        Case "分類名２"
            GetStep2HeaderCandidates = Array("分類名２", "分類名2")
        Case "分類名３"
            GetStep2HeaderCandidates = Array("分類名３", "分類名3")
        Case "2色名"
            GetStep2HeaderCandidates = Array("2色名", "２色名")
        Case "色名"
            GetStep2HeaderCandidates = Array("色名")
        Case "作成年度（和暦）"
            GetStep2HeaderCandidates = Array("作成年度（和暦）", "作成年度(和暦)")
        Case "ｎ＋1"
            GetStep2HeaderCandidates = Array("ｎ＋1", "ｎ+1", "Ｎ＋1", "Ｎ+1", "n＋1", "n+1", "N＋1", "N+1")
        Case Else
            GetStep2HeaderCandidates = Array(targetHeader)
    End Select

End Function

Private Function HasArrayElements(ByVal values As Variant) As Boolean

    On Error GoTo SafeExit
    If IsArray(values) Then
        HasArrayElements = (LBound(values) <= UBound(values))
    End If
    Exit Function

SafeExit:
    HasArrayElements = False

End Function

Private Sub CreateFormatAndWidthTemplate( _
    ByVal wsDst As Worksheet, _
    ByVal lastCol As Long, _
    ByVal formatTemplateMap As Object, _
    ByVal columnWidthMap As Object, _
    ByRef wsTemplate As Worksheet)

    Dim c As Long
    Dim templateCol As Long
    Dim headerText As String
    Dim canonical As String

    If lastCol <= 0 Then Exit Sub

    Set wsTemplate = ThisWorkbook.Worksheets.Add(After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count))
    wsTemplate.Visible = xlSheetVeryHidden
    wsTemplate.Name = "__FMTTMP_" & Format(Now, "hhnnss")
    templateCol = 1

    For c = 1 To lastCol
        headerText = Trim$(CStr(wsDst.Cells(1, c).Value))
        If Len(headerText) > 0 Then
            canonical = CanonicalHeaderName(headerText)
            If Not columnWidthMap.Exists(canonical) Then
                columnWidthMap.Add canonical, wsDst.Columns(c).ColumnWidth
            End If

            wsDst.Cells(2, c).Copy
            wsTemplate.Cells(1, templateCol).PasteSpecial xlPasteFormats
            Application.CutCopyMode = False
            If Not formatTemplateMap.Exists(canonical) Then
                formatTemplateMap.Add canonical, templateCol
                templateCol = templateCol + 1
            End If
        End If
    Next c

End Sub

Private Sub ReapplyFormatAndWidthFromTemplate( _
    ByVal wsDst As Worksheet, _
    ByVal formatTemplateMap As Object, _
    ByVal columnWidthMap As Object, _
    ByVal wsTemplate As Worksheet)

    Dim key As Variant
    Dim lastCol As Long
    Dim dstCol As Long
    Dim templateCol As Long
    Dim applyLastRow As Long

    If wsDst Is Nothing Then Exit Sub

    lastCol = GetLastUsedCol(wsDst)
    If lastCol <= 0 Then Exit Sub

    applyLastRow = GetLastUsedRow(wsDst)
    If applyLastRow < 2 Then applyLastRow = 2

    If Not columnWidthMap Is Nothing Then
        For Each key In columnWidthMap.Keys
            dstCol = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates(CStr(key)))
            If dstCol > 0 Then
                wsDst.Columns(dstCol).ColumnWidth = CDbl(columnWidthMap(CStr(key)))
            End If
        Next key
    End If

    If formatTemplateMap Is Nothing Then Exit Sub
    If wsTemplate Is Nothing Then Exit Sub
    If formatTemplateMap.Count = 0 Then Exit Sub

    For Each key In formatTemplateMap.Keys
        dstCol = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates(CStr(key)))
        If dstCol > 0 Then
            templateCol = CLng(formatTemplateMap(CStr(key)))
            wsTemplate.Cells(1, templateCol).Copy
            wsDst.Range(wsDst.Cells(2, dstCol), wsDst.Cells(applyLastRow, dstCol)).PasteSpecial xlPasteFormats
            Application.CutCopyMode = False
        End If
    Next key

End Sub

Private Sub HideKeyColumnsForStep2( _
    ByVal wsDst As Worksheet, _
    ByVal showHeaders As Variant, _
    ByRef missingHeadersText As String)

    Dim lastCol As Long
    Dim i As Long
    Dim colNo As Long
    Dim missing As String

    lastCol = GetLastUsedCol(wsDst)
    If lastCol <= 0 Then Exit Sub

    ' 追記: 左側固定対象見出しの不足だけを収集する（列の表示/非表示は変更しない）
    For i = LBound(showHeaders) To UBound(showHeaders)
        colNo = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates(CStr(showHeaders(i))))
        If colNo = 0 Then
            If Len(missing) > 0 Then missing = missing & vbCrLf
            missing = missing & "・" & CStr(showHeaders(i))
        End If
    Next i

    missingHeadersText = missing

End Sub

Private Sub CreateValidationTemplateSheet( _
    ByVal wsDst As Worksheet, _
    ByVal lastCol As Long, _
    ByVal validationTemplateMap As Object, _
    ByRef wsTemplate As Worksheet)

    Dim c As Long
    Dim templateCol As Long
    Dim headerText As String
    Dim canonical As String

    If lastCol <= 0 Then Exit Sub

    Set wsTemplate = ThisWorkbook.Worksheets.Add(After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count))
    wsTemplate.Visible = xlSheetVeryHidden
    wsTemplate.Name = "__DVTMP_" & Format(Now, "hhnnss")
    templateCol = 1

    ' 追記: 既存入力規則がある列だけテンプレート退避（ヘッダー名で紐づけ）
    For c = 1 To lastCol
        headerText = Trim$(CStr(wsDst.Cells(1, c).Value))
        If Len(headerText) > 0 Then
            If HasValidationRule(wsDst.Cells(2, c)) Then
                wsDst.Cells(2, c).Copy
                wsTemplate.Cells(1, templateCol).PasteSpecial xlPasteValidation
                Application.CutCopyMode = False
                canonical = CanonicalHeaderName(headerText)
                If Not validationTemplateMap.Exists(canonical) Then
                    validationTemplateMap.Add canonical, templateCol
                    templateCol = templateCol + 1
                End If
            End If
        End If
    Next c

End Sub

Private Sub ReapplyValidationFromTemplate( _
    ByVal wsDst As Worksheet, _
    ByVal validationTemplateMap As Object, _
    ByVal wsTemplate As Worksheet)

    Dim key As Variant
    Dim lastCol As Long
    Dim dstCol As Long
    Dim templateCol As Long
    Dim applyLastRow As Long

    If validationTemplateMap Is Nothing Then Exit Sub
    If wsTemplate Is Nothing Then Exit Sub
    If validationTemplateMap.Count = 0 Then Exit Sub

    lastCol = GetLastUsedCol(wsDst)
    applyLastRow = GetLastUsedRow(wsDst)
    If applyLastRow < 2 Then applyLastRow = 2

    ' 追記: 見出し名で現在列を再取得し、退避した入力規則を再適用
    For Each key In validationTemplateMap.Keys
        dstCol = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates(CStr(key)))
        If dstCol > 0 Then
            templateCol = CLng(validationTemplateMap(CStr(key)))
            wsTemplate.Cells(1, templateCol).Copy
