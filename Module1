Private Sub WriteRowByFixedLayout( _
    ByVal wsEdit As Worksheet, _
    ByVal wsOut As Worksheet, _
    ByVal srcRow As Long, _
    ByVal outRow As Long, _
    ByVal fixedHeaders As Variant, _
    ByVal editHeaderMap As Object, _
    ByVal outputSourceMap As Object)

    Dim i As Long
    Dim headerName As String
    Dim sourceHeaderName As String
    Dim editCol As Long

    For i = LBound(fixedHeaders) To UBound(fixedHeaders)
        headerName = CStr(fixedHeaders(i))

        ' 年度暦年区分は固定で「暦年」を出力（新ファイル基準表の列有無に依存させない）
        If headerName = "年度暦年区分" Then
            wsOut.Cells(outRow, i - LBound(fixedHeaders) + 1).value = "暦年"
        Else
            sourceHeaderName = headerName

            If outputSourceMap.Exists(headerName) Then
                sourceHeaderName = CStr(outputSourceMap(headerName))
            End If

            If editHeaderMap.Exists(sourceHeaderName) Then
                editCol = CLng(editHeaderMap(sourceHeaderName))
                wsOut.Cells(outRow, i - LBound(fixedHeaders) + 1).value = wsEdit.Cells(srcRow, editCol).value
            Else
                wsOut.Cells(outRow, i - LBound(fixedHeaders) + 1).value = ""
            End If
        End If
    Next i

End Sub

Public Sub 手順3_コード管理CSVを作成する()

    Dim wsSrc As Worksheet
    Dim wsDst As Worksheet
    Dim srcLastRow As Long
    Dim srcLastCol As Long
    Dim pairDefs As Variant
    Dim i As Long
    Dim r As Long
    Dim outRow As Long
    Dim codeCol As Long
    Dim nameCol As Long
    Dim codeValue As String
    Dim nameValue As String
    Dim uniqueKey As String
    Dim dict As Object

    On Error GoTo ErrorHandler

    Set wsSrc = ThisWorkbook.Worksheets(SHEET_MOKUROKU_CSV)
    Set wsDst = ThisWorkbook.Worksheets(SHEET_CODE_MANAGEMENT)
    Set dict = CreateObject("Scripting.Dictionary")

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    srcLastCol = GetLastUsedCol(wsSrc)
    srcLastRow = GetLastUsedRow(wsSrc)

    pairDefs = Array( _
        Array("原課", Array("原課ID"), Array("原課")), _
        Array("保存期間", Array("保存期間ID"), Array("保存期間")), _
        Array("分類名１", Array("分類コード１"), Array("分類名１")), _
        Array("分類名２", Array("分類コード２"), Array("分類名２")), _
        Array("分類名３", Array("分類コード３"), Array("分類名３")), _
        Array("色", Array("色ID"), Array("色名")), _
        Array("媒体種別", Array("媒体種別ID"), Array("媒体種別")) _
    )

    wsDst.Cells.Clear
    wsDst.Range("A1:C1").value = Array("項目名", "コード", "表示名")
    outRow = 2

    ' ① 実データからコード⇔表示名を抽出（見出し未存在はスキップ）
    For i = LBound(pairDefs) To UBound(pairDefs)
        codeCol = FindHeaderColumn(wsSrc, srcLastCol, pairDefs(i)(1))
        nameCol = FindHeaderColumn(wsSrc, srcLastCol, pairDefs(i)(2))
        If codeCol = 0 Or nameCol = 0 Then GoTo ContinuePairLoop

        For r = 2 To srcLastRow
            codeValue = Trim(CStr(wsSrc.Cells(r, codeCol).value))
            nameValue = Trim(CStr(wsSrc.Cells(r, nameCol).value))

            If Len(codeValue) > 0 And Len(nameValue) > 0 Then
                uniqueKey = pairDefs(i)(0) & "|" & codeValue & "|" & nameValue
                If Not dict.Exists(uniqueKey) Then
                    dict.Add uniqueKey, True
                    wsDst.Cells(outRow, 1).value = pairDefs(i)(0)
                    wsDst.Cells(outRow, 2).value = codeValue
                    wsDst.Cells(outRow, 3).value = nameValue
                    outRow = outRow + 1
                End If
            End If
        Next r
ContinuePairLoop:
    Next i

    ' ② 固定選択肢マスタを追加（重複キーで除外）
    AddCodeMasterRecord wsDst, dict, outRow, "毎年度利用区分", "1", "毎年作成"
    AddCodeMasterRecord wsDst, dict, outRow, "毎年度利用区分", "2", "単年のみ"

    AddCodeMasterRecord wsDst, dict, outRow, "年度暦年区分", "1", "年度"
    AddCodeMasterRecord wsDst, dict, outRow, "年度暦年区分", "2", "暦年"


    AddCodeMasterRecord wsDst, dict, outRow, "完結区分", "-1", "未完結"
    AddCodeMasterRecord wsDst, dict, outRow, "完結区分", "1", "完結"

    AddCodeMasterRecord wsDst, dict, outRow, "公開区分", "-1", "非公開"
    AddCodeMasterRecord wsDst, dict, outRow, "公開区分", "1", "公開"

    AddCodeMasterRecord wsDst, dict, outRow, "歴史資料区分", "-1", "非該当"
    AddCodeMasterRecord wsDst, dict, outRow, "歴史資料区分", "1", "該当"

    AddCodeMasterRecord wsDst, dict, outRow, "廃棄区分", "1", "未廃棄"
    AddCodeMasterRecord wsDst, dict, outRow, "廃棄区分", "2", "廃棄済"
    AddCodeMasterRecord wsDst, dict, outRow, "廃棄区分", "3", "不明"

    AddCodeMasterRecord wsDst, dict, outRow, "履歴ファイル区分", "-1", "非該当"
    AddCodeMasterRecord wsDst, dict, outRow, "履歴ファイル区分", "1", "該当"

    AddCodeMasterRecord wsDst, dict, outRow, "機密ファイル区分", "-1", "機密ファイル"

    With wsDst.Range("A1:C1")
        .Font.Bold = True
        .Interior.Color = RGB(242, 242, 242)
    End With

    wsDst.Range("A1:C1").AutoFilter
    wsDst.Columns("A:C").AutoFit

    MsgBox "コード管理CSV の作成が完了しました。" & vbCrLf & _
           "出力件数: " & outRow - 2 & " 件", vbInformation

SafeExit:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Exit Sub

ErrorHandler:
    MsgBox "コード管理CSV の作成中にエラーが発生しました: " & Err.Description, vbCritical
    Resume SafeExit

End Sub

Private Sub AddCodeMasterRecord( _
    ByVal wsDst As Worksheet, _
    ByVal dict As Object, _
    ByRef outRow As Long, _
    ByVal itemName As String, _
    ByVal codeValue As String, _
    ByVal displayName As String)

    Dim uniqueKey As String

    uniqueKey = itemName & "|" & Trim(codeValue) & "|" & Trim(displayName)
    If dict.Exists(uniqueKey) Then Exit Sub

    dict.Add uniqueKey, True
    wsDst.Cells(outRow, 1).value = itemName
    wsDst.Cells(outRow, 2).value = codeValue
    wsDst.Cells(outRow, 3).value = displayName
    outRow = outRow + 1

End Sub

