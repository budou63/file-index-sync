Public Sub 行移動_移動先クリックで確定(ByVal targetRow As Long)

    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean
    Dim ws As Worksheet
    Dim lastDataRow As Long
    Dim maxTargetRow As Long
    Dim blockRows As Long

    On Error GoTo ErrorHandler

    If Not gRowMoveClickModeActive Then Exit Sub

    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents

    Set ws = GetRowMoveTargetSheet()
    If ws Is Nothing Then
        CancelRowMoveClickDestinationModeInternal
        Exit Sub
    End If

    blockRows = gRowMoveClickEndRow - gRowMoveClickStartRow + 1
    If blockRows <= 0 Then
        MsgBox "移動対象行の情報が不正です。", vbExclamation
        CancelRowMoveClickDestinationModeInternal
        Exit Sub
    End If

    lastDataRow = GetLastUsedRow(ws)
    maxTargetRow = lastDataRow - blockRows + 1
    If maxTargetRow < 2 Then maxTargetRow = 2

    If targetRow < 2 Or targetRow > maxTargetRow Then
        MsgBox "移動先は 2～" & CStr(maxTargetRow) & " 行の範囲でクリックしてください。", vbExclamation
        Exit Sub
    End If

    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.CutCopyMode = False

    If ExecuteRowMoveToTargetRow(ws, gRowMoveClickStartRow, gRowMoveClickEndRow, targetRow, False) Then
        CancelRowMoveClickDestinationModeInternal
    End If

SafeExit:
    Application.CutCopyMode = False
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Exit Sub

ErrorHandler:
    MsgBox "移動先クリック確定でエラーが発生しました: " & Err.Description, vbExclamation
    CancelRowMoveClickDestinationModeInternal
    Resume SafeExit

End Sub

