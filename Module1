Option Explicit

Private Const SHEET_MOKUROKU_CSV As String = "目録CSV"
Private Const SHEET_NEW_FILE_STANDARD As String = "新ファイル基準表"
Private Const SHEET_CODE_MANAGEMENT As String = "コード管理CSV"
Private Const SHEET_DIFF_IMPORT As String = "差分インポートCSV"

Public Sub CSV取込_シンプル版()

    Dim ws As Worksheet
    Dim filePath As Variant
    Dim wbCSV As Workbook

    ' ファイル選択
    filePath = Application.GetOpenFilename("CSV Files (*.csv), *.csv")
    
    If filePath = False Then Exit Sub
    
    ' 目録CSVシート
    Set ws = ThisWorkbook.Worksheets("目録CSV")
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' クリア
    ws.Cells.Clear
    
    ' CSVを普通に開く（←これが一番大事）
    Set wbCSV = Workbooks.Open(filePath)
    
    ' そのままコピー
    wbCSV.Sheets(1).UsedRange.Copy ws.Range("A1")

    ' 見出し一致を安定させるため、取込直後に1行目の改行コードを除去
    NormalizeHeaderLineBreaks ws
    
    wbCSV.Close False
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    
    MsgBox "CSV取込完了"

End Sub

Private Sub NormalizeHeaderLineBreaks(ByVal ws As Worksheet)

    Dim lastCol As Long
    Dim c As Range

    On Error GoTo SafeExit

    lastCol = GetLastUsedCol(ws)
    If lastCol <= 0 Then Exit Sub

    For Each c In ws.Range(ws.Cells(1, 1), ws.Cells(1, lastCol))
        If Not IsEmpty(c.value) Then
            c.value = Replace(CStr(c.value), vbCrLf, "")
            c.value = Replace(CStr(c.value), vbCr, "")
            c.value = Replace(CStr(c.value), vbLf, "")
        End If
    Next c

SafeExit:
    ' 改行除去は補助処理のため、失敗しても取込本体を止めない

End Sub

Public Sub 手順4_差分インポートCSVを作成する()

    Dim wsSrc As Worksheet
    Dim wsEdit As Worksheet
    Dim wsOut As Worksheet
    Dim srcLastRow As Long
    Dim srcLastCol As Long
    Dim editLastRow As Long
    Dim editLastCol As Long
    Dim r As Long
    Dim outRow As Long
    Dim keyFileIdSrc As Long, keyFileNoSrc As Long, keyBarcodeSrc As Long
    Dim keyFileIdEdit As Long, keyFileNoEdit As Long, keyBarcodeEdit As Long
    Dim titleColEdit As Long
    Dim compareDefs As Variant
    Dim fixedHeaders As Variant
    Dim compareSrcCols() As Long
    Dim compareEditCols() As Long
    Dim i As Long
    Dim srcDict As Object
    Dim editHeaderMap As Object
    Dim outputSourceMap As Object
    Dim key As String
    Dim isDifferent As Boolean
    Dim srcRow As Long
    Dim fileIdVal As String, fileNoVal As String, barcodeVal As String
    Dim titleVal As String

    On Error GoTo ErrorHandler

    Set wsSrc = ThisWorkbook.Worksheets(SHEET_MOKUROKU_CSV)
    Set wsEdit = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    Set wsOut = ThisWorkbook.Worksheets(SHEET_DIFF_IMPORT)
    Set srcDict = CreateObject("Scripting.Dictionary")
    Set editHeaderMap = CreateObject("Scripting.Dictionary")
    Set outputSourceMap = CreateObject("Scripting.Dictionary")

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    srcLastRow = GetLastUsedRow(wsSrc)
    srcLastCol = GetLastUsedCol(wsSrc)
    editLastRow = GetLastUsedRow(wsEdit)
    editLastCol = GetLastUsedCol(wsEdit)

    keyFileIdSrc = FindHeaderColumn(wsSrc, srcLastCol, Array("ファイルID"))
    keyFileNoSrc = FindHeaderColumn(wsSrc, srcLastCol, Array("ファイル番号"))
    keyBarcodeSrc = FindHeaderColumn(wsSrc, srcLastCol, Array("バーコード番号"))

    keyFileIdEdit = FindHeaderColumn(wsEdit, editLastCol, Array("ファイルID"))
    keyFileNoEdit = FindHeaderColumn(wsEdit, editLastCol, Array("ファイル番号"))
    keyBarcodeEdit = FindHeaderColumn(wsEdit, editLastCol, Array("バーコード番号"))
    titleColEdit = FindHeaderColumn(wsEdit, editLastCol, Array("タイトル"))

    compareDefs = Array("分類名１", "分類名２", "分類名３", "タイトル", "保存期間", "媒体種別")
    ReDim compareSrcCols(LBound(compareDefs) To UBound(compareDefs))
    ReDim compareEditCols(LBound(compareDefs) To UBound(compareDefs))

    For i = LBound(compareDefs) To UBound(compareDefs)
        compareSrcCols(i) = FindHeaderColumn(wsSrc, srcLastCol, Array(CStr(compareDefs(i))))
        compareEditCols(i) = FindHeaderColumn(wsEdit, editLastCol, Array(CStr(compareDefs(i))))
    Next i

    fixedHeaders = Array( _
        "年度", "所管所属", "所管所属名称", "タイトル", "サブタイトル", "保存期間", "保存期間満了時の措置", "保管期間", "保管期間完了予定年", _
        "分類コード１", "分類名１", "分類コード２", "分類名２", "分類コード３", "分類名３", "分類コード４", "分類名４", "分類コード５", "分類名５", _
        "毎年度利用区分", "年度暦年区分", "色", "保管媒体区分", "保存場所・箱コード１", "保存場所・箱名１", "箱サイン１", "保存場所・箱コード２", "保存場所・箱名２", "箱サイン２", _
        "保存場所・箱コード３", "保存場所・箱名３", "箱サイン３", "保存場所・箱コード４", "保存場所・箱名４", "箱サイン４", "保存場所・箱コード５", "保存場所・箱名５", "箱サイン５", _
        "ラベル種類", "背表紙用タイトル", "背表紙用サブタイトル", "公開用タイトル", "公開用サブタイトル", "公開区分", "歴史資料区分", "内容・取扱い", "備考", _
        "作成所属", "作成年度", "作成者", "機密レベル", "汎用項目１", "汎用項目２", "汎用項目３", "汎用項目４", "汎用項目５", "汎用項目６", "汎用項目７", "汎用項目８", "汎用項目９", "汎用項目１０", _
        "汎用日付項目１", "汎用日付項目２", "汎用日付項目３", "汎用日付項目４", "汎用日付項目５", _
        "汎用数値項目１", "汎用数値項目２", "汎用数値項目３", "汎用数値項目４", "汎用数値項目５", _
        "汎用選択項目１", "汎用選択項目２", "汎用選択項目３", "汎用選択項目４", "汎用選択項目５", _
        "汎用チェック項目１", "汎用チェック項目２", "汎用チェック項目３", "汎用チェック項目４", "汎用チェック項目５", _
        "ファイルラベル区分名", "ファイルラベル区分サイズ", "場所内のファイルのソート")

    ' 新ファイル基準表の見出しを辞書化（固定見出しとの同名照合で使用）
    For i = 1 To editLastCol
        If Len(Trim(CStr(wsEdit.Cells(1, i).value))) > 0 Then
            If Not editHeaderMap.Exists(Trim(CStr(wsEdit.Cells(1, i).value))) Then
                editHeaderMap.Add Trim(CStr(wsEdit.Cells(1, i).value)), i
            End If
        End If
    Next i

    ' 出力見出し -> 取得元見出し のマッピング定義
    ' 固定見出し「所管所属」は新ファイル基準表の「原課ID」から取得する
    outputSourceMap.Add "所管所属", "原課ID"
    ' 固定見出し「毎年度利用区分」は新ファイル基準表の正式見出しから取得する
    outputSourceMap.Add "毎年度利用区分", "毎年度利用区分1:毎年作成 2:単年のみ"

    ' ① 目録CSVをキーで辞書化
    For r = 2 To srcLastRow
        fileIdVal = GetTrimmedCell(wsSrc, r, keyFileIdSrc)
        fileNoVal = GetTrimmedCell(wsSrc, r, keyFileNoSrc)
        barcodeVal = GetTrimmedCell(wsSrc, r, keyBarcodeSrc)
        key = BuildFileKey(fileIdVal, fileNoVal, barcodeVal)

        If Not (fileIdVal = "" And fileNoVal = "" And barcodeVal = "") Then
            If Not srcDict.Exists(key) Then
                srcDict.Add key, r
            End If
        End If
    Next r

    wsOut.Cells.Clear
    ' 1行目に固定見出しを厳密順で出力
    For i = LBound(fixedHeaders) To UBound(fixedHeaders)
        wsOut.Cells(1, i - LBound(fixedHeaders) + 1).value = fixedHeaders(i)
    Next i
    outRow = 2

    ' ② 新ファイル基準表を1行ずつ処理
    For r = 2 To editLastRow
        fileIdVal = GetTrimmedCell(wsEdit, r, keyFileIdEdit)
        fileNoVal = GetTrimmedCell(wsEdit, r, keyFileNoEdit)
        barcodeVal = GetTrimmedCell(wsEdit, r, keyBarcodeEdit)
        titleVal = GetTrimmedCell(wsEdit, r, titleColEdit)
        key = BuildFileKey(fileIdVal, fileNoVal, barcodeVal)

        ' A. キー3項目がすべて空白 -> 新規追加候補
        If fileIdVal = "" And fileNoVal = "" And barcodeVal = "" Then
            If titleVal <> "" Then
                WriteRowByFixedLayout wsEdit, wsOut, r, outRow, fixedHeaders, editHeaderMap, outputSourceMap
                outRow = outRow + 1
            End If

        ' B. キー一致する行が存在 -> 比較列に差異があれば更新行として出力
        ElseIf srcDict.Exists(key) Then
            srcRow = CLng(srcDict(key))
            isDifferent = False

            For i = LBound(compareDefs) To UBound(compareDefs)
                If compareSrcCols(i) > 0 And compareEditCols(i) > 0 Then
                    If GetTrimmedCell(wsSrc, srcRow, compareSrcCols(i)) <> _
                       GetTrimmedCell(wsEdit, r, compareEditCols(i)) Then
                        isDifferent = True
                        Exit For
                    End If
                End If
            Next i

            If isDifferent Then
                WriteRowByFixedLayout wsEdit, wsOut, r, outRow, fixedHeaders, editHeaderMap, outputSourceMap
                outRow = outRow + 1
            End If
        End If
        ' C. キー一致しないがキー空白でない場合は無視
    Next r

    With wsOut.Range(wsOut.Cells(1, 1), wsOut.Cells(1, UBound(fixedHeaders) - LBound(fixedHeaders) + 1))
        .Font.Bold = True
        .Interior.Color = RGB(242, 242, 242)
        .AutoFilter
    End With
    wsOut.Columns(1).Resize(, UBound(fixedHeaders) - LBound(fixedHeaders) + 1).EntireColumn.AutoFit

    MsgBox "差分インポートCSV の作成が完了しました。" & vbCrLf & _
           "出力件数: " & outRow - 2 & " 件", vbInformation

SafeExit:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Exit Sub

ErrorHandler:
    MsgBox "差分インポートCSV の作成中にエラーが発生しました: " & Err.Description, vbExclamation
    Resume SafeExit

End Sub

Public Sub 手順2_新ファイル基準表を作成する()

    Dim wsSrc As Worksheet
    Dim wsDst As Worksheet
    Dim srcLastRow As Long
    Dim srcLastCol As Long
    Dim dstLastCol As Long
    Dim displayHeaders As Variant
    Dim userManagedHeaders As Variant
    Dim srcToDstMap As Object
    Dim existingDstHeaders As Object
    Dim srcCol As Long
    Dim dstCol As Long
    Dim headerText As String
    Dim canonical As String
    Dim i As Long
    Dim targetCol As Long
    Dim foundCol As Long
    Dim leftFixedCount As Long
    Dim clearFromRow As Long
    Dim clearToRow As Long

    On Error GoTo ErrorHandler

    Set wsSrc = ThisWorkbook.Worksheets(SHEET_MOKUROKU_CSV)
    Set wsDst = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    Set srcToDstMap = CreateObject("Scripting.Dictionary")
    Set existingDstHeaders = CreateObject("Scripting.Dictionary")

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    srcLastCol = GetLastUsedCol(wsSrc)
    srcLastRow = GetLastUsedRow(wsSrc)
    dstLastCol = GetLastUsedCol(wsDst)

    If srcLastCol <= 0 Then Err.Raise vbObjectError + 2001, , "目録CSV の見出し行が見つかりません。"

    displayHeaders = Array( _
        "通し番号", _
        "キャビネット番号", _
        "ｎ＋1", _
        "毎年度利用区分1:毎年作成 2:単年のみ", _
        "原課", _
        "年度（和暦）", _
        "分類名１", _
        "分類名２", _
        "分類名３", _
        "タイトル", _
        "保存期間", _
        "媒体種別")
    userManagedHeaders = Array("通し番号", "キャビネット番号", "ｎ＋1")

    ' 1) 既存「新ファイル基準表」の見出しを辞書化（追加列保持のため）
    BuildHeaderMap wsDst, dstLastCol, existingDstHeaders

    ' 2) ユーザー管理列（CSV由来ではない3列）を確保
    For i = LBound(userManagedHeaders) To UBound(userManagedHeaders)
        EnsureColumnByHeader wsDst, existingDstHeaders, CStr(userManagedHeaders(i))
    Next i

    ' 3) CSV由来列を「見出し名ベース」で同期（不足列は追加、既存追加列は維持）
    For srcCol = 1 To srcLastCol
        headerText = Trim(CStr(wsSrc.Cells(1, srcCol).Value))
        If headerText <> "" Then
            canonical = CanonicalHeaderName(headerText)
            dstCol = EnsureColumnByHeader(wsDst, existingDstHeaders, headerText)
            srcToDstMap(canonical) = dstCol
        End If
    Next srcCol

    ' 4) CSV由来列のみ値を更新（2行目以降）。管理列・追加列は壊さない。
    clearFromRow = srcLastRow + 1
    clearToRow = GetLastUsedRow(wsDst)
    For srcCol = 1 To srcLastCol
        headerText = Trim(CStr(wsSrc.Cells(1, srcCol).Value))
        If headerText <> "" Then
            canonical = CanonicalHeaderName(headerText)
            If srcToDstMap.Exists(canonical) Then
                dstCol = CLng(srcToDstMap(canonical))
                wsDst.Cells(1, dstCol).Value = headerText
                If srcLastRow >= 2 Then
                    wsDst.Range(wsDst.Cells(2, dstCol), wsDst.Cells(srcLastRow, dstCol)).Value = _
                        wsSrc.Range(wsSrc.Cells(2, srcCol), wsSrc.Cells(srcLastRow, srcCol)).Value
                End If
                If clearToRow >= clearFromRow Then
                    wsDst.Range(wsDst.Cells(clearFromRow, dstCol), wsDst.Cells(clearToRow, dstCol)).ClearContents
                End If
            End If
        End If
    Next srcCol

    ' 5) 主要列だけ左側へ並べ直し（それ以外は削除せず後ろに残す）
    targetCol = 1
    For i = LBound(displayHeaders) To UBound(displayHeaders)
        srcLastCol = GetLastUsedCol(wsDst)
        foundCol = FindHeaderColumn(wsDst, srcLastCol, GetStep2HeaderCandidates(CStr(displayHeaders(i))))

        If foundCol > 0 Then
            If foundCol <> targetCol Then
                wsDst.Columns(foundCol).Cut
                wsDst.Columns(targetCol).Insert Shift:=xlToRight
                Application.CutCopyMode = False
            End If
            targetCol = targetCol + 1
        End If
    Next i
    leftFixedCount = targetCol - 1

    ' 6) 「毎年度利用区分」表示値変換（目録CSVは変更しない）
    ConvertAnnualUseDivisionValues wsDst, srcLastRow

    ' 7) 主要列の見た目のみ整える（既存追加列の表示/非表示状態は壊さない）
    If leftFixedCount > 0 Then
        With wsDst.Range(wsDst.Cells(1, 1), wsDst.Cells(1, leftFixedCount))
            .Font.Bold = True
            .Interior.Color = RGB(242, 242, 242)
        End With
        wsDst.Range(wsDst.Columns(1), wsDst.Columns(leftFixedCount)).EntireColumn.AutoFit
    End If

    srcLastCol = GetLastUsedCol(wsDst)
    wsDst.Range(wsDst.Cells(1, 1), wsDst.Cells(1, srcLastCol)).AutoFilter

    ' 8) キー列は保持したまま非表示（後続処理で利用）
    HideKeyColumnsForStep2 wsDst

    ' 9) タイトルがある行だけ通し番号を再採番
    ReindexSerial_NewFileStandard wsDst

    MsgBox "新ファイル基準表の作成が完了しました。" & vbCrLf & _
           "左側に固定した主要列数: " & leftFixedCount & " 列", vbInformation

SafeExit:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Exit Sub

ErrorHandler:
    MsgBox "新ファイル基準表の作成中にエラーが発生しました: " & Err.Description, vbCritical
    Resume SafeExit

End Sub

Public Sub 通し番号_再採番_新ファイル基準表()

    On Error GoTo ErrorHandler

    ReindexSerial_NewFileStandard ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    MsgBox "新ファイル基準表の通し番号を再採番しました。", vbInformation
    Exit Sub

ErrorHandler:
    MsgBox "通し番号の再採番中にエラーが発生しました: " & Err.Description, vbExclamation

End Sub

Public Sub ReindexSerial_NewFileStandard(Optional ByVal ws As Worksheet)

    Dim targetWs As Worksheet
    Dim lastCol As Long
    Dim lastRow As Long
    Dim serialCol As Long
    Dim titleCol As Long
    Dim rowNo As Long
    Dim nextSerial As Long
    Dim titleValue As String
    Dim prevEnableEvents As Boolean
    Dim prevScreenUpdating As Boolean

    On Error GoTo SafeExit

    prevEnableEvents = Application.EnableEvents
    prevScreenUpdating = Application.ScreenUpdating
    Application.EnableEvents = False
    Application.ScreenUpdating = False

    If ws Is Nothing Then
        Set targetWs = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    Else
        Set targetWs = ws
    End If

    lastCol = GetLastUsedCol(targetWs)
    If lastCol <= 0 Then Exit Sub

    serialCol = FindHeaderColumn(targetWs, lastCol, Array("通し番号"))
    titleCol = FindHeaderColumn(targetWs, lastCol, Array("タイトル"))

    If serialCol = 0 Then Err.Raise vbObjectError + 2101, , "通し番号 列が見つかりません。"
    If titleCol = 0 Then Err.Raise vbObjectError + 2102, , "タイトル 列が見つかりません。"

    lastRow = GetLastUsedRow(targetWs)
    If lastRow < 2 Then Exit Sub

    nextSerial = 0
    For rowNo = 2 To lastRow
        titleValue = Trim(CStr(targetWs.Cells(rowNo, titleCol).Value))
        If titleValue <> "" Then
            nextSerial = nextSerial + 1
            targetWs.Cells(rowNo, serialCol).Value = nextSerial
        Else
            targetWs.Cells(rowNo, serialCol).ClearContents
        End If
    Next rowNo

SafeExit:
    Application.EnableEvents = prevEnableEvents
    Application.ScreenUpdating = prevScreenUpdating

End Sub

Private Sub BuildHeaderMap(ByVal ws As Worksheet, ByVal lastCol As Long, ByVal headerMap As Object)

    Dim c As Long
    Dim rawHeader As String
    Dim canonical As String

    For c = 1 To lastCol
        rawHeader = Trim(CStr(ws.Cells(1, c).Value))
        If rawHeader <> "" Then
            canonical = CanonicalHeaderName(rawHeader)
            If Not headerMap.Exists(canonical) Then
                headerMap.Add canonical, c
            End If
        End If
    Next c

End Sub

Private Function EnsureColumnByHeader(ByVal ws As Worksheet, ByVal headerMap As Object, ByVal headerName As String) As Long

    Dim canonical As String
    Dim addCol As Long

    canonical = CanonicalHeaderName(headerName)

    If headerMap.Exists(canonical) Then
        EnsureColumnByHeader = CLng(headerMap(canonical))
    Else
        addCol = GetLastUsedCol(ws) + 1
        If addCol < 1 Then addCol = 1
        ws.Cells(1, addCol).Value = headerName
        headerMap.Add canonical, addCol
        EnsureColumnByHeader = addCol
    End If

End Function

Private Function CanonicalHeaderName(ByVal headerName As String) As String

    Dim normalized As String

    normalized = Trim(CStr(headerName))
    normalized = Replace(normalized, " ", "")
    normalized = Replace(normalized, "　", "")

    Select Case normalized
        Case "分類名1", "分類名１"
            CanonicalHeaderName = "分類名１"
        Case "分類名2", "分類名２"
            CanonicalHeaderName = "分類名２"
        Case "分類名3", "分類名３"
            CanonicalHeaderName = "分類名３"
        Case "n+1", "N+1", "ｎ+1", "Ｎ+1", "n＋1", "N＋1", "Ｎ＋1", "ｎ＋1"
            CanonicalHeaderName = "ｎ＋1"
        Case Else
            CanonicalHeaderName = normalized
    End Select

End Function

Private Function FindHeaderColumn(ByVal ws As Worksheet, ByVal lastCol As Long, ByVal candidates As Variant) As Long

    Dim c As Long
    Dim i As Long
    Dim headerValue As String

    FindHeaderColumn = 0

    If lastCol <= 0 Then Exit Function

    For c = 1 To lastCol
        headerValue = Trim(CStr(ws.Cells(1, c).value))
        For i = LBound(candidates) To UBound(candidates)
            If StrComp(headerValue, CStr(candidates(i)), vbTextCompare) = 0 Then
                FindHeaderColumn = c
                Exit Function
            End If
        Next i
    Next c

End Function

Private Function GetStep2HeaderCandidates(ByVal targetHeader As String) As Variant

    Select Case targetHeader
        Case "分類名１"
            GetStep2HeaderCandidates = Array("分類名１", "分類名1")
        Case "分類名２"
            GetStep2HeaderCandidates = Array("分類名２", "分類名2")
        Case "分類名３"
            GetStep2HeaderCandidates = Array("分類名３", "分類名3")
        Case "ｎ＋1"
            GetStep2HeaderCandidates = Array("ｎ＋1", "ｎ+1", "Ｎ＋1", "Ｎ+1", "n＋1", "n+1", "N＋1", "N+1")
        Case Else
            GetStep2HeaderCandidates = Array(targetHeader)
    End Select

End Function

Private Sub HideKeyColumnsForStep2(ByVal wsDst As Worksheet)

    Dim lastCol As Long
    Dim keyHeaders As Variant
    Dim showHeaders As Variant
    Dim i As Long
    Dim colNo As Long

    lastCol = GetLastUsedCol(wsDst)
    keyHeaders = Array("ファイルID", "ファイル番号", "バーコード番号")
    showHeaders = Array("毎年度利用区分1:毎年作成 2:単年のみ", "原課", "年度（和暦）", "分類名１", "分類名２", "分類名３", "タイトル", "保存期間", "媒体種別")

    ' キー列は非表示にする（列自体は保持）
    For i = LBound(keyHeaders) To UBound(keyHeaders)
        colNo = FindHeaderColumn(wsDst, lastCol, Array(CStr(keyHeaders(i))))
        If colNo > 0 Then wsDst.Columns(colNo).Hidden = True
    Next i

    ' 編集対象列は表示状態に戻す（見出し未存在はスキップ）
    For i = LBound(showHeaders) To UBound(showHeaders)
        colNo = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates(CStr(showHeaders(i))))
        If colNo > 0 Then wsDst.Columns(colNo).Hidden = False
    Next i

End Sub

Private Sub ConvertAnnualUseDivisionValues(ByVal wsDst As Worksheet, ByVal lastRow As Long)

    Dim lastCol As Long
    Dim targetCol As Long
    Dim r As Long
    Dim cellValue As String

    lastCol = GetLastUsedCol(wsDst)
    targetCol = FindHeaderColumn(wsDst, lastCol, Array("毎年度利用区分1:毎年作成 2:単年のみ"))
    If targetCol = 0 Then Exit Sub

    For r = 2 To lastRow
        cellValue = Trim(CStr(wsDst.Cells(r, targetCol).value))
        Select Case cellValue
            Case "1"
                wsDst.Cells(r, targetCol).value = "毎年作成"
            Case "2"
                wsDst.Cells(r, targetCol).value = "単年のみ"
            Case Else
                ' 空白または定義外はそのまま
        End Select
    Next r

End Sub

Private Function GetTrimmedCell(ByVal ws As Worksheet, ByVal rowNo As Long, ByVal colNo As Long) As String

