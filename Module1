'========================================================
' 個別フォルダシール（複数）: 大量作成（開始/終了はInputBox指定）
' - 抽出条件:
'   1) 新ファイル基準表で可視行
'   2) 通し番号が開始～終了範囲内
' - 12件ごとに1ページ（縦に連結配置）
'========================================================
Public Sub 個別フォルダシール_大量作成()

    Dim startNo As Variant
    Dim endNo As Variant

    startNo = Application.InputBox("大量出力する通し番号の開始値を入力してください。", "個別フォルダシール（複数）", Type:=1)
    If startNo = False Then Exit Sub

    endNo = Application.InputBox("大量出力する通し番号の終了値を入力してください。", "個別フォルダシール（複数）", Type:=1)
    If endNo = False Then Exit Sub

    GenerateMultiSealSheets_NewSpec CLng(startNo), CLng(endNo)

End Sub

Public Sub GenerateMultiSealSheets_NewSpec(ByVal startNo As Long, ByVal endNo As Long)

    Const MULTI_SHEET_NAME As String = "個別フォルダシール（複数）"
    Const SINGLE_SHEET_NAME1 As String = "個別フォルダシール"
    Const SINGLE_SHEET_NAME2 As String = "個別フォルダーシール"
    Const SINGLE_SHEET_NAME3 As String = "フォルダシール"
    ' 1ページ = 20行（テンプレート「個別フォルダシール」1～20行）
    Const PAGE_ROWS As Long = 20
    ' NOTE:
    ' 右側ブロックの結合セル（M:U / S:U）をテンプレート通りに維持するため、
    ' ページ複製範囲は U 列(21) までを対象にする。
    Const PAGE_LAST_COL As Long = 21

    Dim wsSrc As Worksheet
    Dim wsSingle As Worksheet
    Dim wsMulti As Worksheet
    Dim serialIndex As Object
    Dim headerIndex As Object
    Dim targetRows As Collection
    Dim srcLastRow As Long
    Dim serialCol As Long
    Dim r As Long
    Dim serialVal As String
    Dim serialNo As Long
    Dim pageCount As Long
    Dim pageNo As Long
    Dim slot As Long
    Dim idx As Long
    Dim pageTopRow As Long
    Dim srcRow As Long
    Dim printLastRow As Long
    Dim c As Long
    Dim requiredBlocks As Long
    Dim generatedBlocks As Long
    Dim addPageNo As Long
    Dim clearPageNo As Long

    On Error GoTo ErrorHandler

    If startNo <= 0 Or endNo <= 0 Then
        Err.Raise vbObjectError + 2301, , "開始値/終了値は 1 以上の数値を指定してください。"
    End If
    If startNo > endNo Then
        Err.Raise vbObjectError + 2302, , "開始番号は終了番号以下にしてください。"
    End If

    Set wsSrc = ResolveWorksheetByCandidates(ThisWorkbook, Array(SHEET_NEW_FILE_STANDARD))
    Set wsSingle = ResolveWorksheetByCandidates(ThisWorkbook, Array(SINGLE_SHEET_NAME1, SINGLE_SHEET_NAME2, SINGLE_SHEET_NAME3))
    Set wsMulti = ResolveWorksheetByCandidates(ThisWorkbook, Array(MULTI_SHEET_NAME))

    If wsSrc Is Nothing Then Err.Raise vbObjectError + 2303, , "新ファイル基準表シートが見つかりません。"
    If wsSingle Is Nothing Then Err.Raise vbObjectError + 2304, , "単発用の個別フォルダシールシートが見つかりません。"
    If wsMulti Is Nothing Then Err.Raise vbObjectError + 2305, , "大量出力用シート「" & MULTI_SHEET_NAME & "」が見つかりません。"

    frmSeal.BuildIndexes_NewSpec wsSrc, serialIndex, headerIndex
    serialCol = CLng(headerIndex("通し番号"))
    If serialCol = 0 Then Err.Raise vbObjectError + 2306, , "見出し「通し番号」が見つかりません。"

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    Set targetRows = New Collection
    srcLastRow = GetLastUsedRow(wsSrc)

    For r = 2 To srcLastRow
        If Not wsSrc.Rows(r).Hidden Then
            serialVal = Trim$(CStr(wsSrc.Cells(r, serialCol).Value))
            If Len(serialVal) > 0 And IsNumeric(serialVal) Then
                serialNo = CLng(Val(serialVal))
                If serialNo >= startNo And serialNo <= endNo Then
                    targetRows.Add r
                End If
            End If
        End If
    Next r

    ' 追記: 列幅はテンプレート（単発用1ページ目）と一致させる
    For c = 1 To PAGE_LAST_COL
        wsMulti.Columns(c).ColumnWidth = wsSingle.Columns(c).ColumnWidth
    Next c
    ' 追記: 印刷ズレ抑制のためページ設定もテンプレートに合わせる
    ApplyPageSetupFromTemplate wsSingle, wsMulti

    If targetRows.Count = 0 Then
        Err.Raise vbObjectError + 2307, , "該当するデータがありません。"
    End If

    pageCount = (targetRows.Count + 11) \ 12
    requiredBlocks = pageCount
    generatedBlocks = GetGeneratedSealBlockCount(wsMulti, PAGE_ROWS)

    ' 既存ブロックを再利用し、不足分のみ12面単位で追加
    If generatedBlocks < requiredBlocks Then
        For addPageNo = generatedBlocks + 1 To requiredBlocks
            pageTopRow = (addPageNo - 1) * PAGE_ROWS + 1
            CopySealTemplatePageLayout wsSingle, wsMulti, pageTopRow, PAGE_ROWS, PAGE_LAST_COL
        Next addPageNo
        generatedBlocks = requiredBlocks
    End If

    ' 12面ブロックごとに改ページを固定（既存ブロックも含めて再設定）
    ConfigureSealPageBreaks wsMulti, PAGE_ROWS, generatedBlocks

    For pageNo = 1 To pageCount
        pageTopRow = (pageNo - 1) * PAGE_ROWS + 1

        For slot = 1 To 12
            idx = (pageNo - 1) * 12 + slot
            If idx <= targetRows.Count Then
                srcRow = CLng(targetRows(idx))
                WriteOneSeal_NewSpec_WithRowOffset _
                    wsSrc, srcRow, wsMulti, slot, (pageTopRow - 1), _
                    CLng(headerIndex("タイトル")), _
                    CLng(headerIndex("分類名2")), _
                    CLng(headerIndex("分類名3")), _
                    CLng(headerIndex("年度和暦")), _
                    CLng(headerIndex("保存期間"))
            Else
                ClearOneSealSlot_WithRowOffset wsMulti, slot, (pageTopRow - 1)
            End If
        Next slot
    Next pageNo

    ' 今回未使用の既存ブロックは削除せず残し、値だけクリア
    If generatedBlocks > pageCount Then
        For clearPageNo = pageCount + 1 To generatedBlocks
            For slot = 1 To 12
                ClearOneSealSlot_WithRowOffset wsMulti, slot, (clearPageNo - 1) * PAGE_ROWS
            Next slot
        Next clearPageNo
    End If

    printLastRow = pageCount * PAGE_ROWS
    wsMulti.PageSetup.PrintArea = wsMulti.Range(wsMulti.Cells(1, 1), wsMulti.Cells(printLastRow, PAGE_LAST_COL)).Address

    MsgBox "個別フォルダシール（複数）を作成しました。" & vbCrLf & _
           "対象件数: " & targetRows.Count & " 件" & vbCrLf & _
           "ページ数: " & pageCount & " ページ", vbInformation

SafeExit:
    Application.CutCopyMode = False
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Exit Sub

ErrorHandler:
    MsgBox "大量作成でエラーが発生しました: " & Err.Description, vbExclamation
    Resume SafeExit

End Sub

Private Function GetGeneratedSealBlockCount(ByVal ws As Worksheet, ByVal pageRows As Long) As Long

    Dim areaText As String
    Dim rngPrint As Range
    Dim rowBottom As Long

    On Error GoTo Fallback

    areaText = Trim$(ws.PageSetup.PrintArea)
    If Len(areaText) > 0 Then
        Set rngPrint = ws.Range(areaText)
        rowBottom = rngPrint.Row + rngPrint.Rows.Count - 1
        If rowBottom > 0 Then
            GetGeneratedSealBlockCount = (rowBottom + pageRows - 1) \ pageRows
            Exit Function
        End If
    End If

Fallback:
    If Application.WorksheetFunction.CountA(ws.Range(ws.Cells(1, 1), ws.Cells(pageRows, 1))) > 0 Then
        GetGeneratedSealBlockCount = 1
    Else
        GetGeneratedSealBlockCount = 0
    End If

End Function

Private Sub ConfigureSealPageBreaks(ByVal ws As Worksheet, ByVal pageRows As Long, ByVal blockCount As Long)

    Dim pageNo As Long
    Dim pageTopRow As Long

    ws.ResetAllPageBreaks

    If blockCount <= 1 Then Exit Sub

    For pageNo = 2 To blockCount
        pageTopRow = (pageNo - 1) * pageRows + 1
        ws.HPageBreaks.Add Before:=ws.Cells(pageTopRow, 1)
    Next pageNo

End Sub

Private Sub ApplyPageSetupFromTemplate(ByVal wsTemplate As Worksheet, ByVal wsDst As Worksheet)

    With wsDst.PageSetup
        .Orientation = wsTemplate.PageSetup.Orientation
        .PaperSize = wsTemplate.PageSetup.PaperSize
        .Zoom = wsTemplate.PageSetup.Zoom
        .FitToPagesWide = wsTemplate.PageSetup.FitToPagesWide
        .FitToPagesTall = wsTemplate.PageSetup.FitToPagesTall
        .TopMargin = wsTemplate.PageSetup.TopMargin
        .BottomMargin = wsTemplate.PageSetup.BottomMargin
        .LeftMargin = wsTemplate.PageSetup.LeftMargin
        .RightMargin = wsTemplate.PageSetup.RightMargin
        .HeaderMargin = wsTemplate.PageSetup.HeaderMargin
        .FooterMargin = wsTemplate.PageSetup.FooterMargin
        .CenterHorizontally = wsTemplate.PageSetup.CenterHorizontally
        .CenterVertically = wsTemplate.PageSetup.CenterVertically
    End With

End Sub

Private Sub CopySealTemplatePageLayout( _
    ByVal wsTemplate As Worksheet, _
    ByVal wsDst As Worksheet, _
    ByVal dstTopRow As Long, _
    ByVal pageRows As Long, _
    ByVal pageLastCol As Long)

    Dim r As Long
    Dim c As Long

    wsTemplate.Range(wsTemplate.Cells(1, 1), wsTemplate.Cells(pageRows, pageLastCol)).Copy
    wsDst.Cells(dstTopRow, 1).PasteSpecial xlPasteAll
    Application.CutCopyMode = False

    ' 追記: 行高は PasteAll だけでは不一致になり得るため明示コピー
    For r = 1 To pageRows
        wsDst.Rows(dstTopRow + r - 1).RowHeight = wsTemplate.Rows(r).RowHeight
    Next r

    ' 追記: 列幅もテンプレート値を明示的に維持
    For c = 1 To pageLastCol
        wsDst.Columns(c).ColumnWidth = wsTemplate.Columns(c).ColumnWidth
    Next c

End Sub

Private Sub WriteOneSeal_NewSpec_WithRowOffset( _
    ByVal wsSrc As Worksheet, _
    ByVal srcRow As Long, _
    ByVal wsSeal As Worksheet, _
    ByVal slot As Long, _
    ByVal rowOffset As Long, _
    ByVal colTitle As Long, _
    ByVal colClass2 As Long, _
    ByVal colClass3 As Long, _
    ByVal colWareki As Long, _
    ByVal colSaveTerm As Long)

    Dim baseCol As Long
    Dim baseRow As Long
    Dim offSlash As Long
    Dim offG1 As Long
    Dim vTitle As String
    Dim vClass2 As String
    Dim vClass3 As String
    Dim vWareki As String
    Dim vSave As String
    Dim vSaveOut As String
    Dim slashOut As String

    GroupBase slot, baseCol, baseRow, offSlash, offG1
    baseRow = baseRow + rowOffset

    vTitle = Trim$(CStr(wsSrc.Cells(srcRow, colTitle).Value))
    vClass2 = Trim$(CStr(wsSrc.Cells(srcRow, colClass2).Value))
    vClass3 = Trim$(CStr(wsSrc.Cells(srcRow, colClass3).Value))
    vWareki = Trim$(CStr(wsSrc.Cells(srcRow, colWareki).Value))
    vSave = Trim$(CStr(wsSrc.Cells(srcRow, colSaveTerm).Value))
    vSaveOut = frmSeal.SaveTermToKei(vSave)

    If Len(vSaveOut) > 0 _
       Or Len(vTitle) > 0 _
       Or Len(vClass2) > 0 _
       Or Len(vClass3) > 0 _
       Or Len(frmSeal.ExtractWarekiNumber(vWareki)) > 0 Then
        slashOut = "/"
    Else
        slashOut = ""
    End If

    ClearMergeTarget wsSeal, baseRow, baseCol
    ClearMergeTarget wsSeal, baseRow, baseCol + 1
    ClearMergeTarget wsSeal, baseRow, baseCol + offSlash
    ClearMergeTarget wsSeal, baseRow, baseCol + 7
    ClearMergeTarget wsSeal, baseRow + 1, baseCol
    ClearMergeTarget wsSeal, baseRow + 1, baseCol + 1

    PutMergeTopLeft wsSeal, baseRow, baseCol, vSaveOut
    PutMergeTopLeft wsSeal, baseRow, baseCol + 1, vTitle
    PutMergeTopLeft wsSeal, baseRow, baseCol + offSlash, slashOut
    PutMergeTopLeft wsSeal, baseRow, baseCol + 7, vClass2
    PutMergeTopLeft wsSeal, baseRow + 1, baseCol, frmSeal.ExtractWarekiNumber(vWareki)
    PutMergeTopLeft wsSeal, baseRow + 1, baseCol + 1, vClass3

End Sub

Private Sub ClearOneSealSlot_WithRowOffset(ByVal wsSeal As Worksheet, ByVal slot As Long, ByVal rowOffset As Long)

    Dim baseCol As Long
    Dim baseRow As Long
    Dim offSlash As Long
    Dim offG1 As Long

    GroupBase slot, baseCol, baseRow, offSlash, offG1
    baseRow = baseRow + rowOffset

    ClearMergeTarget wsSeal, baseRow, baseCol
    ClearMergeTarget wsSeal, baseRow, baseCol + 1
    ClearMergeTarget wsSeal, baseRow, baseCol + offSlash
    ClearMergeTarget wsSeal, baseRow, baseCol + 7
    ClearMergeTarget wsSeal, baseRow + 1, baseCol
    ClearMergeTarget wsSeal, baseRow + 1, baseCol + 1

    PutMergeTopLeft wsSeal, baseRow, baseCol, ""
    PutMergeTopLeft wsSeal, baseRow, baseCol + 1, ""
    PutMergeTopLeft wsSeal, baseRow, baseCol + offSlash, ""
    PutMergeTopLeft wsSeal, baseRow, baseCol + 7, ""
    PutMergeTopLeft wsSeal, baseRow + 1, baseCol, ""
    PutMergeTopLeft wsSeal, baseRow + 1, baseCol + 1, ""

End Sub

Public Sub ClearAllSeals_NewSpec()

    Dim wsSeal As Worksheet
    Dim slot As Long

    Set wsSeal = ResolveWorksheetByCandidates(ThisWorkbook, Array("個別フォルダシール", "個別フォルダーシール", "フォルダシール"))
    If wsSeal Is Nothing Then Exit Sub

    For slot = 1 To 12
        ClearOneSealSlot wsSeal, slot
    Next slot

End Sub
