        "保存場所・箱コード３", "保存場所・箱名３", "箱サイン３", "保存場所・箱コード４", "保存場所・箱名４", "箱サイン４", "保存場所・箱コード５", "保存場所・箱名５", "箱サイン５", _
        "ラベル種類", "背表紙用タイトル", "背表紙用サブタイトル", "公開用タイトル", "公開用サブタイトル", "公開区分", "歴史資料区分", "内容・取扱い", "備考", _
        "作成所属", "作成年度", "作成者", "機密レベル", "汎用項目１", "汎用項目２", "汎用項目３", "汎用項目４", "汎用項目５", "汎用項目６", "汎用項目７", "汎用項目８", "汎用項目９", "汎用項目１０", _
        "汎用日付項目１", "汎用日付項目２", "汎用日付項目３", "汎用日付項目４", "汎用日付項目５", _
        "汎用数値項目１", "汎用数値項目２", "汎用数値項目３", "汎用数値項目４", "汎用数値項目５", _
