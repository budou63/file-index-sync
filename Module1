        ' A. キー3項目がすべて空白 / 年度空欄 / タイトル空欄 -> 無視
        '    同一年度内比較を徹底するため、年度空欄は比較対象外にする。
        If isKeyBlank Or yearVal = "" Or titleVal = "" Then
            ' 何もしない

        ' B. キー一致する行が存在 -> 比較列に差異があれば更新行として出力
        ElseIf srcDict.Exists(key) Then
            ' 同一キーの複数行に対応するため、1キー1行ではなく候補行一覧を保持する
            ' 誤突合を防ぐため、候補の中から比較列の一致数が最大の行を採用する
            srcRow = GetBestMatchedSourceRow( _
                wsSrc, _
                wsEdit, _
                srcDict(key), _
                usedSrcRows, _
                compareSrcCols, _
                compareEditCols, _
                r)

            If srcRow > 0 Then
                ' 採用済み候補行は再利用しない
                MarkSourceRowAsUsed usedSrcRows, srcRow

                isDifferent = False
                For i = LBound(compareDefs) To UBound(compareDefs)
                    If compareSrcCols(i) > 0 And compareEditCols(i) > 0 Then
                        If NormalizeForDiffCompare(wsSrc.Cells(srcRow, compareSrcCols(i)).Value) <> _
                           NormalizeForDiffCompare(wsEdit.Cells(r, compareEditCols(i)).Value) Then
                            isDifferent = True
                            Exit For
                        End If
                    End If
                Next i
            Else
                isDifferent = True
            End If

            If isDifferent Then
                WriteRowByFixedLayout wsEdit, wsOut, r, outRow, fixedHeaders, editHeaderMap, outputSourceMap
                outRow = outRow + 1
            End If

        ' C. キー一致なし -> 新規行として出力
        Else
            WriteRowByFixedLayout wsEdit, wsOut, r, outRow, fixedHeaders, editHeaderMap, outputSourceMap
            outRow = outRow + 1
        End If

ContinueNextEditRow:
    Next r

    With wsOut.Range(wsOut.Cells(1, 1), wsOut.Cells(1, UBound(fixedHeaders) - LBound(fixedHeaders) + 1))
        .Font.Bold = True
        .Interior.Color = RGB(242, 242, 242)
