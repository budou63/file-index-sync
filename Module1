    Dim pageTopRow As Long
    Dim srcRow As Long
    Dim printLastRow As Long
    Dim c As Long
    Dim requiredBlocks As Long
    Dim generatedBlocks As Long
    Dim addPageNo As Long
    Dim clearPageNo As Long

    On Error GoTo ErrorHandler

    If startNo <= 0 Or endNo <= 0 Then
        Err.Raise vbObjectError + 2301, , "開始値/終了値は 1 以上の数値を指定してください。"
    End If
    If startNo > endNo Then
        Err.Raise vbObjectError + 2302, , "開始番号は終了番号以下にしてください。"
    End If

    Set wsSrc = ResolveWorksheetByCandidates(ThisWorkbook, Array(SHEET_NEW_FILE_STANDARD))
    Set wsSingle = ResolveWorksheetByCandidates(ThisWorkbook, Array(SINGLE_SHEET_NAME1, SINGLE_SHEET_NAME2, SINGLE_SHEET_NAME3))
    Set wsMulti = ResolveWorksheetByCandidates(ThisWorkbook, Array(MULTI_SHEET_NAME))

    If wsSrc Is Nothing Then Err.Raise vbObjectError + 2303, , "新ファイル基準表シートが見つかりません。"
    If wsSingle Is Nothing Then Err.Raise vbObjectError + 2304, , "単発用の個別フォルダシールシートが見つかりません。"
    If wsMulti Is Nothing Then Err.Raise vbObjectError + 2305, , "大量出力用シート「" & MULTI_SHEET_NAME & "」が見つかりません。"

    frmSeal.BuildIndexes_NewSpec wsSrc, serialIndex, headerIndex
    serialCol = CLng(headerIndex("通し番号"))
    If serialCol = 0 Then Err.Raise vbObjectError + 2306, , "見出し「通し番号」が見つかりません。"

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    Set targetRows = New Collection
    srcLastRow = GetLastUsedRow(wsSrc)

    For r = 2 To srcLastRow
        If Not wsSrc.Rows(r).Hidden Then
            serialVal = Trim$(CStr(wsSrc.Cells(r, serialCol).Value))
            If Len(serialVal) > 0 And IsNumeric(serialVal) Then
                serialNo = CLng(Val(serialVal))
                If serialNo >= startNo And serialNo <= endNo Then
                    targetRows.Add r
                End If
            End If
        End If
    Next r

    ' 追記: 列幅はテンプレート（単発用1ページ目）と一致させる
    For c = 1 To PAGE_LAST_COL
        wsMulti.Columns(c).ColumnWidth = wsSingle.Columns(c).ColumnWidth
    Next c
    ' 追記: 印刷ズレ抑制のためページ設定もテンプレートに合わせる
    ApplyPageSetupFromTemplate wsSingle, wsMulti

    If targetRows.Count = 0 Then
        Err.Raise vbObjectError + 2307, , "該当するデータがありません。"
    End If

    pageCount = CLng(Application.WorksheetFunction.RoundUp(CDbl(targetRows.Count) / 12#, 0))
    requiredBlocks = pageCount
    generatedBlocks = GetGeneratedSealBlockCount(wsMulti, PAGE_ROWS)

    ' 既存ブロックを再利用し、不足分のみ12面単位で追加
    If generatedBlocks < requiredBlocks Then
        For addPageNo = generatedBlocks + 1 To requiredBlocks
            pageTopRow = (addPageNo - 1) * PAGE_ROWS + 1
            CopySealTemplatePageLayout wsSingle, wsMulti, pageTopRow, PAGE_ROWS, PAGE_LAST_COL
        Next addPageNo
        generatedBlocks = requiredBlocks
    End If

    ' 12面ブロックごとに改ページを固定（今回印刷する必要ページ数を基準に再設定）
    ConfigureSealPageBreaks wsMulti, PAGE_ROWS, pageCount

    For pageNo = 1 To pageCount
        pageTopRow = (pageNo - 1) * PAGE_ROWS + 1

        For slot = 1 To 12
            idx = (pageNo - 1) * 12 + slot
            If idx <= targetRows.Count Then
                srcRow = CLng(targetRows(idx))
                WriteOneSeal_NewSpec_WithRowOffset _
                    wsSrc, srcRow, wsMulti, slot, (pageTopRow - 1), _
                    CLng(headerIndex("タイトル")), _
                    CLng(headerIndex("分類名2")), _
                    CLng(headerIndex("分類名3")), _
                    CLng(headerIndex("年度和暦")), _
                    CLng(headerIndex("保存期間"))
            Else
                ClearOneSealSlot_WithRowOffset wsMulti, slot, (pageTopRow - 1)
            End If
        Next slot
    Next pageNo

    ' 今回未使用の既存ブロックは削除せず残し、値だけクリア
    If generatedBlocks > pageCount Then
        For clearPageNo = pageCount + 1 To generatedBlocks
            For slot = 1 To 12
                ClearOneSealSlot_WithRowOffset wsMulti, slot, (clearPageNo - 1) * PAGE_ROWS
            Next slot
        Next clearPageNo
    End If

    printLastRow = pageCount * PAGE_ROWS
    wsMulti.PageSetup.PrintArea = wsMulti.Range(wsMulti.Cells(1, 1), wsMulti.Cells(printLastRow, PAGE_LAST_COL)).Address

    MsgBox "個別フォルダシール（複数）を作成しました。" & vbCrLf & _
           "対象件数: " & targetRows.Count & " 件" & vbCrLf & _
           "ページ数: " & pageCount & " ページ", vbInformation

SafeExit:
    Application.CutCopyMode = False
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Exit Sub

ErrorHandler:
    MsgBox "大量作成でエラーが発生しました: " & Err.Description, vbExclamation
    Resume SafeExit

End Sub

Private Function GetGeneratedSealBlockCount(ByVal ws As Worksheet, ByVal pageRows As Long) As Long

    Dim areaText As String
    Dim rngPrint As Range
    Dim rowBottom As Long
    Dim lastDataCell As Range
    Dim dataBottom As Long
    Dim maxBottom As Long

    On Error GoTo Fallback

    areaText = Trim$(ws.PageSetup.PrintArea)
    If Len(areaText) > 0 Then
        Set rngPrint = ws.Range(areaText)
        rowBottom = rngPrint.Row + rngPrint.Rows.Count - 1
    End If

    Set lastDataCell = ws.Range(ws.Cells(1, 1), ws.Cells(ws.Rows.Count, 21)).Find( _
        What:="*", LookIn:=xlFormulas, SearchOrder:=xlByRows, SearchDirection:=xlPrevious)
    If Not lastDataCell Is Nothing Then dataBottom = lastDataCell.Row

    maxBottom = IIf(rowBottom > dataBottom, rowBottom, dataBottom)
    If maxBottom > 0 Then
        GetGeneratedSealBlockCount = (maxBottom + pageRows - 1) \ pageRows
        If GetGeneratedSealBlockCount < 1 Then GetGeneratedSealBlockCount = 1
        Exit Function
    End If

Fallback:
    GetGeneratedSealBlockCount = 1

End Function

Private Sub ConfigureSealPageBreaks(ByVal ws As Worksheet, ByVal pageRows As Long, ByVal blockCount As Long)

    Dim pageNo As Long
    Dim pageTopRow As Long

    ws.ResetAllPageBreaks

    If blockCount <= 1 Then Exit Sub

    For pageNo = 2 To blockCount
        pageTopRow = (pageNo - 1) * pageRows + 1
        ws.HPageBreaks.Add Before:=ws.Cells(pageTopRow, 1)
    Next pageNo

End Sub

Private Sub ApplyPageSetupFromTemplate(ByVal wsTemplate As Worksheet, ByVal wsDst As Worksheet)

    With wsDst.PageSetup
        .Orientation = wsTemplate.PageSetup.Orientation
        .PaperSize = wsTemplate.PageSetup.PaperSize
        .Zoom = wsTemplate.PageSetup.Zoom
        .FitToPagesWide = wsTemplate.PageSetup.FitToPagesWide
        .FitToPagesTall = wsTemplate.PageSetup.FitToPagesTall
        .TopMargin = wsTemplate.PageSetup.TopMargin
        .BottomMargin = wsTemplate.PageSetup.BottomMargin
        .LeftMargin = wsTemplate.PageSetup.LeftMargin
        .RightMargin = wsTemplate.PageSetup.RightMargin
        .HeaderMargin = wsTemplate.PageSetup.HeaderMargin
        .FooterMargin = wsTemplate.PageSetup.FooterMargin
        .CenterHorizontally = wsTemplate.PageSetup.CenterHorizontally
        .CenterVertically = wsTemplate.PageSetup.CenterVertically
    End With

End Sub

Private Sub CopySealTemplatePageLayout( _
    ByVal wsTemplate As Worksheet, _
    ByVal wsDst As Worksheet, _
    ByVal dstTopRow As Long, _
    ByVal pageRows As Long, _
    ByVal pageLastCol As Long)

    Dim r As Long
    Dim c As Long

    wsTemplate.Range(wsTemplate.Cells(1, 1), wsTemplate.Cells(pageRows, pageLastCol)).Copy
    wsDst.Cells(dstTopRow, 1).PasteSpecial xlPasteAll
    Application.CutCopyMode = False

    ' 追記: 行高は PasteAll だけでは不一致になり得るため明示コピー
    For r = 1 To pageRows
        wsDst.Rows(dstTopRow + r - 1).RowHeight = wsTemplate.Rows(r).RowHeight
    Next r

    ' 追記: 列幅もテンプレート値を明示的に維持
    For c = 1 To pageLastCol
        wsDst.Columns(c).ColumnWidth = wsTemplate.Columns(c).ColumnWidth
    Next c

End Sub

Private Sub WriteOneSeal_NewSpec_WithRowOffset( _
    ByVal wsSrc As Worksheet, _
    ByVal srcRow As Long, _
    ByVal wsSeal As Worksheet, _
    ByVal slot As Long, _
    ByVal rowOffset As Long, _
    ByVal colTitle As Long, _
    ByVal colClass2 As Long, _
    ByVal colClass3 As Long, _
    ByVal colWareki As Long, _
    ByVal colSaveTerm As Long)

    Dim baseCol As Long
    Dim baseRow As Long
    Dim offSlash As Long
    Dim offG1 As Long
    Dim vTitle As String
    Dim vClass2 As String
    Dim vClass3 As String
    Dim vWareki As String
    Dim vSave As String
    Dim vSaveOut As String
    Dim slashOut As String

    GroupBase slot, baseCol, baseRow, offSlash, offG1
    baseRow = baseRow + rowOffset

    vTitle = Trim$(CStr(wsSrc.Cells(srcRow, colTitle).Value))
    vClass2 = Trim$(CStr(wsSrc.Cells(srcRow, colClass2).Value))
    vClass3 = Trim$(CStr(wsSrc.Cells(srcRow, colClass3).Value))
    vWareki = Trim$(CStr(wsSrc.Cells(srcRow, colWareki).Value))
    vSave = Trim$(CStr(wsSrc.Cells(srcRow, colSaveTerm).Value))
    vSaveOut = frmSeal.SaveTermToKei(vSave)

    If Len(vSaveOut) > 0 _
       Or Len(vTitle) > 0 _
       Or Len(vClass2) > 0 _
       Or Len(vClass3) > 0 _
       Or Len(frmSeal.ExtractWarekiNumber(vWareki)) > 0 Then
        slashOut = "/"
    Else
        slashOut = ""
    End If

    ClearMergeTarget wsSeal, baseRow, baseCol
    ClearMergeTarget wsSeal, baseRow, baseCol + 1
    ClearMergeTarget wsSeal, baseRow, baseCol + offSlash
    ClearMergeTarget wsSeal, baseRow, baseCol + 7
    ClearMergeTarget wsSeal, baseRow + 1, baseCol
    ClearMergeTarget wsSeal, baseRow + 1, baseCol + 1

    PutMergeTopLeft wsSeal, baseRow, baseCol, vSaveOut
    PutMergeTopLeft wsSeal, baseRow, baseCol + 1, vTitle
    PutMergeTopLeft wsSeal, baseRow, baseCol + offSlash, slashOut
    PutMergeTopLeft wsSeal, baseRow, baseCol + 7, vClass2
    PutMergeTopLeft wsSeal, baseRow + 1, baseCol, frmSeal.ExtractWarekiNumber(vWareki)
    PutMergeTopLeft wsSeal, baseRow + 1, baseCol + 1, vClass3

End Sub

Private Sub ClearOneSealSlot_WithRowOffset(ByVal wsSeal As Worksheet, ByVal slot As Long, ByVal rowOffset As Long)

    Dim baseCol As Long
    Dim baseRow As Long
    Dim offSlash As Long
    Dim offG1 As Long

    GroupBase slot, baseCol, baseRow, offSlash, offG1
    baseRow = baseRow + rowOffset

    ClearMergeTarget wsSeal, baseRow, baseCol
    ClearMergeTarget wsSeal, baseRow, baseCol + 1
    ClearMergeTarget wsSeal, baseRow, baseCol + offSlash
    ClearMergeTarget wsSeal, baseRow, baseCol + 7
    ClearMergeTarget wsSeal, baseRow + 1, baseCol
    ClearMergeTarget wsSeal, baseRow + 1, baseCol + 1

    PutMergeTopLeft wsSeal, baseRow, baseCol, ""
    PutMergeTopLeft wsSeal, baseRow, baseCol + 1, ""
    PutMergeTopLeft wsSeal, baseRow, baseCol + offSlash, ""
    PutMergeTopLeft wsSeal, baseRow, baseCol + 7, ""
    PutMergeTopLeft wsSeal, baseRow + 1, baseCol, ""
    PutMergeTopLeft wsSeal, baseRow + 1, baseCol + 1, ""

End Sub

Public Sub ClearAllSeals_NewSpec()

    Const MULTI_SHEET_NAME As String = "個別フォルダシール（複数）"
    Const PAGE_ROWS As Long = 20
    Const PAGE_LAST_COL As Long = 21

    Dim wsSingle As Worksheet
    Dim wsMulti As Worksheet
    Dim slot As Long
    Dim generatedBlocks As Long
    Dim pageNo As Long
    Dim clearedSingle As Boolean
    Dim clearedMulti As Boolean

    Set wsSingle = ResolveWorksheetByCandidates(ThisWorkbook, Array("個別フォルダシール", "個別フォルダーシール", "フォルダシール"))
    If Not wsSingle Is Nothing Then
        For slot = 1 To 12
            ClearOneSealSlot wsSingle, slot
        Next slot
        clearedSingle = True
    End If

    Set wsMulti = ResolveWorksheetByCandidates(ThisWorkbook, Array(MULTI_SHEET_NAME))
    If Not wsMulti Is Nothing Then
        generatedBlocks = GetGeneratedSealBlockCount(wsMulti, PAGE_ROWS)
        For pageNo = 1 To generatedBlocks
            For slot = 1 To 12
                ClearOneSealSlot_WithRowOffset wsMulti, slot, (pageNo - 1) * PAGE_ROWS
            Next slot
        Next pageNo
        ' クリア後は1ページ固定に戻す（列範囲はテンプレートどおり A:U）
        ConfigureSealPageBreaks wsMulti, PAGE_ROWS, 1
        wsMulti.PageSetup.PrintArea = wsMulti.Range(wsMulti.Cells(1, 1), wsMulti.Cells(PAGE_ROWS, PAGE_LAST_COL)).Address
        clearedMulti = True
    End If

    If clearedSingle And clearedMulti Then
        MsgBox "単発用シートと複数用シートをクリアしました。", vbInformation
    ElseIf clearedSingle Then
        MsgBox "単発用シートをクリアしました。", vbInformation
    ElseIf clearedMulti Then
        MsgBox "複数用シートをクリアしました。", vbInformation
    End If

End Sub


Public Sub 旧基準表_継続文書移行()

    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean
    Dim oldDisplayAlerts As Boolean
    Dim previousCalculationMode As XlCalculation

    Dim targetYearRaw As String
    Dim targetYearNorm As String
    Dim oldBookPath As String

    Dim wbOld As Workbook
    Dim wsOld As Worksheet
    Dim wsNew As Worksheet

    Dim oldHeaderRow As Long
    Dim newHeaderRow As Long
    Dim oldDataStartRow As Long

    Dim oldColKeizoku As Long
    Dim oldColGuide1 As Long
    Dim oldColColor1 As Long
    Dim oldColGuide2 As Long
    Dim oldColColor2 As Long
    Dim oldColNendo As Long
    Dim oldColKobetsu As Long
    Dim oldColMedia As Long

    Dim newColClass2 As Long
    Dim newColColor As Long
    Dim newColClass3 As Long
    Dim newColColor2 As Long
    Dim newColWareki As Long
    Dim newColCreatedWareki As Long
    Dim newColTitle As Long
    Dim newColBiko As Long
    Dim newColMediaType As Long

    Dim oldLastRow As Long
    Dim oldLastCol As Long
    Dim oldData As Variant
    Dim rowCount As Long

    Dim grouped As Object
    Dim keyOrder As Collection
    Dim groupKey As String
    Dim recs As Collection
    Dim rec As Variant

    Dim i As Long
    Dim movedCount As Long
    Dim existingFolderKeys As Object
    Dim folderKey As String

    On Error GoTo ErrorHandler

    If MsgBox("旧ファイル基準表から新ファイル基準表へ継続文書を移行します。実行しますか？", vbYesNo + vbQuestion) <> vbYes Then Exit Sub

    targetYearRaw = InputBox("対象年度（和暦）を入力してください。（例: R8 / 令和8）", "対象年度入力")
    targetYearNorm = NormalizeWarekiYear_Mig(targetYearRaw)
    DebugLog "[年度入力] raw=[" & targetYearRaw & "] normalized=[" & targetYearNorm & "]"
    If targetYearNorm = "" Then
        MsgBox "年度（和暦）の入力を解釈できませんでした", vbExclamation
        Exit Sub
    End If

    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents
    oldDisplayAlerts = Application.DisplayAlerts
    previousCalculationMode = Application.Calculation

    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.Calculation = xlCalculationManual
    Application.DisplayAlerts = False

    oldBookPath = SelectOldStandardWorkbookPath()
    If oldBookPath = "" Then GoTo SafeExit

    Set wbOld = Workbooks.Open(Filename:=oldBookPath, ReadOnly:=True)

    If Not FindKijunSheet_Mig(wbOld, wsOld, "選択したブックに『基準表』シートがありません。") Then GoTo SafeExit
    If Not FindKijunSheet_Mig(ThisWorkbook, wsNew, "このブックに『基準表』シートがありません。") Then GoTo SafeExit

    oldHeaderRow = FindHeaderRowByKeys_Mig(wsOld, Array("継続", "第１ガイド", "１色", "第２ガイド", "２色", "年度", "個別フォルダー", "媒体"), 30)
    newHeaderRow = FindHeaderRowByKeys_Mig(wsNew, Array("分類名２", "色名", "分類名３", "2色名", "年度（和暦）", "作成年度（和暦）", "タイトル", "備考", "媒体種別"), 30)

    If oldHeaderRow = 0 Then MsgBox "旧シートの見出し行が見つかりません。", vbExclamation: GoTo SafeExit
    If newHeaderRow = 0 Then MsgBox "新シートの見出し行が見つかりません。", vbExclamation: GoTo SafeExit

    oldDataStartRow = oldHeaderRow + 1
    DebugLog "[旧] 採用見出し行=" & oldHeaderRow
    DebugLog "[新] 採用見出し行=" & newHeaderRow
    DebugLog "[旧] データ開始行=" & oldDataStartRow

    oldColKeizoku = GetHeaderColumnByName_Mig(wsOld, oldHeaderRow, "継続")
    oldColGuide1 = GetHeaderColumnByName_Mig(wsOld, oldHeaderRow, "第１ガイド")
    oldColColor1 = GetHeaderColumnByName_Mig(wsOld, oldHeaderRow, "１色")
    oldColGuide2 = GetHeaderColumnByName_Mig(wsOld, oldHeaderRow, "第２ガイド")
    oldColColor2 = GetHeaderColumnByName_Mig(wsOld, oldHeaderRow, "２色")
    oldColNendo = GetHeaderColumnByName_Mig(wsOld, oldHeaderRow, "年度")
    oldColKobetsu = GetHeaderColumnByName_Mig(wsOld, oldHeaderRow, "個別フォルダー")
    oldColMedia = GetHeaderColumnByName_Mig(wsOld, oldHeaderRow, "媒体")

    newColClass2 = GetHeaderColumnByName_Mig(wsNew, newHeaderRow, "分類名２")
    newColColor = GetHeaderColumnByName_Mig(wsNew, newHeaderRow, "色名")
    newColClass3 = GetHeaderColumnByName_Mig(wsNew, newHeaderRow, "分類名３")
    newColColor2 = GetHeaderColumnByName_Mig(wsNew, newHeaderRow, "2色名")
    newColWareki = GetHeaderColumnByName_Mig(wsNew, newHeaderRow, "年度（和暦）")
    newColCreatedWareki = GetHeaderColumnByName_Mig(wsNew, newHeaderRow, "作成年度（和暦）")
    newColTitle = GetHeaderColumnByName_Mig(wsNew, newHeaderRow, "タイトル")
    newColBiko = GetHeaderColumnByName_Mig(wsNew, newHeaderRow, "備考")
    newColMediaType = GetHeaderColumnByName_Mig(wsNew, newHeaderRow, "媒体種別")

    If oldColKeizoku = 0 Then StopWithMissingColumn "継続"
    If oldColGuide1 = 0 Then StopWithMissingColumn "第１ガイド"
    If oldColColor1 = 0 Then StopWithMissingColumn "１色"
    If oldColGuide2 = 0 Then StopWithMissingColumn "第２ガイド"
    If oldColColor2 = 0 Then StopWithMissingColumn "２色"
    If oldColNendo = 0 Then StopWithMissingColumn "年度"
    If oldColKobetsu = 0 Then StopWithMissingColumn "個別フォルダー"
    If oldColMedia = 0 Then StopWithMissingColumn "媒体"
    If newColClass2 = 0 Then StopWithMissingColumn "分類名２"
    If newColColor = 0 Then StopWithMissingColumn "色名"
    If newColClass3 = 0 Then StopWithMissingColumn "分類名３"
    If newColColor2 = 0 Then StopWithMissingColumn "2色名"
    If newColWareki = 0 Then StopWithMissingColumn "年度（和暦）"
    If newColCreatedWareki = 0 Then StopWithMissingColumn "作成年度（和暦）"
    If newColTitle = 0 Then StopWithMissingColumn "タイトル"
    If newColBiko = 0 Then StopWithMissingColumn "備考"
    If newColMediaType = 0 Then StopWithMissingColumn "媒体種別"

    DebugLog "[列番号][旧] 継続=" & oldColKeizoku & " 第１ガイド=" & oldColGuide1 & " １色=" & oldColColor1 & " 第２ガイド=" & oldColGuide2 & " ２色=" & oldColColor2 & " 年度=" & oldColNendo & " 個別フォルダー=" & oldColKobetsu & " 媒体=" & oldColMedia
    DebugLog "[列番号][新] 分類名２=" & newColClass2 & " 色名=" & newColColor & " 分類名３=" & newColClass3 & " 2色名=" & newColColor2 & " 年度（和暦）=" & newColWareki & " 作成年度（和暦）=" & newColCreatedWareki & " タイトル=" & newColTitle & " 備考=" & newColBiko & " 媒体種別=" & newColMediaType

    oldLastRow = wsOld.Cells(wsOld.Rows.Count, 1).End(xlUp).Row
    If oldLastRow < oldDataStartRow Then
        MsgBox "0件の継続文書を移行しました", vbInformation
        GoTo SafeExit
    End If

    oldLastCol = wsOld.Cells(oldHeaderRow, wsOld.Columns.Count).End(xlToLeft).Column
    oldData = wsOld.Range(wsOld.Cells(oldDataStartRow, 1), wsOld.Cells(oldLastRow, oldLastCol)).Value2
    rowCount = UBound(oldData, 1)

    Set grouped = CreateObject("Scripting.Dictionary")
    grouped.CompareMode = vbTextCompare
    Set keyOrder = New Collection

    Set existingFolderKeys = CreateObject("Scripting.Dictionary")
    existingFolderKeys.CompareMode = vbBinaryCompare

    Dim newLastRow As Long
    Dim rr As Long
    newLastRow = wsNew.Cells(wsNew.Rows.Count, 1).End(xlUp).Row
    For rr = newHeaderRow + 1 To newLastRow
        folderKey = BuildFolderCompareKey_Mig( _
            GetRawCellMerged(wsNew, rr, newColClass2), _
            GetRawCellMerged(wsNew, rr, newColClass3), _
            GetRawCellMerged(wsNew, rr, newColTitle))
        If folderKey <> "||" Then
            If Not existingFolderKeys.Exists(folderKey) Then existingFolderKeys.Add folderKey, True
        End If
    Next rr

    For i = 1 To rowCount
        If i <= 10 Then
            Debug.Print "Row=" & (oldDataStartRow + i - 1) & _
                " 継続 raw=[" & CStr(oldData(i, oldColKeizoku)) & "] normalized=[" & NormalizeTextForMatch(CStr(oldData(i, oldColKeizoku))) & "]" & _
                " 媒体 raw=[" & CStr(oldData(i, oldColMedia)) & "] normalized=[" & NormalizeMediaValue(CStr(oldData(i, oldColMedia))) & "]"
        End If

        If IsContinuousDocument(CStr(oldData(i, oldColKeizoku))) And IsPaperMedia(CStr(oldData(i, oldColMedia))) Then
            groupKey = NormalizeTextForMatch(CStr(oldData(i, oldColGuide1)))
            If Not grouped.Exists(groupKey) Then
                Set recs = New Collection
                grouped.Add groupKey, recs
                keyOrder.Add groupKey
            End If
            ' 転記対応一覧（継続文書差込）
            ' - 第１ガイド -> 分類名２
            ' - １色 -> 色名
            ' - 第２ガイド -> 分類名３
            ' - ２色 -> 2色名
            ' - 年度 -> 作成年度（和暦）
            ' - 個別フォルダー -> タイトル
            ' - 媒体 -> 媒体種別
            folderKey = BuildFolderCompareKey_Mig(CStr(oldData(i, oldColGuide1)), CStr(oldData(i, oldColGuide2)), CStr(oldData(i, oldColKobetsu)))
            If folderKey <> "||" Then
                If existingFolderKeys.Exists(folderKey) Then
                    GoTo NextRowMigImport
                End If
                existingFolderKeys(folderKey) = True
            End If

            rec = Array(CStr(oldData(i, oldColGuide1)), CStr(oldData(i, oldColColor1)), CStr(oldData(i, oldColGuide2)), CStr(oldData(i, oldColColor2)), CStr(oldData(i, oldColNendo)), CStr(oldData(i, oldColKobetsu)), Trim$(CStr(oldData(i, oldColMedia))))
            grouped(groupKey).Add rec
        End If
NextRowMigImport:
    Next i

    DebugPrintNewYearSample_Mig wsNew, newHeaderRow + 1, newColWareki, 10

    movedCount = 0
    For i = 1 To keyOrder.Count
        groupKey = CStr(keyOrder(i))
        Set recs = grouped(groupKey)
        If recs.Count > 0 Then
            Dim insertRow As Long
            insertRow = FindInsertRowForGroup_Mig(wsNew, newHeaderRow + 1, newColWareki, newColClass2, targetYearNorm, groupKey)

            wsNew.Rows(insertRow).Resize(recs.Count).Insert Shift:=xlDown

            Dim j As Long
            For j = 1 To recs.Count
                rec = recs(j)
                wsNew.Cells(insertRow + j - 1, newColClass2).Value = rec(0)
                wsNew.Cells(insertRow + j - 1, newColColor).Value = NormalizeColorName(CStr(rec(1)))
                wsNew.Cells(insertRow + j - 1, newColClass3).Value = rec(2)
                wsNew.Cells(insertRow + j - 1, newColColor2).Value = NormalizeColorName(CStr(rec(3)))
                wsNew.Cells(insertRow + j - 1, newColCreatedWareki).Value = rec(4)
                wsNew.Cells(insertRow + j - 1, newColTitle).Value = rec(5)
                wsNew.Cells(insertRow + j - 1, newColMediaType).Value = Trim$(CStr(rec(6)))
                wsNew.Cells(insertRow + j - 1, newColBiko).Value = "マクロ差込"
                movedCount = movedCount + 1
            Next j
        End If
    Next i

    MsgBox CStr(movedCount) & "件の継続文書を移行しました", vbInformation

SafeExit:
    On Error Resume Next
    If Not wbOld Is Nothing Then wbOld.Close SaveChanges:=False
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Application.Calculation = previousCalculationMode
    Application.DisplayAlerts = oldDisplayAlerts
    Application.StatusBar = False
    On Error GoTo 0
    Exit Sub

ErrorHandler:
    MsgBox "処理を停止しました: " & Err.Description, vbExclamation
    Resume SafeExit

End Sub

Private Function NormalizeColorName(ByVal value As String) As String

    Dim normalized As String

    normalized = Trim$(CStr(value))

    Select Case normalized
        Case "赤"
            NormalizeColorName = "赤色"
        Case "青"
            NormalizeColorName = "青色"
        Case "黄"
            NormalizeColorName = "黄色"
        Case "緑"
            NormalizeColorName = "緑色"
        Case "白"
            NormalizeColorName = "白色"
        Case Else
            NormalizeColorName = normalized
    End Select

End Function

Private Function FindKijunSheet_Mig(ByVal wb As Workbook, ByRef foundWs As Worksheet, ByVal notFoundMessage As String) As Boolean

    Dim ws As Worksheet
    Dim partial As Collection
    Dim normName As String
    Dim msg As String
    Dim i As Long

    Set partial = New Collection

    For Each ws In wb.Worksheets
        normName = NormalizeSheetNameForMatch(ws.Name)
        If normName = "基準表" Then
            Set foundWs = ws
            FindKijunSheet_Mig = True
            Exit Function
        End If
    Next ws

    For Each ws In wb.Worksheets
        normName = NormalizeSheetNameForMatch(ws.Name)
        If InStr(1, normName, "基準表", vbBinaryCompare) > 0 Then
            partial.Add ws.Name
            Set foundWs = ws
        End If
    Next ws

    If partial.Count = 1 Then
        FindKijunSheet_Mig = True
        Exit Function
    End If

    If partial.Count > 1 Then
        msg = "『基準表』に一致するシート候補が複数あります:" & vbCrLf
        For i = 1 To partial.Count
            msg = msg & "- " & CStr(partial(i)) & vbCrLf
        Next i
        MsgBox msg, vbExclamation
        Exit Function
    End If

    MsgBox notFoundMessage, vbExclamation

End Function

Private Function FindHeaderRowByKeys_Mig(ByVal ws As Worksheet, ByVal requiredKeys As Variant, ByVal maxScanRow As Long) As Long

    Dim r As Long
    Dim i As Long
    Dim lastColInRow As Long
    Dim keyText As String
    Dim hitCount As Long
    Dim bestCount As Long

    For r = 1 To maxScanRow
        lastColInRow = ws.Cells(r, ws.Columns.Count).End(xlToLeft).Column
        hitCount = 0

        For i = LBound(requiredKeys) To UBound(requiredKeys)
            keyText = CStr(requiredKeys(i))
            If HeaderExistsInRow_Mig(ws, r, lastColInRow, keyText) Then hitCount = hitCount + 1
        Next i

        If hitCount > bestCount Then
            bestCount = hitCount
            FindHeaderRowByKeys_Mig = r
        End If
    Next r

    If bestCount = 0 Then FindHeaderRowByKeys_Mig = 0

End Function

Private Function HeaderExistsInRow_Mig(ByVal ws As Worksheet, ByVal rowNo As Long, ByVal lastCol As Long, ByVal headerName As String) As Boolean

    Dim c As Long

    For c = 1 To lastCol
        If StrComp(NormalizeTextForMatch(GetRawCellMerged(ws, rowNo, c)), NormalizeTextForMatch(headerName), vbBinaryCompare) = 0 Then
            HeaderExistsInRow_Mig = True
            Exit Function
        End If
    Next c

End Function

Private Function GetHeaderColumnByName_Mig(ByVal ws As Worksheet, ByVal headerRow As Long, ByVal headerName As String) As Long

    Dim c As Long
    Dim lastCol As Long

    lastCol = ws.Cells(headerRow, ws.Columns.Count).End(xlToLeft).Column

    For c = 1 To lastCol
        If StrComp(NormalizeTextForMatch(GetRawCellMerged(ws, headerRow, c)), NormalizeTextForMatch(headerName), vbBinaryCompare) = 0 Then
            GetHeaderColumnByName_Mig = c
            Exit Function
        End If
    Next c

End Function

Private Function NormalizeWarekiYear_Mig(ByVal rawValue As Variant) As String

    Dim s As String
    Dim i As Long
    Dim ch As String
    Dim n As String

    s = NormalizeTextForMatch(CStr(rawValue))
    If s = "" Then Exit Function

    On Error Resume Next
    s = StrConv(s, vbNarrow)
    On Error GoTo 0

    s = UCase$(s)
    s = Replace(s, " ", "")

    If Left$(s, 2) = "令和" Then s = "R" & Mid$(s, 3)
    If Left$(s, 1) = "Ｒ" Then s = "R" & Mid$(s, 2)
    If Left$(s, 1) <> "R" Then Exit Function

    For i = 2 To Len(s)
        ch = Mid$(s, i, 1)
        If ch Like "[0-9]" Then
            n = n & ch
        Else
            Exit Function
        End If
    Next i

    If n = "" Then Exit Function
    Do While Len(n) > 1 And Left$(n, 1) = "0"
        n = Mid$(n, 2)
    Loop

    NormalizeWarekiYear_Mig = "R" & n

End Function


Private Function BuildFolderCompareKey_Mig(ByVal class2Value As String, ByVal class3Value As String, ByVal titleValue As String) As String
    BuildFolderCompareKey_Mig = NormalizeFolderCompareText_Mig(class2Value) & "|" & _
                              NormalizeFolderCompareText_Mig(class3Value) & "|" & _
                              NormalizeFolderCompareText_Mig(titleValue)
End Function

Private Function NormalizeFolderCompareText_Mig(ByVal valueText As String) As String

    Dim s As String

    s = CStr(valueText)
    s = StrConv(s, vbNarrow)
    s = Replace(s, "（", "(")
    s = Replace(s, "）", ")")

    s = Replace(s, vbCrLf, " ")
    s = Replace(s, vbCr, " ")
    s = Replace(s, vbLf, " ")
    s = Replace(s, vbTab, " ")
    s = Replace(s, ChrW(&H3000), " ")
    s = Trim$(s)

    Do While InStr(s, "  ") > 0
        s = Replace(s, "  ", " ")
    Loop

    NormalizeFolderCompareText_Mig = s

End Function

Private Function FindInsertRowForGroup_Mig( _
    ByVal wsNew As Worksheet, _
    ByVal dataStartRow As Long, _
    ByVal colYear As Long, _
    ByVal colClass2 As Long, _
    ByVal targetYearNorm As String, _
    ByVal class2Norm As String) As Long

    Dim lastRow As Long
    Dim r As Long
    Dim y As String
    Dim c2 As String
    Dim hasYear As Boolean
    Dim yearEnd As Long
    Dim hasClass2 As Boolean
    Dim class2End As Long

    lastRow = wsNew.Cells(wsNew.Rows.Count, 1).End(xlUp).Row
    If lastRow < dataStartRow Then
        FindInsertRowForGroup_Mig = dataStartRow
        Exit Function
    End If

    For r = dataStartRow To lastRow
        y = NormalizeWarekiYear_Mig(GetRawCellMerged(wsNew, r, colYear))
        If y = targetYearNorm Then
            hasYear = True
            yearEnd = r

            c2 = NormalizeTextForMatch(GetRawCellMerged(wsNew, r, colClass2))
            If c2 = class2Norm Then
                hasClass2 = True
                class2End = r
                Do While class2End < lastRow
                    If NormalizeWarekiYear_Mig(GetRawCellMerged(wsNew, class2End + 1, colYear)) = targetYearNorm And _
                       NormalizeTextForMatch(GetRawCellMerged(wsNew, class2End + 1, colClass2)) = class2Norm Then
                        class2End = class2End + 1
                    Else
                        Exit Do
                    End If
                Loop
            End If
        End If
    Next r

    If hasClass2 Then
        FindInsertRowForGroup_Mig = class2End + 1
    ElseIf hasYear Then
        FindInsertRowForGroup_Mig = yearEnd + 1
    Else
        FindInsertRowForGroup_Mig = lastRow + 1
    End If

End Function

Private Sub DebugPrintNewYearSample_Mig(ByVal ws As Worksheet, ByVal startRow As Long, ByVal yearCol As Long, ByVal sampleCount As Long)

    Dim i As Long
