    Set srcHeaderMap = CreateObject("Scripting.Dictionary")
    Set existingDstHeaders = CreateObject("Scripting.Dictionary")
    Set existingRowMap = CreateObject("Scripting.Dictionary")
    Set sourceKeyMap = CreateObject("Scripting.Dictionary")
    Set validationTemplateMap = CreateObject("Scripting.Dictionary")
    Set formatTemplateMap = CreateObject("Scripting.Dictionary")
    Set columnWidthMap = CreateObject("Scripting.Dictionary")

    Application.ScreenUpdating = False
    Application.EnableEvents = False
    previousCalculationMode = Application.Calculation
    Application.Calculation = xlCalculationManual

    srcLastCol = GetLastUsedCol(wsSrc)
    srcLastRow = GetLastUsedRow(wsSrc)
    dstLastCol = GetLastUsedCol(wsDst)

    If srcLastCol <= 0 Then Err.Raise vbObjectError + 2001, , "目録CSV の見出し行が見つかりません。"

    ' 主要表示列（左側に寄せる列）
    ' 差し替えポイント: 列順定義は専用関数で一元管理
    displayHeaders = GetStep2DisplayHeadersOrder()

    ' ユーザー管理列（CSV上書き対象外）
    baselineUserManagedHeaders = Array("通し番号", "キャビネット番号", "ｎ＋1", "保存番号", "廃棄年月日", "同期状態")

    ' 左側に追加したい独自列（必要時にここへ追記）
    additionalLeftDisplayHeaders = Array()

    ' 1) 既存「新ファイル基準表」の見出しを辞書化（追加列保持のため）
    BuildHeaderMap wsDst, dstLastCol, existingDstHeaders

    ' 2) ユーザー管理列を確保
    For i = LBound(baselineUserManagedHeaders) To UBound(baselineUserManagedHeaders)
        EnsureColumnByHeader wsDst, existingDstHeaders, CStr(baselineUserManagedHeaders(i))
    Next i

    ' 3) 目録CSVの見出し辞書を作成し、CSV由来列の転記マップを組み立てる
    BuildSourceHeaderMap wsSrc, srcLastCol, srcHeaderMap
    For srcCol = 1 To srcLastCol
        headerText = Trim$(CStr(wsSrc.Cells(1, srcCol).Value))
        If headerText <> "" Then
            canonical = CanonicalHeaderName(headerText)
            dstCol = EnsureColumnByHeader(wsDst, existingDstHeaders, headerText)

            ' 目録CSVにある列は基本的に更新対象だが、ユーザー管理列は除外する
            If Not IsUserManagedHeader(canonical, srcHeaderMap, baselineUserManagedHeaders) Then
                srcToDstMap(canonical) = dstCol
            End If
        End If
    Next srcCol

    ' 4) 既存行マップを作成し、「更新＋新規追加」で反映する
    dstLastRow = GetLastUsedRow(wsDst)
    If dstLastRow < 1 Then dstLastRow = 1
    appendRow = dstLastRow + 1

    ' 高速化対応: 重複呼び出しを削除（1回のみ）
    BuildExistingRowMap wsDst, dstLastRow, existingRowMap

    ' 目録CSVの対象年度行件数を先に確認
    If srcLastRow >= 2 Then
        For srcRow = 2 To srcLastRow
            key = BuildFileKeyFromSheetRow(wsSrc, srcRow, srcHeaderMap)

            If key = "" Then
                ' キー（ファイルID/ファイル番号/バーコード番号）不足行は更新不可のためスキップ
                skippedNoKeyCount = skippedNoKeyCount + 1
                GoTo ContinueNextSourceRow
            End If

            ' 今回の目録CSVに存在するキーとして記録（同期状態判定で利用）
            If Not sourceKeyMap.Exists(key) Then
                sourceKeyMap.Add key, True
            End If

            If existingRowMap.Exists(key) Then
                targetRow = CLng(existingRowMap(key))
                UpdateRowFromSourceByHeader wsSrc, wsDst, srcRow, targetRow, srcHeaderMap, srcToDstMap
                updatedCount = updatedCount + 1

                If Not didUpdateRows Then
                    updateStartRow = targetRow
                    updateEndRow = targetRow
                    didUpdateRows = True
                Else
                    If targetRow < updateStartRow Then updateStartRow = targetRow
                    If targetRow > updateEndRow Then updateEndRow = targetRow
                End If
            Else
                AppendRowFromSourceByHeader wsSrc, wsDst, srcRow, appendRow, srcHeaderMap, srcToDstMap
                existingRowMap.Add key, appendRow
                appendedCount = appendedCount + 1
                appendRow = appendRow + 1
            End If

ContinueNextSourceRow:
        Next srcRow
    End If

    ' 5) 主要列だけ左側へ並べ直し（それ以外は削除せず後ろに残す）
    ' 高速化対応: Cut/Insert廃止済みのため Shapes退避/復元は行わない
    ' 高速化対応: 配列一括並び替えを実行
    columnOrderMap = BuildColumnOrderMap(wsDst, displayHeaders, additionalLeftDisplayHeaders, leftFixedCount, shouldReorderColumns)

    ' 高速化対応: 実際に列順変更がある場合のみテンプレート退避/再適用を行う
    If shouldReorderColumns Then
        dstLastCol = GetLastUsedCol(wsDst)
        CreateValidationTemplateSheet wsDst, dstLastCol, validationTemplateMap, wsValidationTemplate
        CreateFormatAndWidthTemplate wsDst, dstLastCol, formatTemplateMap, columnWidthMap, wsFormatTemplate
        ReorderSheetColumnsByMap wsDst, columnOrderMap
    End If

    ' 6) 同期状態列を更新（現行 / 削除候補 / 未登録）
    UpdateSyncStatusColumn wsDst, sourceKeyMap

    ' 7) 「毎年度利用区分」表示値変換と2色名同期（更新行＋新規行）
    If didUpdateRows Then
        ConvertAnnualUseDivisionValues wsDst, updateEndRow, updateStartRow
        SyncSecondColorNameFromColor wsDst, updateStartRow, updateEndRow
    End If

    If appendRow > dstLastRow + 1 Then
        ConvertAnnualUseDivisionValues wsDst, appendRow - 1, dstLastRow + 1
        SyncSecondColorNameFromColor wsDst, dstLastRow + 1, appendRow - 1
    End If

    ' 8) 主要列の見た目のみ整える（既存追加列の表示/非表示状態は壊さない）
    If leftFixedCount > 0 Then
        With wsDst.Range(wsDst.Cells(1, 1), wsDst.Cells(1, leftFixedCount))
            .Font.Bold = True
            .Interior.Color = RGB(242, 242, 242)
        End With
        wsDst.Range(wsDst.Columns(1), wsDst.Columns(leftFixedCount)).EntireColumn.AutoFit
    End If

    srcLastCol = GetLastUsedCol(wsDst)
    wsDst.Range(wsDst.Cells(1, 1), wsDst.Cells(1, srcLastCol)).AutoFilter

    ' 9) 左側固定対象の不足見出しを通知用に収集（列の表示状態は変更しない）
    HideKeyColumnsForStep2 wsDst, displayHeaders, missingHeadersText

    ' 10) タイトルがある行だけ通し番号を再採番
    ReindexSerial_NewFileStandard wsDst

    ' 11) 高速化対応: 実際に列順変更があった場合のみ再適用
    If shouldReorderColumns Then
        ReapplyValidationFromTemplate wsDst, validationTemplateMap, wsValidationTemplate
        ReapplyFormatAndWidthFromTemplate wsDst, formatTemplateMap, columnWidthMap, wsFormatTemplate
    End If

    If Len(missingHeadersText) > 0 Then
        MsgBox "新ファイル基準表の作成が完了しました。" & vbCrLf & _
               "更新件数: " & updatedCount & " 件" & vbCrLf & _
               "追加件数: " & appendedCount & " 件" & vbCrLf & _
               "キー不足スキップ件数: " & skippedNoKeyCount & " 件" & vbCrLf & _
               "左側に固定した主要列数: " & leftFixedCount & " 列" & vbCrLf & vbCrLf & _
               "以下の見出しが見つからないため、左側固定対象から除外しました:" & vbCrLf & _
               missingHeadersText, vbExclamation
    Else
        MsgBox "新ファイル基準表の作成が完了しました。" & vbCrLf & _
               "更新件数: " & updatedCount & " 件" & vbCrLf & _
               "追加件数: " & appendedCount & " 件" & vbCrLf & _
               "キー不足スキップ件数: " & skippedNoKeyCount & " 件" & vbCrLf & _
               "左側に固定した主要列数: " & leftFixedCount & " 列", vbInformation
    End If

SafeExit:
    On Error Resume Next
    If Not wsValidationTemplate Is Nothing Then
        Application.DisplayAlerts = False
        wsValidationTemplate.Delete
        Application.DisplayAlerts = True
    End If
    If Not wsFormatTemplate Is Nothing Then
        Application.DisplayAlerts = False
        wsFormatTemplate.Delete
        Application.DisplayAlerts = True
    End If
    On Error GoTo 0

    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Application.Calculation = previousCalculationMode
    Exit Sub

ErrorHandler:
    MsgBox "新ファイル基準表の作成中にエラーが発生しました: " & Err.Description, vbCritical
    Resume SafeExit


End Sub

'========================================================
' 色名 -> 2色名 同期（生成時/再生成時に利用）
'========================================================
Public Sub SyncSecondColorNameFromColor( _
    ByVal wsDst As Worksheet, _
    ByVal startRow As Long, _
    Optional ByVal endRow As Long = 0)

    Dim lastCol As Long
    Dim colorCol As Long
    Dim color2Col As Long
    Dim lastRow As Long
    Dim rowNo As Long
    Dim colorName As String

    If wsDst Is Nothing Then Exit Sub

    lastCol = GetLastUsedCol(wsDst)
    If lastCol <= 0 Then Exit Sub

    colorCol = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates("色名"))
    color2Col = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates("2色名"))
    If colorCol = 0 Or color2Col = 0 Then Exit Sub

    If endRow <= 0 Then
        lastRow = GetLastUsedRow(wsDst)
    Else
        lastRow = endRow
    End If
    If lastRow < startRow Then Exit Sub

    wsDst.Range(wsDst.Cells(startRow, color2Col), wsDst.Cells(lastRow, color2Col)).Value = _
        wsDst.Range(wsDst.Cells(startRow, colorCol), wsDst.Cells(lastRow, colorCol)).Value

    ' 値転記後に、色名/2色名セルへ背景色を設定する
    For rowNo = startRow To lastRow
        colorName = GetTrimmedCell(wsDst, rowNo, colorCol)
        SetCellColorByName wsDst.Cells(rowNo, colorCol), colorName
        SetCellColorByName wsDst.Cells(rowNo, color2Col), colorName
    Next rowNo

End Sub

'--------------------------------------------------------
' 色名文字列からセル背景色を設定する
' - 空欄: 何もしない
' - 未定義値: 何もしない
' - 白: 塗りつぶしなし
'--------------------------------------------------------
Private Sub SetCellColorByName(ByVal targetCell As Range, ByVal colorName As String)

    Dim normalized As String

    If targetCell Is Nothing Then Exit Sub

    normalized = Trim$(CStr(colorName))
    If normalized = "" Then Exit Sub

    Select Case normalized
        Case "赤"
            targetCell.Interior.Pattern = xlSolid
            targetCell.Interior.Color = RGB(255, 0, 0)
        Case "青"
            targetCell.Interior.Pattern = xlSolid
            targetCell.Interior.Color = RGB(0, 0, 255)
        Case "黄"
            targetCell.Interior.Pattern = xlSolid
            targetCell.Interior.Color = RGB(255, 255, 0)
        Case "緑"
            targetCell.Interior.Pattern = xlSolid
            targetCell.Interior.Color = RGB(0, 176, 80)
        Case "白"
            targetCell.Interior.Pattern = xlNone
        Case Else
            ' 指定外の色名は何もしない
    End Select

End Sub

'========================================================
' ｎ＋1 フラグ行から次年度フォルダ行を生成する
'========================================================
Public Sub nPlus1_次年度フォルダ生成()

    Dim wsDst As Worksheet
    Dim lastRow As Long
    Dim lastCol As Long
    Dim rowNo As Long
    Dim appendRow As Long
    Dim targetRows As Collection
    Dim generatedCount As Long
    Dim targetCount As Long
    Dim prevScreenUpdating As Boolean
    Dim prevEnableEvents As Boolean

    Dim colNPlus1 As Long
    Dim colWareki As Long
    Dim colCreateWareki As Long
    Dim colTitle As Long
    Dim colSubTitle As Long
    Dim colSpineTitle As Long
    Dim colSpineSubTitle As Long
    Dim colPublicTitle As Long
    Dim colPublicSubTitle As Long
    Dim colSyncStatus As Long
    Dim colHaiki As Long
    Dim headerMap As Object

    On Error GoTo ErrorHandler

    Set wsDst = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    Set targetRows = New Collection
    Set headerMap = CreateObject("Scripting.Dictionary")

    lastCol = GetLastUsedCol(wsDst)
    lastRow = GetLastUsedRow(wsDst)
    If lastCol <= 0 Or lastRow < 2 Then
        MsgBox "新ファイル基準表に対象データがありません。", vbInformation
        Exit Sub
    End If

    BuildHeaderMap wsDst, lastCol, headerMap

    colNPlus1 = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates("ｎ＋1"))
    colWareki = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates("年度（和暦）"))
    colCreateWareki = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates("作成年度（和暦）"))
    colTitle = FindHeaderColumn(wsDst, lastCol, Array("タイトル"))
    colSubTitle = FindHeaderColumn(wsDst, lastCol, Array("サブタイトル"))
    colSpineTitle = FindHeaderColumn(wsDst, lastCol, Array("背表紙用タイトル"))
    colSpineSubTitle = FindHeaderColumn(wsDst, lastCol, Array("背表紙用サブタイトル"))
    colPublicTitle = FindHeaderColumn(wsDst, lastCol, Array("公開用タイトル"))
    colPublicSubTitle = FindHeaderColumn(wsDst, lastCol, Array("公開用サブタイトル"))
    colSyncStatus = EnsureColumnByHeader(wsDst, headerMap, "同期状態")
    colHaiki = EnsureColumnByHeader(wsDst, headerMap, "廃棄年月日")

    If colNPlus1 <= 0 Then
        MsgBox "ｎ＋1 列が見つかりません。", vbExclamation
        Exit Sub
    End If

    For rowNo = 2 To lastRow
        If IsNPlus1Flag(GetTrimmedCell(wsDst, rowNo, colNPlus1)) Then
            targetRows.Add rowNo
        End If
    Next rowNo

    targetCount = targetRows.Count
    If targetCount = 0 Then
        MsgBox "ｎ＋1 フラグがある行はありません。", vbInformation
        Exit Sub
    End If

    prevScreenUpdating = Application.ScreenUpdating
    prevEnableEvents = Application.EnableEvents
    Application.ScreenUpdating = False
    Application.EnableEvents = False

    For rowNo = 1 To targetRows.Count
        appendRow = GetLastUsedRow(wsDst) + 1
        wsDst.Cells(appendRow, 1).Resize(1, lastCol).Value = _
            wsDst.Cells(CLng(targetRows(rowNo)), 1).Resize(1, lastCol).Value

        If colWareki > 0 Then
            wsDst.Cells(appendRow, colWareki).Value = IncrementWarekiYearText(CStr(wsDst.Cells(appendRow, colWareki).Value))
        End If
        If colCreateWareki > 0 Then
            wsDst.Cells(appendRow, colCreateWareki).Value = IncrementWarekiYearText(CStr(wsDst.Cells(appendRow, colCreateWareki).Value))
        End If

        IncrementTitleCellIfExists wsDst, appendRow, colTitle
        IncrementTitleCellIfExists wsDst, appendRow, colSubTitle
        IncrementTitleCellIfExists wsDst, appendRow, colSpineTitle
        IncrementTitleCellIfExists wsDst, appendRow, colSpineSubTitle
        IncrementTitleCellIfExists wsDst, appendRow, colPublicTitle
        IncrementTitleCellIfExists wsDst, appendRow, colPublicSubTitle

        ClearIdentityColumnsForNewRow wsDst, appendRow
        wsDst.Cells(appendRow, colSyncStatus).Value = "未登録"
        wsDst.Cells(appendRow, colHaiki).ClearContents
        wsDst.Cells(appendRow, colNPlus1).ClearContents

        generatedCount = generatedCount + 1
    Next rowNo

    ReindexSerial_NewFileStandard wsDst

SafeExit:
    Application.ScreenUpdating = prevScreenUpdating
    Application.EnableEvents = prevEnableEvents

    If generatedCount > 0 Then
        MsgBox "次年度フォルダ行を生成しました。" & vbCrLf & _
               "対象件数: " & targetCount & " 件" & vbCrLf & _
               "生成件数: " & generatedCount & " 件" & vbCrLf & _
               "年度表記を変換できなかったタイトルはそのままコピーしています。", vbInformation
    End If
    Exit Sub

ErrorHandler:
    MsgBox "次年度フォルダ生成中にエラーが発生しました: " & Err.Description, vbExclamation
    Resume SafeExit

End Sub

Private Function IsNPlus1Flag(ByVal flagText As String) As Boolean

    Dim s As String

    s = NormalizeBasicText(flagText)

    Select Case UCase$(s)
        Case "1", "○", "◯", "✓", "TRUE", "レ"
            IsNPlus1Flag = True
        Case Else
            IsNPlus1Flag = False
    End Select

End Function

Private Function IncrementWarekiYearText(ByVal warekiText As String) As String

    Dim eraName As String
    Dim eraYear As Long
    Dim westernYear As Long

    If ParseWarekiYear(warekiText, eraName, eraYear, westernYear) Then
        IncrementWarekiYearText = WesternYearToWarekiLabel(westernYear + 1)
    Else
        IncrementWarekiYearText = warekiText
    End If

End Function

Private Sub IncrementTitleCellIfExists(ByVal ws As Worksheet, ByVal rowNo As Long, ByVal colNo As Long)

    If ws Is Nothing Then Exit Sub
    If colNo <= 0 Then Exit Sub

    ws.Cells(rowNo, colNo).Value = IncrementYearExpressionsInTitle(CStr(ws.Cells(rowNo, colNo).Value))

End Sub

Private Function IncrementYearExpressionsInTitle(ByVal titleText As String) As String

    Dim s As String

    s = CStr(titleText)
    If Len(s) = 0 Then
        IncrementYearExpressionsInTitle = s
        Exit Function
    End If

    s = IncrementWarekiRangeExpressions(s)
    s = IncrementSingleWarekiToken(s)
    IncrementYearExpressionsInTitle = s

End Function

Private Function IncrementWarekiRangeExpressions(ByVal inputText As String) As String

    Dim s As String

    s = inputText
    s = IncrementWarekiRangePattern(s, "(令和)\s*(\d+)\s*(から|～|・|/)\s*(\d+)(年度|年)?", "令和")
    s = IncrementWarekiRangePattern(s, "(平成)\s*(\d+)\s*(から|～|・|/)\s*(\d+)(年度|年)?", "平成")
    s = IncrementWarekiRangePattern(s, "([Rr])\s*(\d+)\s*(から|～|・|/)\s*([Rr])?\s*(\d+)(年度|年)?", "R")
    s = IncrementWarekiRangePattern(s, "([Hh])\s*(\d+)\s*(から|～|・|/)\s*([Hh])?\s*(\d+)(年度|年)?", "H")
    IncrementWarekiRangeExpressions = s

End Function

Private Function IncrementWarekiRangePattern(ByVal inputText As String, ByVal patternText As String, ByVal eraType As String) As String

    Dim re As Object
    Dim matches As Object
    Dim m As Object
    Dim idx As Long
    Dim s As String
    Dim firstYear As Long
    Dim secondYear As Long
    Dim sepText As String
    Dim suffixText As String
    Dim replaced As String

    s = inputText
    Set re = CreateObject("VBScript.RegExp")
    re.Global = True
    re.IgnoreCase = True
    re.Pattern = patternText

    Set matches = re.Execute(s)
    If matches.Count = 0 Then
        IncrementWarekiRangePattern = s
        Exit Function
    End If

    For idx = matches.Count - 1 To 0 Step -1
        Set m = matches(idx)
        If eraType = "令和" Or eraType = "平成" Then
            firstYear = CLng(m.SubMatches(1))
            sepText = CStr(m.SubMatches(2))
            secondYear = CLng(m.SubMatches(3))
            suffixText = NzString(m.SubMatches(4))
            replaced = eraType & CStr(firstYear + 1) & sepText & CStr(secondYear + 1) & suffixText
        Else
            firstYear = CLng(m.SubMatches(1))
            sepText = CStr(m.SubMatches(2))
            secondYear = CLng(m.SubMatches(4))
            suffixText = NzString(m.SubMatches(5))
            replaced = eraType & CStr(firstYear + 1) & sepText & eraType & CStr(secondYear + 1) & suffixText
        End If

        s = Left$(s, m.FirstIndex) & replaced & Mid$(s, m.FirstIndex + m.Length + 1)
    Next idx

    IncrementWarekiRangePattern = s

End Function

Private Function IncrementSingleWarekiToken(ByVal inputText As String) As String

    Dim s As String

    s = inputText
    s = IncrementSinglePattern(s, "令和\s*(\d+)(年度|年)?", "令和")
    s = IncrementSinglePattern(s, "平成\s*(\d+)(年度|年)?", "平成")
    s = IncrementSinglePattern(s, "[Rr]\s*(\d+)(年度|年)?", "R")
    s = IncrementSinglePattern(s, "[Hh]\s*(\d+)(年度|年)?", "H")
    IncrementSingleWarekiToken = s

End Function

Private Function IncrementSinglePattern(ByVal inputText As String, ByVal patternText As String, ByVal prefixText As String) As String

    Dim re As Object
    Dim matches As Object
    Dim m As Object
    Dim idx As Long
    Dim yearNo As Long
    Dim suffixText As String
    Dim replaced As String
    Dim s As String

    s = inputText
    Set re = CreateObject("VBScript.RegExp")
    re.Global = True
    re.IgnoreCase = True
    re.Pattern = patternText

    Set matches = re.Execute(s)
    If matches.Count = 0 Then
        IncrementSinglePattern = s
        Exit Function
    End If

    For idx = matches.Count - 1 To 0 Step -1
        Set m = matches(idx)
        yearNo = CLng(m.SubMatches(0))
        suffixText = NzString(m.SubMatches(1))
        replaced = prefixText & CStr(yearNo + 1) & suffixText
        s = Left$(s, m.FirstIndex) & replaced & Mid$(s, m.FirstIndex + m.Length + 1)
    Next idx

    IncrementSinglePattern = s

End Function

Private Sub ClearIdentityColumnsForNewRow(ByVal ws As Worksheet, ByVal rowNo As Long)

    Dim clearHeaders As Variant
    Dim i As Long
    Dim colNo As Long
    Dim lastCol As Long

    If ws Is Nothing Then Exit Sub

    clearHeaders = Array( _
        "ファイルID", "ファイル番号", "バーコード番号", _
        "登録者メンバーID", "登録日時", _
        "更新者メンバーID", "更新日時", _
        "引継処理日", "棚卸処理日", "廃棄処理日", _
        "履歴番号", "履歴管理コメント")

    lastCol = GetLastUsedCol(ws)
    For i = LBound(clearHeaders) To UBound(clearHeaders)
        colNo = FindHeaderColumn(ws, lastCol, Array(CStr(clearHeaders(i))))
        If colNo > 0 Then ws.Cells(rowNo, colNo).ClearContents
    Next i

End Sub

Private Function NzString(ByVal v As Variant) As String

    If IsNull(v) Then
        NzString = ""
    Else
        NzString = CStr(v)
    End If

End Function

