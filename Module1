'========================================================
' 新ファイル基準表: Worksheet_Changeから呼び出す処理本体
'========================================================
Public Sub 新ファイル基準表_表示名からID自動補完(ByVal Target As Range)

    Dim wsEdit As Worksheet
    Dim lastCol As Long
    Dim pairDefs As Variant
    Dim i As Long
    Dim displayCol As Long
    Dim idCol As Long
    Dim watchRange As Range
    Dim workRange As Range
    Dim changedCell As Range
    Dim inputName As String
    Dim codeValue As String
    Dim warekiCol As Long
    Dim seirekiCol As Long
    Dim westernYear As String

    If Target Is Nothing Then Exit Sub
    If Target.CountLarge > 1000 Then Exit Sub

    On Error GoTo ExitHandler
    Application.EnableEvents = False

    Set wsEdit = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    If Target.Worksheet.name <> wsEdit.name Then GoTo ExitHandler

    lastCol = GetLastUsedCol(wsEdit)
    If lastCol <= 0 Then GoTo ExitHandler

    ' 表示列ヘッダー / ID列ヘッダー / コード管理CSV上の項目名
    pairDefs = Array( _
        Array("原課", "原課ID", "原課"), _
        Array("保存期間", "保存期間ID", "保存期間"), _
        Array("分類名１", "分類コード１", "分類名１"), _
        Array("分類名２", "分類コード２", "分類名２"), _
        Array("分類名３", "分類コード３", "分類名３"), _
        Array("媒体種別", "媒体種別ID", "媒体種別") _
    )

    ' 追加機能: 年度（和暦）→ 年度（西暦）自動反映
    warekiCol = GetHeaderColumnExact(wsEdit, "年度（和暦）")
    seirekiCol = GetHeaderColumnExact(wsEdit, "年度")

    ' 対象表示列だけを監視対象にする（見出し未存在はスキップ）
    For i = LBound(pairDefs) To UBound(pairDefs)
        displayCol = GetHeaderColumnExact(wsEdit, CStr(pairDefs(i)(0)))
        If displayCol > 0 Then
            Set workRange = wsEdit.Range(wsEdit.Cells(2, displayCol), wsEdit.Cells(wsEdit.Rows.Count, displayCol))
            If watchRange Is Nothing Then
                Set watchRange = workRange
            Else
                Set watchRange = Union(watchRange, workRange)
            End If
        End If
    Next i

    ' 追加機能: 「年度（和暦）」列も変更監視対象に含める
    If warekiCol > 0 Then
        Set workRange = wsEdit.Range(wsEdit.Cells(2, warekiCol), wsEdit.Cells(wsEdit.Rows.Count, warekiCol))
        If watchRange Is Nothing Then
            Set watchRange = workRange
        Else
            Set watchRange = Union(watchRange, workRange)
        End If
    End If

    If watchRange Is Nothing Then GoTo ExitHandler
    Set workRange = Intersect(Target, watchRange)
    If workRange Is Nothing Then GoTo ExitHandler

    ' 変更セルごとに表示列→ID列の補完を実施
    For Each changedCell In workRange.Cells
        '--------------------------------------------------------
        ' 追加機能: 年度（和暦）入力時に「年度」列へ西暦を反映
        '--------------------------------------------------------
        If warekiCol > 0 And seirekiCol > 0 Then
            If changedCell.Column = warekiCol Then
                westernYear = ConvertReiwaToWesternYear(CStr(changedCell.value))
                wsEdit.Cells(changedCell.row, seirekiCol).value = westernYear
                GoTo ContinueCellLoop
            End If
        End If

        For i = LBound(pairDefs) To UBound(pairDefs)
            displayCol = GetHeaderColumnExact(wsEdit, CStr(pairDefs(i)(0)))
            If displayCol = 0 Then GoTo ContinuePair
            If changedCell.Column <> displayCol Then GoTo ContinuePair

            idCol = GetHeaderColumnExact(wsEdit, CStr(pairDefs(i)(1)))
            If idCol = 0 Then Exit For ' ID見出しが無ければその項目はスキップ

            inputName = Trim(CStr(changedCell.value))
            If Len(inputName) = 0 Then
                wsEdit.Cells(changedCell.row, idCol).value = ""
            Else
                codeValue = GetCodeFromCodeMaster(CStr(pairDefs(i)(2)), inputName)
                If Len(codeValue) > 0 Then
                    wsEdit.Cells(changedCell.row, idCol).value = codeValue
                Else
                    wsEdit.Cells(changedCell.row, idCol).value = ""
                End If
            End If
            Exit For
ContinuePair:
        Next i
ContinueCellLoop:
    Next changedCell

ExitHandler:
    Application.EnableEvents = True

End Sub

'--------------------------------------------------------
' 見出し名(完全一致)から列番号を取得する
' 見つからない場合は0を返す
'--------------------------------------------------------
Private Function GetHeaderColumnExact(ByVal ws As Worksheet, ByVal headerName As String) As Long

    Dim c As Long
    Dim lastCol As Long
    Dim headerValue As String

    GetHeaderColumnExact = 0
    If ws Is Nothing Then Exit Function

    lastCol = GetLastUsedCol(ws)
    If lastCol <= 0 Then Exit Function

    For c = 1 To lastCol
        headerValue = Trim(CStr(ws.Cells(1, c).value))
        If StrComp(headerValue, Trim(headerName), vbBinaryCompare) = 0 Then
            GetHeaderColumnExact = c
            Exit Function
        End If
    Next c

End Function

'--------------------------------------------------------
' コード管理CSVから 区分 + 表示名 の完全一致でコードを取得する
' 見つからない場合は空文字を返す
'--------------------------------------------------------
Private Function GetCodeFromCodeMaster(ByVal kubunName As String, ByVal displayName As String) As String

    Dim wsMaster As Worksheet
    Dim lastRow As Long
    Dim r As Long
    Dim kubunValue As String
    Dim nameValue As String

    GetCodeFromCodeMaster = ""

    On Error GoTo SafeExit

    Set wsMaster = ThisWorkbook.Worksheets(SHEET_CODE_MANAGEMENT)
    If wsMaster Is Nothing Then GoTo SafeExit

    lastRow = GetLastUsedRow(wsMaster)
    If lastRow < 2 Then GoTo SafeExit

    ' コード管理CSV仕様: A列=項目名 / B列=コード / C列=表示名
    For r = 2 To lastRow
        kubunValue = Trim(CStr(wsMaster.Cells(r, 1).value))
        nameValue = Trim(CStr(wsMaster.Cells(r, 3).value))

        If StrComp(kubunValue, Trim(kubunName), vbBinaryCompare) = 0 _
           And StrComp(nameValue, Trim(displayName), vbBinaryCompare) = 0 Then
            GetCodeFromCodeMaster = Trim(CStr(wsMaster.Cells(r, 2).value))
            Exit For
        End If
    Next r

SafeExit:
    ' 見つからない場合やエラー時は空文字のまま返す

End Function

'--------------------------------------------------------
' 令和表記を西暦へ変換する
' 対応例: R7 / r7 / R07 / 令和7 / 令和7年度
' 変換式: 西暦 = 2018 + 令和年
' 変換不可・空白時は空文字を返す
'--------------------------------------------------------
Private Function ConvertReiwaToWesternYear(ByVal warekiText As String) As String

    Dim s As String
    Dim numPart As String
    Dim i As Long
    Dim ch As String
    Dim n As Long

    ConvertReiwaToWesternYear = ""

    s = Trim(CStr(warekiText))
    If Len(s) = 0 Then Exit Function

    ' 全角/半角スペースを除去
    s = Replace(s, " ", "")
    s = Replace(s, "　", "")

    ' 接頭辞を除去（R / r / 令和）
    If LCase$(Left$(s, 1)) = "r" Then
        numPart = Mid$(s, 2)
    ElseIf Left$(s, 2) = "令和" Then
        numPart = Mid$(s, 3)
    Else
        Exit Function
    End If

    ' 「年度」を除去
    numPart = Replace(numPart, "年度", "")
    numPart = Trim$(numPart)
    If Len(numPart) = 0 Then Exit Function

    ' 数字だけを抽出
    For i = 1 To Len(numPart)
        ch = Mid$(numPart, i, 1)
        If ch Like "#" Then
            ConvertReiwaToWesternYear = ConvertReiwaToWesternYear & ch
        End If
    Next i

    If Len(ConvertReiwaToWesternYear) = 0 Then
        ConvertReiwaToWesternYear = ""
        Exit Function
    End If

    n = CLng(ConvertReiwaToWesternYear)
    If n <= 0 Then
        ConvertReiwaToWesternYear = ""
        Exit Function
    End If

    ConvertReiwaToWesternYear = CStr(2018 + n)

End Function

Private Function GetLastUsedRow(ByVal ws As Worksheet) As Long

    Dim lastCell As Range

    Set lastCell = ws.Cells.Find(What:="*", LookIn:=xlFormulas, SearchOrder:=xlByRows, SearchDirection:=xlPrevious)
    If lastCell Is Nothing Then
        GetLastUsedRow = 1
    Else
        GetLastUsedRow = lastCell.row
    End If

End Function

Private Function GetLastUsedCol(ByVal ws As Worksheet) As Long

    Dim lastCell As Range

    Set lastCell = ws.Cells.Find(What:="*", LookIn:=xlFormulas, SearchOrder:=xlByColumns, SearchDirection:=xlPrevious)
    If lastCell Is Nothing Then
        GetLastUsedCol = 0
    Else
        GetLastUsedCol = lastCell.Column
    End If

End Function

'========================================================
' frmSeal から呼び出す新基準表→個別フォルダシール反映
'========================================================
Public Sub ApplyBySerial_NewSpec(ByVal startSerial As String)

    Dim wsSrc As Worksheet
    Dim wsSeal As Worksheet
    Dim serialIndex As Object
    Dim headerIndex As Object

    Dim startNo As Long
    Dim slot As Long
    Dim serialKey As String
    Dim srcRow As Long

    On Error GoTo ErrorHandler

    Set wsSrc = ResolveWorksheetByCandidates(ThisWorkbook, Array("新ファイル基準表"))
    Set wsSeal = ResolveWorksheetByCandidates(ThisWorkbook, Array("個別フォルダシール", "個別フォルダーシール", "フォルダシール"))

    If wsSrc Is Nothing Then
        Err.Raise vbObjectError + 1201, , "転記元シート（新ファイル基準表）が見つかりません。"
    End If

    If wsSeal Is Nothing Then
        Err.Raise vbObjectError + 1202, , "転記先シート（個別フォルダシール）が見つかりません。"
    End If

    frmSeal.BuildIndexes_NewSpec wsSrc, serialIndex, headerIndex

    If serialIndex Is Nothing Or headerIndex Is Nothing Then
        Err.Raise vbObjectError + 1203, , "見出しインデックスの作成に失敗しました。"
    End If

    If CLng(headerIndex("通し番号")) = 0 Then
        Err.Raise vbObjectError + 1204, , "見出し「通し番号」が見つかりません。"
    End If

    startNo = CLng(Val(startSerial))
    If startNo <= 0 Then
        Err.Raise vbObjectError + 1205, , "開始通し番号は 1 以上の数値で入力してください。"
    End If

    For slot = 1 To 12
        serialKey = CStr(startNo + slot - 1)

        If serialIndex.Exists(serialKey) Then
            srcRow = CLng(serialIndex(serialKey))
            frmSeal.WriteOneSeal_NewSpec _
                wsSrc, srcRow, wsSeal, slot, _
                CLng(headerIndex("タイトル")), _
                CLng(headerIndex("分類名2")), _
                CLng(headerIndex("分類名3")), _
                CLng(headerIndex("年度和暦")), _
                CLng(headerIndex("保存期間"))
        Else
            ClearOneSealSlot wsSeal, slot
        End If
    Next slot

    Exit Sub

ErrorHandler:
    Err.Raise Err.Number, Err.Source, Err.Description

End Sub

Public Sub ClearOneSealSlot(ByVal wsSeal As Worksheet, ByVal slot As Long)

    Dim baseCol As Long
    Dim baseRow As Long
    Dim offSlash As Long
    Dim offG1 As Long

    GroupBase slot, baseCol, baseRow, offSlash, offG1

    ClearMergeTarget wsSeal, baseRow, baseCol
    ClearMergeTarget wsSeal, baseRow, baseCol + 1
    ClearMergeTarget wsSeal, baseRow, baseCol + 7
    ClearMergeTarget wsSeal, baseRow + 1, baseCol
    ClearMergeTarget wsSeal, baseRow + 1, baseCol + 1

    PutMergeTopLeft wsSeal, baseRow, baseCol, ""
    PutMergeTopLeft wsSeal, baseRow, baseCol + 1, ""
    PutMergeTopLeft wsSeal, baseRow, baseCol + 7, ""
    PutMergeTopLeft wsSeal, baseRow + 1, baseCol, ""
    PutMergeTopLeft wsSeal, baseRow + 1, baseCol + 1, ""

End Sub

Private Function ResolveWorksheetByCandidates(ByVal wb As Workbook, ByVal candidates As Variant) As Worksheet

    Dim i As Long
    Dim ws As Worksheet

    On Error Resume Next
    For i = LBound(candidates) To UBound(candidates)
        Set ws = Nothing
        Set ws = wb.Worksheets(CStr(candidates(i)))
        If Not ws Is Nothing Then
            Set ResolveWorksheetByCandidates = ws
            Exit Function
        End If
    Next i
    On Error GoTo 0

End Function

'========================================================
' 個別フォルダシール配置ユーティリティ
' 既存frmSealのPrivate実装を標準モジュールへ移設
'========================================================
Public Sub GroupBase( _
    ByVal idx As Long, _
    ByRef baseCol As Long, _
    ByRef baseRow As Long, _
    ByRef offSlash As Long, _
    ByRef offG1 As Long)

    Dim rowMap As Variant

    rowMap = Array(2, 5, 8, 11, 14, 17)

    If idx < 1 Then idx = 1
    If idx > 12 Then idx = 12

    If idx <= 6 Then
        baseCol = 1                ' 左ブロック A列起点
        baseRow = CLng(rowMap(idx - 1))
    Else
        baseCol = 12               ' 右ブロック L列起点
        baseRow = CLng(rowMap(idx - 7))
    End If

    offSlash = 6
    offG1 = 7

End Sub

Public Sub ClearMergeTarget(ByVal ws As Worksheet, ByVal r As Long, ByVal c As Long)

    With ws.Cells(r, c)
        If .MergeCells Then
            .MergeArea.ClearContents
        Else
            .ClearContents
        End If
    End With

End Sub

Public Sub PutMergeTopLeft(ByVal ws As Worksheet, ByVal r As Long, ByVal c As Long, ByVal v As Variant)

    With ws.Cells(r, c)
        If .MergeCells Then
            .MergeArea.Cells(1, 1).value = v
        Else
            .value = v
        End If
    End With

End Sub

