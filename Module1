Public Sub SyncSecondColorNameFromColor( _
    ByVal wsDst As Worksheet, _
    ByVal startRow As Long, _
    Optional ByVal endRow As Long = 0)

    Dim lastCol As Long
    Dim colorCol As Long
    Dim color2Col As Long
    Dim lastRow As Long

    If wsDst Is Nothing Then Exit Sub

    lastCol = GetLastUsedCol(wsDst)
    If lastCol <= 0 Then Exit Sub

    colorCol = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates("色名"))
    color2Col = FindHeaderColumn(wsDst, lastCol, GetStep2HeaderCandidates("2色名"))
    If colorCol = 0 Or color2Col = 0 Then Exit Sub

    If endRow <= 0 Then
        lastRow = GetLastUsedRow(wsDst)
    Else
        lastRow = endRow
    End If
    If lastRow < startRow Then Exit Sub

    wsDst.Range(wsDst.Cells(startRow, color2Col), wsDst.Cells(lastRow, color2Col)).Value = _
        wsDst.Range(wsDst.Cells(startRow, colorCol), wsDst.Cells(lastRow, colorCol)).Value

End Sub

