Option Explicit

Private Const SHEET_MOKUROKU As String = "目録CSV"
Private Const SHEET_VIEW As String = "新ファイル基準表"
Private Const SHEET_CODE As String = "コード管理CSV"
Private Const SHEET_IMPORT As String = "差分インポートCSV"
' SHEET_CODE / SHEET_IMPORT are reserved for future code-completion/export features.

Public Sub CSVを取り込む()
    Call ImportCsvToMokurokuSheet
End Sub

Public Sub CSVを取り込んで整形()
    If ImportCsvToMokurokuSheet() Then
        CSVを旧基準表形式に整形
    End If
End Sub

Private Function ImportCsvToMokurokuSheet() As Boolean
    Dim wsSrc As Worksheet
    Dim selectedPath As Variant
    Dim csvWb As Workbook
    Dim csvWs As Worksheet
    Const SHIFT_JIS_CODEPAGE As Long = 932
    
    On Error GoTo ErrHandler
    
    selectedPath = Application.GetOpenFilename( _
        FileFilter:="CSV Files (*.csv),*.csv", _
        Title:="取り込むCSVファイルを選択してください")
    
    If VarType(selectedPath) = vbBoolean Then
        If selectedPath = False Then
            MsgBox "CSVファイルが選択されなかったため、処理を終了しました。", vbExclamation
            ImportCsvToMokurokuSheet = False
            Exit Function
        End If
    End If
    
    Set wsSrc = GetWorksheetByName(SHEET_MOKUROKU)
    
    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.DisplayAlerts = False
    
    wsSrc.Cells.Clear
    
    ' This project currently assumes Shift-JIS CSV from upstream systems.
    Set csvWb = OpenCsvAsWorkbook(CStr(selectedPath), SHIFT_JIS_CODEPAGE)
    Set csvWs = csvWb.Worksheets(1)
    
    csvWs.UsedRange.Copy Destination:=wsSrc.Range("A1")
    csvWb.Close SaveChanges:=False
    Set csvWb = Nothing
    
    ImportCsvToMokurokuSheet = True
    MsgBox "CSVを目録CSVシートにそのまま取り込みました。", vbInformation
    
Cleanup:
    If Not csvWb Is Nothing Then
        csvWb.Close SaveChanges:=False
    End If
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Application.DisplayAlerts = True
    Exit Function
    
ErrHandler:
    ImportCsvToMokurokuSheet = False
    If InStr(Err.Description, "シート '") > 0 Then
        MsgBox Err.Description, vbExclamation
    Else
        MsgBox "CSVの取り込みに失敗しました。" & vbCrLf & _
               "このCSVはShift-JIS(932)前提で読み込みます。将来的にUTF-8対応を追加可能です。" & vbCrLf & _
               Err.Description, vbExclamation
    End If
    Resume Cleanup
End Function

Private Function OpenCsvAsWorkbook(ByVal csvPath As String, ByVal codePage As Long) As Workbook
    ' Use Excel's text import engine so delimiter and quoting behavior
    ' stays close to opening the CSV directly in Excel.
    ' Current default is Shift-JIS (932). For future extension, this function
    ' can be called with 65001 (UTF-8) and fallback logic can be added.
    Workbooks.OpenText _
        Filename:=csvPath, _
        Origin:=codePage, _
        StartRow:=1, _
        DataType:=xlDelimited, _
        TextQualifier:=xlTextQualifierDoubleQuote, _
        ConsecutiveDelimiter:=False, _
        Tab:=False, _
        Semicolon:=False, _
        Comma:=True, _
        Space:=False, _
        Other:=False, _
        Local:=True
    
    Set OpenCsvAsWorkbook = ActiveWorkbook
End Function

Sub CSVを旧基準表形式に整形()

    Dim wsSrc As Worksheet
    Dim wsDst As Worksheet
    Dim headerRow As Long
    Dim dataStartRow As Long
    Dim lastRow As Long
    Dim lastOutRow As Long
    Dim outRow As Long
    Dim i As Long
    
    Dim colNendo As Long
    Dim colBunrui1 As Long
    Dim colBunrui2 As Long
    Dim colBunrui3 As Long
    Dim colTitle As Long
    Dim colHozon As Long
    Dim colMedia As Long
    
    ' ===== 設定 =====
    ' 処理フロー:
    ' 目録CSV（元データ）→ 整形 → 新ファイル基準表（表示・編集用）
    Set wsSrc = GetWorksheetByName(SHEET_MOKUROKU)
    Set wsDst = GetWorksheetByName(SHEET_VIEW)
    
    ' 現在のCSV構造:
    ' 1行目=正式見出し、2～10行目=補助情報、11行目以降=実データ
    ' 見出し行は自動検出し、データ開始は11行目以降を保証する。
    headerRow = DetectHeaderRow(wsSrc)
    If headerRow = 0 Then
        headerRow = 1
    End If
    dataStartRow = Application.WorksheetFunction.Max(11, headerRow + 1)
    
    Application.ScreenUpdating = False
    Application.EnableEvents = False
    
    On Error GoTo ErrHandler
    
    ' ===== 元シートの見出し列を取得 =====
    colNendo = FindHeaderColumn(wsSrc, headerRow, "年度（和暦）")
    If colNendo = 0 Then colNendo = FindHeaderColumn(wsSrc, headerRow, "年度(和暦)")
    colBunrui1 = FindHeaderColumn(wsSrc, headerRow, "分類名１")
    If colBunrui1 = 0 Then colBunrui1 = FindHeaderColumn(wsSrc, headerRow, "分類名1")
    
    colBunrui2 = FindHeaderColumn(wsSrc, headerRow, "分類名２")
    If colBunrui2 = 0 Then colBunrui2 = FindHeaderColumn(wsSrc, headerRow, "分類名2")
    
    colBunrui3 = FindHeaderColumn(wsSrc, headerRow, "分類名３")
    If colBunrui3 = 0 Then colBunrui3 = FindHeaderColumn(wsSrc, headerRow, "分類名3")
    
    colTitle = FindHeaderColumn(wsSrc, headerRow, "タイトル")
    colHozon = FindHeaderColumn(wsSrc, headerRow, "保存期間")
    colMedia = FindHeaderColumn(wsSrc, headerRow, "媒体種別")
    
    ' 必須チェック
    CheckColumn colNendo, "年度（和暦）"
    CheckColumn colBunrui1, "分類名１"
    CheckColumn colBunrui2, "分類名２"
    CheckColumn colBunrui3, "分類名３"
    CheckColumn colTitle, "タイトル"
    CheckColumn colHozon, "保存期間"
    CheckColumn colMedia, "媒体種別"
    
    ' ===== 出力先クリア =====
    wsDst.Cells.Clear
    
    ' ===== 出力見出し =====
    wsDst.Cells(1, 1).Value = "年度"
    wsDst.Cells(1, 2).Value = "第0ガイド"
    wsDst.Cells(1, 3).Value = "第1ガイド"
    wsDst.Cells(1, 4).Value = "第2ガイド"
    wsDst.Cells(1, 5).Value = "個別フォルダー"
    wsDst.Cells(1, 6).Value = "保存期間"
    wsDst.Cells(1, 7).Value = "媒体"
    ' 将来拡張メモ（必要時に列追加）
    ' - 処理区分（新規 / 更新）
    ' - 更新フラグ
    ' - ファイルID（裏で保持）
    
    ' ===== 最終行取得 =====
    lastRow = GetLastRowByColumns(wsSrc, Array(colNendo, colBunrui1, colBunrui2, colBunrui3, colTitle, colHozon, colMedia))
    
    ' ===== データ転記 =====
    outRow = 2
    For i = dataStartRow To lastRow
        
        ' 完全空行はスキップ
        If Application.WorksheetFunction.CountA(wsSrc.Rows(i)) > 0 Then
            wsDst.Cells(outRow, 1).Value = wsSrc.Cells(i, colNendo).Value
            wsDst.Cells(outRow, 2).Value = wsSrc.Cells(i, colBunrui1).Value
            wsDst.Cells(outRow, 3).Value = wsSrc.Cells(i, colBunrui2).Value
            wsDst.Cells(outRow, 4).Value = wsSrc.Cells(i, colBunrui3).Value
            wsDst.Cells(outRow, 5).Value = wsSrc.Cells(i, colTitle).Value
            wsDst.Cells(outRow, 6).Value = wsSrc.Cells(i, colHozon).Value
            wsDst.Cells(outRow, 7).Value = wsSrc.Cells(i, colMedia).Value
            outRow = outRow + 1
        End If
    Next i
    lastOutRow = outRow - 1
    
    ' ===== 並び替え =====
    If lastOutRow >= 2 Then
        With wsDst.Sort
            .SortFields.Clear
            .SortFields.Add Key:=wsDst.Range("A2:A" & lastOutRow), SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal
            .SortFields.Add Key:=wsDst.Range("B2:B" & lastOutRow), SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal
            .SortFields.Add Key:=wsDst.Range("C2:C" & lastOutRow), SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal
            .SortFields.Add Key:=wsDst.Range("D2:D" & lastOutRow), SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal
            .SortFields.Add Key:=wsDst.Range("E2:E" & lastOutRow), SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal
            .SetRange wsDst.Range("A1:G" & lastOutRow)
            .Header = xlYes
            .MatchCase = False
            .Orientation = xlTopToBottom
            .Apply
        End With
    End If
    
    ' ===== 体裁調整 =====
    With wsDst
        .Rows(1).Font.Bold = True
        .Rows(1).Interior.Color = RGB(217, 217, 217)
        .Rows(1).HorizontalAlignment = xlCenter
        .Columns("A:G").EntireColumn.AutoFit
        .Range("A1:G1").AutoFilter
        
        If lastOutRow >= 1 Then
            .Range("A1:G" & lastOutRow).Borders.LineStyle = xlContinuous
        End If
        
        If lastOutRow >= 2 Then
            .Range("A2:A" & lastOutRow).HorizontalAlignment = xlCenter
            .Range("F2:G" & lastOutRow).HorizontalAlignment = xlCenter
            .Range("E2:E" & lastOutRow).HorizontalAlignment = xlLeft
        End If
    End With
    
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    
    MsgBox "整形が完了しました。", vbInformation
    Exit Sub

ErrHandler:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    If InStr(Err.Description, "見出し「") > 0 Then
        MsgBox "エラーが発生しました：" & vbCrLf & Err.Description & vbCrLf & _
               "想定している見出し行と実際のCSV構造が異なる可能性があります。", vbExclamation
    Else
        MsgBox "エラーが発生しました：" & vbCrLf & Err.Description, vbExclamation
    End If

End Sub

Private Function GetWorksheetByName(ByVal sheetName As String) As Worksheet
    On Error Resume Next
    Set GetWorksheetByName = ThisWorkbook.Worksheets(sheetName)
    On Error GoTo 0
    
    If GetWorksheetByName Is Nothing Then
        Err.Raise vbObjectError + 1100, , "シート '" & sheetName & "' が見つかりません。"
    End If
End Function

Private Function DetectHeaderRow(ByVal ws As Worksheet) As Long
    Dim r As Long
    Const SEARCH_LIMIT As Long = 30
    
    For r = 1 To SEARCH_LIMIT
        If HasRequiredHeadersInRow(ws, r) Then
            DetectHeaderRow = r
            Exit Function
        End If
    Next r
    
    DetectHeaderRow = 0
End Function

Private Function HasRequiredHeadersInRow(ByVal ws As Worksheet, ByVal rowNum As Long) As Boolean
    If FindHeaderColumn(ws, rowNum, "年度（和暦）") = 0 And _
       FindHeaderColumn(ws, rowNum, "年度(和暦)") = 0 Then
        Exit Function
    End If
    
    If FindHeaderColumn(ws, rowNum, "分類名１") = 0 And _
       FindHeaderColumn(ws, rowNum, "分類名1") = 0 Then
        Exit Function
    End If
    
    If FindHeaderColumn(ws, rowNum, "分類名２") = 0 And _
       FindHeaderColumn(ws, rowNum, "分類名2") = 0 Then
        Exit Function
    End If
    
    If FindHeaderColumn(ws, rowNum, "分類名３") = 0 And _
       FindHeaderColumn(ws, rowNum, "分類名3") = 0 Then
        Exit Function
    End If
    
    If FindHeaderColumn(ws, rowNum, "タイトル") = 0 Then Exit Function
    If FindHeaderColumn(ws, rowNum, "保存期間") = 0 Then Exit Function
    If FindHeaderColumn(ws, rowNum, "媒体種別") = 0 Then Exit Function
    
    HasRequiredHeadersInRow = True
End Function

Private Function FindHeaderColumn(ws As Worksheet, headerRow As Long, headerName As String) As Long
    Dim lastCol As Long
    Dim c As Long
    
    lastCol = ws.Cells(headerRow, ws.Columns.Count).End(xlToLeft).Column
    
    For c = 1 To lastCol
        If Trim(CStr(ws.Cells(headerRow, c).Value)) = headerName Then
            FindHeaderColumn = c
            Exit Function
        End If
    Next c
    
    FindHeaderColumn = 0
End Function

Private Sub CheckColumn(colNum As Long, headerName As String)
    If colNum = 0 Then
        Err.Raise vbObjectError + 1000, , "見出し「" & headerName & "」が見つかりません。"
    End If
End Sub

Private Function GetLastRowByColumns(ws As Worksheet, cols As Variant) As Long
    Dim i As Long
    Dim tmpLast As Long
    Dim maxLast As Long
    
    maxLast = 0
    For i = LBound(cols) To UBound(cols)
        tmpLast = ws.Cells(ws.Rows.Count, cols(i)).End(xlUp).Row
        If tmpLast > maxLast Then maxLast = tmpLast
    Next i
    
    GetLastRowByColumns = maxLast
End Function
