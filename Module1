Public Sub CSV取込_シンプル版()

    Dim ws As Worksheet
    Dim filePath As Variant
    Dim wbCSV As Workbook
    Dim wsCSV As Worksheet
    Dim dstLastRow As Long
    Dim dstLastCol As Long
    Dim srcLastRow As Long
    Dim srcLastCol As Long
    Dim appendRow As Long
    Dim srcRow As Long
    Dim appendedCount As Long
    Dim deletedCount As Long
    Dim skippedBlankYearCount As Long
    Dim existingHasHeader As Boolean
    Dim srcWarekiCol As Long
    Dim dstWarekiCol As Long
    Dim targetFiscalYear As String
    Dim rowYear As String
    Dim annualFixChangedCount As Long
    Dim annualFixReviewCount As Long

    On Error GoTo ErrorHandler

    ' ファイル選択
    filePath = Application.GetOpenFilename("CSV Files (*.csv), *.csv")
    
    If filePath = False Then Exit Sub
    
    ' 目録CSVシート
    Set ws = ThisWorkbook.Worksheets("目録CSV")
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' CSVを開く
    Set wbCSV = Workbooks.Open(filePath)
    Set wsCSV = wbCSV.Sheets(1)

    srcLastRow = GetLastUsedRow(wsCSV)
    srcLastCol = GetLastUsedCol(wsCSV)
    dstLastRow = GetLastUsedRow(ws)
    dstLastCol = GetLastUsedCol(ws)
    existingHasHeader = (dstLastRow >= 1 And dstLastCol > 0 And Len(Trim$(CStr(ws.Cells(1, 1).Value))) > 0)

    If srcLastCol <= 0 Then Err.Raise vbObjectError + 2101, , "選択したCSVの見出し行が見つかりません。"

    ' 取込CSV側の「年度（和暦）」列を特定
    srcWarekiCol = FindHeaderColumn(wsCSV, srcLastCol, Array("年度（和暦）", "年度(和暦)"))
    If srcWarekiCol <= 0 Then
        Err.Raise vbObjectError + 2102, , "取込CSVに「年度（和暦）」列が見つかりません。"
    End If

    ' 2行目以降の最初の非空欄値を「今回取込対象年度」とする
    For srcRow = 2 To srcLastRow
        rowYear = GetTrimmedCell(wsCSV, srcRow, srcWarekiCol)
        If rowYear <> "" Then
            targetFiscalYear = rowYear
            Exit For
        End If
    Next srcRow
    If targetFiscalYear = "" Then
        Err.Raise vbObjectError + 2103, , "取込CSVの「年度（和暦）」列から対象年度を取得できません。"
    End If

    ' 単年CSV前提のため、対象年度以外が混在していないか事前検証
    For srcRow = 2 To srcLastRow
        rowYear = GetTrimmedCell(wsCSV, srcRow, srcWarekiCol)
        If rowYear <> "" And rowYear <> targetFiscalYear Then
            Err.Raise vbObjectError + 2104, , _
                "取込CSVに複数年度が混在しています。行" & srcRow & _
                " の年度（和暦）=""" & rowYear & """（対象年度: " & targetFiscalYear & "）"
        End If
    Next srcRow

    If Not existingHasHeader Then
        ' 初回取込: 見出しはそのまま取り込む
        ws.Range(ws.Cells(1, 1), ws.Cells(1, srcLastCol)).Value = _
            wsCSV.Range(wsCSV.Cells(1, 1), wsCSV.Cells(1, srcLastCol)).Value
        NormalizeHeaderLineBreaks ws
        appendRow = 2
    Else
        ' 追記取込: 既存見出しを維持
        NormalizeHeaderLineBreaks ws

        ' 目録CSVシート側の「年度（和暦）」列を特定
        dstWarekiCol = FindHeaderColumn(ws, dstLastCol, Array("年度（和暦）", "年度(和暦)"))
        If dstWarekiCol <= 0 Then
            Err.Raise vbObjectError + 2105, , "目録CSVシートに「年度（和暦）」列が見つかりません。"
        End If

        ' 高速化対応: 対象年度行を連続ブロック単位で一括削除（他年度は残す）
        deletedCount = DeleteRowsByFiscalYearBulk(ws, 2, dstLastRow, dstWarekiCol, targetFiscalYear)

        dstLastRow = GetLastUsedRow(ws)
        appendRow = dstLastRow + 1
    End If

    ' データ部（2行目以降）を重複判定なしで追記
    For srcRow = 2 To srcLastRow
        rowYear = GetTrimmedCell(wsCSV, srcRow, srcWarekiCol)

        If rowYear = "" Then
            skippedBlankYearCount = skippedBlankYearCount + 1
        Else
            ws.Range(ws.Cells(appendRow, 1), ws.Cells(appendRow, srcLastCol)).Value = _
                wsCSV.Range(wsCSV.Cells(srcRow, 1), wsCSV.Cells(srcRow, srcLastCol)).Value
            appendRow = appendRow + 1
            appendedCount = appendedCount + 1
        End If
    Next srcRow
    
    wbCSV.Close False

    ' 取込後補正: 「毎年作成」行のみ年度表現を安全に補正
    ApplyAnnualFolderNameCorrections ws, annualFixChangedCount, annualFixReviewCount
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    
    MsgBox "CSV取込完了" & vbCrLf & _
           "対象年度: " & targetFiscalYear & vbCrLf & _
           "削除件数: " & deletedCount & " 件" & vbCrLf & _
           "取込件数: " & appendedCount & " 件" & vbCrLf & _
           "年度空欄スキップ件数: " & skippedBlankYearCount & " 件" & vbCrLf & _
           "年度表現補正件数: " & annualFixChangedCount & " 件" & vbCrLf & _
           "年度表現要確認件数: " & annualFixReviewCount & " 件", vbInformation
    Exit Sub

ErrorHandler:
    On Error Resume Next
    If Not wbCSV Is Nothing Then wbCSV.Close False
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    On Error GoTo 0
    MsgBox "CSV取込中にエラーが発生しました: " & Err.Description, vbExclamation

End Sub

'========================================================
' CSV取込後補正: 「毎年作成」行の年度表現のみ安全に補正
'========================================================
Private Sub ApplyAnnualFolderNameCorrections( _
    ByVal ws As Worksheet, _
    ByRef changedCount As Long, _
    ByRef reviewCount As Long)

    Dim lastRow As Long
    Dim lastCol As Long
    Dim rowNo As Long
    Dim fiscalCol As Long
    Dim annualUseCol As Long
    Dim reviewCol As Long
    Dim targetCols As Variant
    Dim i As Long
    Dim colNo As Long
    Dim fiscalYear As String
    Dim annualUseVal As String
    Dim originalValue As String
    Dim correctedValue As String
    Dim rowChanged As Boolean
    Dim rowNeedsReview As Boolean
    Dim corrected As Boolean
    Dim needsReview As Boolean
    Dim reason As String
    Dim reviewReasons As String

    If ws Is Nothing Then Exit Sub

    lastCol = GetLastUsedCol(ws)
    lastRow = GetLastUsedRow(ws)
    If lastCol <= 0 Or lastRow < 2 Then Exit Sub

    fiscalCol = FindHeaderColumn(ws, lastCol, Array("年度（和暦）", "年度(和暦)", "年度"))
    annualUseCol = FindHeaderColumn(ws, lastCol, Array("毎年度利用区分", "毎年度利用区分1:毎年作成 2:単年のみ"))
    If fiscalCol <= 0 Or annualUseCol <= 0 Then Exit Sub

    targetCols = ResolveAnnualCorrectionTargetColumns(ws, lastCol)
    If IsEmpty(targetCols) Then Exit Sub

    reviewCol = EnsureHeaderColumn(ws, "年度補正確認")

    For rowNo = 2 To lastRow
        annualUseVal = GetTrimmedCell(ws, rowNo, annualUseCol)
        If Not IsAnnualCreationCategory(annualUseVal) Then GoTo ContinueNextRow

        fiscalYear = GetTrimmedCell(ws, rowNo, fiscalCol)
        rowChanged = False
        rowNeedsReview = False
        reviewReasons = ""

        For i = LBound(targetCols) To UBound(targetCols)
            colNo = CLng(targetCols(i))
            originalValue = CStr(ws.Cells(rowNo, colNo).Value)
            correctedValue = NormalizeAnnualFolderName(originalValue, fiscalYear, corrected, needsReview, reason)

            If corrected Then
                ws.Cells(rowNo, colNo).Value = correctedValue
                rowChanged = True
            End If

            If needsReview Then
                rowNeedsReview = True
                If Len(reason) > 0 Then
                    If Len(reviewReasons) > 0 Then reviewReasons = reviewReasons & " / "
                    reviewReasons = reviewReasons & ws.Cells(1, colNo).Value & ":" & reason
                End If
            End If
        Next i

        If rowChanged Then changedCount = changedCount + 1
        If rowNeedsReview Then
            reviewCount = reviewCount + 1
            ws.Cells(rowNo, reviewCol).Value = "要確認" & IIf(Len(reviewReasons) > 0, "（" & reviewReasons & "）", "")
        ElseIf rowChanged Then
            ws.Cells(rowNo, reviewCol).Value = "補正済"
        Else
            ws.Cells(rowNo, reviewCol).ClearContents
        End If

ContinueNextRow:
    Next rowNo

End Sub

Private Function ResolveAnnualCorrectionTargetColumns(ByVal ws As Worksheet, ByVal lastCol As Long) As Variant

    ' 補正対象列は配列で定義（将来追加しやすい）
    ' まずは「フォルダ名相当」としてタイトル列のみを対象
    Dim targetHeaderCandidates As Variant
    Dim resultCols() As Long
    Dim i As Long
    Dim colNo As Long
    Dim count As Long

    targetHeaderCandidates = Array(Array("タイトル"))

    ReDim resultCols(0 To 0)
    count = 0

    For i = LBound(targetHeaderCandidates) To UBound(targetHeaderCandidates)
        colNo = FindHeaderColumn(ws, lastCol, targetHeaderCandidates(i))
        If colNo > 0 Then
            If count > 0 Then ReDim Preserve resultCols(0 To count)
            resultCols(count) = colNo
            count = count + 1
        End If
    Next i

    If count = 0 Then
        ResolveAnnualCorrectionTargetColumns = Empty
    Else
        ResolveAnnualCorrectionTargetColumns = resultCols
    End If

End Function

Private Function EnsureHeaderColumn(ByVal ws As Worksheet, ByVal headerName As String) As Long

    Dim lastCol As Long
    Dim colNo As Long

    lastCol = GetLastUsedCol(ws)
    colNo = FindHeaderColumn(ws, lastCol, Array(headerName))
    If colNo > 0 Then
        EnsureHeaderColumn = colNo
        Exit Function
    End If

    colNo = lastCol + 1
    ws.Cells(1, colNo).Value = headerName
    EnsureHeaderColumn = colNo

End Function

Private Function IsAnnualCreationCategory(ByVal categoryText As String) As Boolean

    Dim s As String

    s = NormalizeBasicText(categoryText)
    IsAnnualCreationCategory = (InStr(1, s, "毎年作成", vbTextCompare) > 0 Or s = "1")

End Function

' 年度補正メイン
' - 補正する: 遷移表現（A→B）/ 単独年度表現（令和N年度, RN, N年度）
' - 補正しない: 曖昧な数字、号数・様式番号など年度断定不可なもの
Private Function NormalizeAnnualFolderName( _
    ByVal folderName As String, _
    ByVal fiscalYear As String, _
    ByRef wasCorrected As Boolean, _
    ByRef needsReview As Boolean, _
    Optional ByRef reason As String = "") As String

    Dim s As String
    Dim changedTransition As Boolean
    Dim changedSingle As Boolean
    Dim reviewTransition As Boolean
    Dim reviewSingle As Boolean
    Dim transitionReason As String
    Dim singleReason As String

    s = CStr(folderName)
    If Len(s) = 0 Then
        NormalizeAnnualFolderName = s
        Exit Function
    End If

    ' 優先1: 遷移表現（例: 7→8 / R8→9 / 令和8年度→令和9年度）を先に+1
    s = ShiftYearTransitionExpression(s, changedTransition, reviewTransition, transitionReason)

    ' 優先2: 単独年度表現（例: 令和8年度 / R8 / 8年度）を行年度へ合わせる
    s = ReplaceSingleYearExpression(s, fiscalYear, changedSingle, reviewSingle, singleReason)

    wasCorrected = (changedTransition Or changedSingle)
    needsReview = (reviewTransition Or reviewSingle)

    If needsReview Then
        reason = ""
        If Len(transitionReason) > 0 Then reason = transitionReason
        If Len(singleReason) > 0 Then
            If Len(reason) > 0 Then reason = reason & ", "
            reason = reason & singleReason
        End If
    End If

    NormalizeAnnualFolderName = s

End Function

Private Function ShiftYearTransitionExpression( _
    ByVal s As String, _
    ByRef changed As Boolean, _
    ByRef needsReview As Boolean, _
    Optional ByRef reason As String = "") As String

    Dim re As Object
    Dim matches As Object
    Dim m As Object
    Dim idx As Long
    Dim leftNum As Long
    Dim rightNum As Long
    Dim leftEra As String
    Dim rightEra As String
    Dim leftSuffix As String
    Dim rightSuffix As String
    Dim replacement As String
    Dim outText As String

    outText = s
    Set re = CreateObject("VBScript.RegExp")
    re.Global = True
    re.IgnoreCase = True
    re.Pattern = "(令和|[Rr])?\s*(\d{1,2})\s*(年度|年)?\s*→\s*(令和|[Rr])?\s*(\d{1,2})\s*(年度|年)?"

    Set matches = re.Execute(outText)
    If matches.Count = 0 Then
        ShiftYearTransitionExpression = outText
        Exit Function
    End If

    For idx = matches.Count - 1 To 0 Step -1
        Set m = matches(idx)
        leftEra = NzString(m.SubMatches(0))
        leftNum = CLng(m.SubMatches(1))
        leftSuffix = NzString(m.SubMatches(2))
        rightEra = NzString(m.SubMatches(3))
        rightNum = CLng(m.SubMatches(4))
        rightSuffix = NzString(m.SubMatches(5))

        If rightNum <> leftNum + 1 Then
            needsReview = True
            reason = "遷移年が連番ではない"
            GoTo ContinueNextMatch
        End If

        replacement = BuildYearToken(leftEra, leftNum + 1, leftSuffix) & "→" & _
                      BuildYearToken(rightEra, rightNum + 1, rightSuffix)
        outText = Left$(outText, m.FirstIndex) & replacement & Mid$(outText, m.FirstIndex + m.Length + 1)
        changed = True

ContinueNextMatch:
    Next idx

    ShiftYearTransitionExpression = outText

End Function

Private Function ReplaceSingleYearExpression( _
    ByVal s As String, _
    ByVal fiscalYear As String, _
    ByRef changed As Boolean, _
    ByRef needsReview As Boolean, _
    Optional ByRef reason As String = "") As String

    Dim targetYear As Long
    Dim tokenCount As Long
    Dim outText As String
    Dim tokenStart As Long
    Dim tokenLength As Long
    Dim tokenStyle As String
    Dim replacement As String

    outText = s
    targetYear = ParseReiwaYearNumber(fiscalYear)
    If targetYear <= 0 Then
        If Len(outText) > 0 Then
            needsReview = True
            reason = "行の年度を解釈できない"
        End If
        ReplaceSingleYearExpression = outText
        Exit Function
    End If

    ' 矢印遷移は優先1で処理済みのため、単独補正では触らない
    If InStr(outText, "→") > 0 Then
        ReplaceSingleYearExpression = outText
        Exit Function
    End If

    tokenCount = FindSingleYearCandidate(outText, tokenStart, tokenLength, tokenStyle)
    If tokenCount = 0 Then
        ReplaceSingleYearExpression = outText
        Exit Function
    End If

    If tokenCount > 1 Then
        needsReview = True
        reason = "単独年度候補が複数ある"
        ' 曖昧なため、単独補正は適用せず元文字列を返す
        ReplaceSingleYearExpression = s
        Exit Function
    End If

    replacement = BuildSingleYearReplacement(tokenStyle, targetYear)
    outText = Left$(outText, tokenStart - 1) & replacement & Mid$(outText, tokenStart + tokenLength)
    changed = (outText <> s)
    ReplaceSingleYearExpression = outText

End Function

Private Function FindSingleYearCandidate( _
    ByVal s As String, _
    ByRef tokenStart As Long, _
    ByRef tokenLength As Long, _
    ByRef tokenStyle As String) As Long

    Dim re As Object
    Dim matches As Object
    Dim m As Object
    Dim i As Long
    Dim candidateCount As Long
    Dim firstStart As Long
    Dim beforeChar As String
    Dim mStart As Long
    Dim mLength As Long

    tokenStart = 0
    tokenLength = 0
    tokenStyle = ""
    firstStart = 0

    Set re = CreateObject("VBScript.RegExp")
    re.Global = True
    re.IgnoreCase = True

    ' 1) 令和N年度
    re.Pattern = "令和\s*\d{1,2}\s*年度"
    Set matches = re.Execute(s)
    For i = 0 To matches.Count - 1
        Set m = matches(i)
        mStart = m.FirstIndex + 1
        mLength = m.Length
        candidateCount = candidateCount + 1
        If firstStart = 0 Or mStart < firstStart Then
            firstStart = mStart
            tokenStart = mStart
            tokenLength = mLength
            tokenStyle = "REIWA"
        End If
    Next i

    ' 2) RN
    re.Pattern = "\b[Rr]\s*\d{1,2}\b"
    Set matches = re.Execute(s)
    For i = 0 To matches.Count - 1
        Set m = matches(i)
        mStart = m.FirstIndex + 1
        mLength = m.Length
        candidateCount = candidateCount + 1
        If firstStart = 0 Or mStart < firstStart Then
            firstStart = mStart
            tokenStart = mStart
            tokenLength = mLength
            tokenStyle = "R"
        End If
    Next i

    ' 3) N年度（ただし令和N年度 / RN年度 の一部は除外）
    re.Pattern = "\d{1,2}\s*年度"
    Set matches = re.Execute(s)
    For i = 0 To matches.Count - 1
        Set m = matches(i)
        mStart = m.FirstIndex + 1
        mLength = m.Length

        If mStart > 1 Then
            beforeChar = Mid$(s, mStart - 1, 1)
        Else
            beforeChar = ""
        End If

        If beforeChar = "和" Or UCase$(beforeChar) = "R" Then
            ' 令和N年度 / RN年度 の重複検出は除外
        Else
            candidateCount = candidateCount + 1
            If firstStart = 0 Or mStart < firstStart Then
                firstStart = mStart
                tokenStart = mStart
                tokenLength = mLength
                tokenStyle = "NENDO"
            End If
        End If
    Next i

    FindSingleYearCandidate = candidateCount

End Function

Private Function BuildSingleYearReplacement(ByVal tokenStyle As String, ByVal targetYear As Long) As String

    Select Case UCase$(tokenStyle)
        Case "REIWA"
            BuildSingleYearReplacement = "令和" & CStr(targetYear) & "年度"
        Case "R"
            BuildSingleYearReplacement = "R" & CStr(targetYear)
        Case Else
            BuildSingleYearReplacement = CStr(targetYear) & "年度"
    End Select

End Function

Private Function BuildYearToken(ByVal eraText As String, ByVal y As Long, ByVal suffixText As String) As String

    Dim normalizedEra As String

    normalizedEra = Trim$(eraText)
    If normalizedEra = "" Then
        BuildYearToken = CStr(y) & suffixText
    ElseIf UCase$(normalizedEra) = "R" Then
        BuildYearToken = "R" & CStr(y) & suffixText
    ElseIf normalizedEra = "令和" Then
        BuildYearToken = "令和" & CStr(y) & suffixText
    Else
        BuildYearToken = normalizedEra & CStr(y) & suffixText
    End If

End Function

Private Function ParseReiwaYearNumber(ByVal fiscalYear As String) As Long

    Dim s As String
    Dim re As Object
    Dim matches As Object

    s = NormalizeBasicText(fiscalYear)
    If Len(s) = 0 Then Exit Function

    Set re = CreateObject("VBScript.RegExp")
    re.Global = False
    re.IgnoreCase = True
    re.Pattern = "(令和|[Rr])\s*(\d{1,2})"
    Set matches = re.Execute(s)
    If matches.Count > 0 Then
        ParseReiwaYearNumber = CLng(matches(0).SubMatches(1))
        Exit Function
    End If

    re.Pattern = "^(\d{1,2})$"
    Set matches = re.Execute(s)
    If matches.Count > 0 Then ParseReiwaYearNumber = CLng(matches(0).SubMatches(0))

End Function

Private Sub NormalizeHeaderLineBreaks(ByVal ws As Worksheet)

    Dim lastCol As Long
    Dim c As Range

    On Error GoTo SafeExit

    lastCol = GetLastUsedCol(ws)
    If lastCol <= 0 Then Exit Sub

    For Each c In ws.Range(ws.Cells(1, 1), ws.Cells(1, lastCol))
        If Not IsEmpty(c.value) Then
            c.value = Replace(CStr(c.value), vbCrLf, "")
            c.value = Replace(CStr(c.value), vbCr, "")
            c.value = Replace(CStr(c.value), vbLf, "")
        End If
    Next c

SafeExit:
    ' 改行除去は補助処理のため、失敗しても取込本体を止めない

End Sub

'========================================================
' 高速化対応: 対象年度行を連続ブロック単位で一括削除
'========================================================
Private Function DeleteRowsByFiscalYearBulk( _
    ByVal ws As Worksheet, _
    ByVal startRow As Long, _
    ByVal endRow As Long, _
    ByVal fiscalYearCol As Long, _
    ByVal targetFiscalYear As String) As Long

    Dim rowNo As Long
    Dim inBlock As Boolean
    Dim blockStart As Long
    Dim blockEnd As Long

    If ws Is Nothing Then Exit Function
    If endRow < startRow Then Exit Function

    For rowNo = endRow To startRow Step -1
        If GetTrimmedCell(ws, rowNo, fiscalYearCol) = targetFiscalYear Then
            If Not inBlock Then
                inBlock = True
                blockEnd = rowNo
                blockStart = rowNo
            Else
                blockStart = rowNo
            End If
        ElseIf inBlock Then
            ws.Rows(blockStart & ":" & blockEnd).Delete
            DeleteRowsByFiscalYearBulk = DeleteRowsByFiscalYearBulk + (blockEnd - blockStart + 1)
            inBlock = False
        End If
    Next rowNo

    If inBlock Then
        ws.Rows(blockStart & ":" & blockEnd).Delete
        DeleteRowsByFiscalYearBulk = DeleteRowsByFiscalYearBulk + (blockEnd - blockStart + 1)
    End If

End Function

Public Sub 手順5_差分インポートCSVを外部出力する()

    Dim wsOut As Worksheet
    Dim wbExport As Workbook
    Dim wsExport As Worksheet
    Dim usedRng As Range
    Dim savePath As Variant
    Dim finalPath As String
    Dim defaultFileName As String
    Dim oldDisplayAlerts As Boolean
    Dim srcCol As Long
    Dim dstCol As Long
    Dim absCol As Long
    Dim headerName As String
    Dim lastRow As Long

    On Error GoTo ErrorHandler

    On Error Resume Next
    Set wsOut = ThisWorkbook.Worksheets(SHEET_DIFF_IMPORT)
    On Error GoTo ErrorHandler

    If wsOut Is Nothing Then
        MsgBox "「差分インポートCSV」シートが見つかりません。", vbExclamation
        Exit Sub
    End If

    If Application.WorksheetFunction.CountA(wsOut.UsedRange) = 0 Then
        MsgBox "「差分インポートCSV」シートに出力対象データがありません。", vbInformation
        Exit Sub
    End If

    defaultFileName = "差分インポートCSV_" & Format(Now, "yyyymmdd_hhnnss") & ".csv"
    savePath = Application.GetSaveAsFilename( _
        InitialFileName:=defaultFileName, _
        FileFilter:="CSV UTF-8 (*.csv),*.csv,CSV (Comma delimited) (*.csv),*.csv", _
        Title:="差分インポートCSV の保存先を選択してください")

    If VarType(savePath) = vbBoolean Then
        If savePath = False Then Exit Sub
    End If

    finalPath = EnsureCsvExtension(CStr(savePath))

    Set wbExport = Workbooks.Add(xlWBATWorksheet)
    Set wsExport = wbExport.Worksheets(1)
    Set usedRng = wsOut.UsedRange

    lastRow = usedRng.Rows.Count
    dstCol = 1

    ' ヘッダー名ベースで「通し番号」列を除外してCSV出力する（シート上の列は保持）
    For srcCol = 1 To usedRng.Columns.Count
        absCol = usedRng.Column + srcCol - 1
        headerName = Trim$(CStr(wsOut.Cells(1, absCol).Value))

        If headerName <> "通し番号" Then
            wsExport.Cells(1, dstCol).Resize(lastRow, 1).Value = _
                wsOut.Cells(usedRng.Row, absCol).Resize(lastRow, 1).Value
            dstCol = dstCol + 1
        End If
    Next srcCol

    If dstCol = 1 Then
        Err.Raise vbObjectError + 2401, , "出力対象列がありません（すべて「通し番号」列の可能性があります）。"
    End If

    oldDisplayAlerts = Application.DisplayAlerts
    Application.DisplayAlerts = False

    On Error Resume Next
    wbExport.SaveAs Filename:=finalPath, FileFormat:=62, Local:=True ' xlCSVUTF8
    If Err.Number <> 0 Then
        Err.Clear
        wbExport.SaveAs Filename:=finalPath, FileFormat:=xlCSV, Local:=True
    End If
    On Error GoTo ErrorHandler

    wbExport.Close SaveChanges:=False
    Application.DisplayAlerts = oldDisplayAlerts

    MsgBox "差分インポートCSV を外部出力しました。" & vbCrLf & _
           finalPath, vbInformation
    Exit Sub

ErrorHandler:
    On Error Resume Next
    If Not wbExport Is Nothing Then wbExport.Close SaveChanges:=False
    Application.DisplayAlerts = oldDisplayAlerts
    On Error GoTo 0
    MsgBox "差分インポートCSV の外部出力中にエラーが発生しました: " & Err.Description, vbExclamation

End Sub

Private Function EnsureCsvExtension(ByVal path As String) As String

    If LCase$(Right$(Trim$(path), 4)) <> ".csv" Then
        EnsureCsvExtension = Trim$(path) & ".csv"
    Else
        EnsureCsvExtension = Trim$(path)
    End If

End Function

