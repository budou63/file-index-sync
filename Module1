Public Sub 新ファイル基準表_表示名からID自動補完(ByVal Target As Range)

    Dim wsEdit As Worksheet
    Dim lastCol As Long
    Dim pairDefs As Variant
    Dim i As Long
    Dim displayCol As Long
    Dim idCol As Long
    Dim watchRange As Range
    Dim workRange As Range
    Dim changedCell As Range
    Dim inputName As String
    Dim codeValue As String
    Dim warekiCol As Long
    Dim seirekiCol As Long
    Dim westernYear As String

    If Target Is Nothing Then Exit Sub
    If Target.CountLarge > 1000 Then Exit Sub

    On Error GoTo ExitHandler
    Application.EnableEvents = False

    Set wsEdit = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    If Target.Worksheet.name <> wsEdit.name Then GoTo ExitHandler

    lastCol = GetLastUsedCol(wsEdit)
    If lastCol <= 0 Then GoTo ExitHandler

    ' 表示列ヘッダー / ID列ヘッダー / コード管理CSV上の項目名
    pairDefs = Array( _
        Array("原課", "原課ID", "原課"), _
        Array("保存期間", "保存期間ID", "保存期間"), _
        Array("分類名１", "分類コード１", "分類名１"), _
        Array("分類名２", "分類コード２", "分類名２"), _
        Array("分類名３", "分類コード３", "分類名３"), _
        Array("媒体種別", "媒体種別ID", "媒体種別") _
    )

    ' 追加機能: 年度（和暦）→ 年度（西暦）自動反映
    warekiCol = GetHeaderColumnExact(wsEdit, "年度（和暦）")
    seirekiCol = GetHeaderColumnExact(wsEdit, "年度")

    ' 対象表示列だけを監視対象にする（見出し未存在はスキップ）
    For i = LBound(pairDefs) To UBound(pairDefs)
        displayCol = GetHeaderColumnExact(wsEdit, CStr(pairDefs(i)(0)))
        If displayCol > 0 Then
            Set workRange = wsEdit.Range(wsEdit.Cells(2, displayCol), wsEdit.Cells(wsEdit.Rows.Count, displayCol))
            If watchRange Is Nothing Then
                Set watchRange = workRange
            Else
                Set watchRange = Union(watchRange, workRange)
            End If
        End If
    Next i

    ' 追加機能: 「年度（和暦）」列も変更監視対象に含める
    If warekiCol > 0 Then
        Set workRange = wsEdit.Range(wsEdit.Cells(2, warekiCol), wsEdit.Cells(wsEdit.Rows.Count, warekiCol))
        If watchRange Is Nothing Then
            Set watchRange = workRange
        Else
            Set watchRange = Union(watchRange, workRange)
        End If
    End If

    If watchRange Is Nothing Then GoTo ExitHandler
    Set workRange = Intersect(Target, watchRange)
    If workRange Is Nothing Then GoTo ExitHandler

    ' 変更セルごとに表示列→ID列の補完を実施
    For Each changedCell In workRange.Cells
        '--------------------------------------------------------
        ' 追加機能: 年度（和暦）入力時に「年度」列へ西暦を反映
        '--------------------------------------------------------
        If warekiCol > 0 And seirekiCol > 0 Then
            If changedCell.Column = warekiCol Then
                westernYear = ConvertReiwaToWesternYear(CStr(changedCell.value))
                wsEdit.Cells(changedCell.row, seirekiCol).value = westernYear
                GoTo ContinueCellLoop
            End If
        End If

        For i = LBound(pairDefs) To UBound(pairDefs)
            displayCol = GetHeaderColumnExact(wsEdit, CStr(pairDefs(i)(0)))
            If displayCol = 0 Then GoTo ContinuePair
            If changedCell.Column <> displayCol Then GoTo ContinuePair

            idCol = GetHeaderColumnExact(wsEdit, CStr(pairDefs(i)(1)))
            If idCol = 0 Then Exit For ' ID見出しが無ければその項目はスキップ

            inputName = Trim(CStr(changedCell.value))
            If Len(inputName) = 0 Then
                wsEdit.Cells(changedCell.row, idCol).value = ""
            Else
                codeValue = GetCodeFromCodeMaster(CStr(pairDefs(i)(2)), inputName)
                If Len(codeValue) > 0 Then
                    wsEdit.Cells(changedCell.row, idCol).value = codeValue
                Else
                    wsEdit.Cells(changedCell.row, idCol).value = ""
                End If
            End If
            Exit For
ContinuePair:
        Next i
ContinueCellLoop:
    Next changedCell

    ' 同じ変更イベント内で、年度（和暦）/保存期間に応じた廃棄年月日を自動更新する。
    ' （Worksheet_Change 側の呼び出し漏れがあっても、この主処理経由で必ず反映されるようにする）
    Call 新ファイル基準表_廃棄年月日自動計算(Target)

ExitHandler:
    Application.EnableEvents = True

End Sub

'========================================================
' 新ファイル基準表: 年度（和暦）/保存期間 変更時に廃棄年月日を自動計算
' Worksheet_Change から呼び出す想定
'========================================================
Public Sub 新ファイル基準表_廃棄年月日自動計算(ByVal Target As Range)

    Dim wsEdit As Worksheet
    Dim warekiCol As Long
    Dim saveTermCol As Long
    Dim haikiCol As Long
    Dim monitorRange As Range
    Dim workRange As Range
    Dim changedCell As Range
    Dim rowMap As Object
    Dim key As Variant
    Dim rowNo As Long
    Dim warekiText As String
    Dim saveTermText As String
    Dim calcResult As String
    Dim prevEnableEvents As Boolean

    If Target Is Nothing Then Exit Sub

    On Error GoTo SafeExit
    prevEnableEvents = Application.EnableEvents

    Set wsEdit = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    If wsEdit Is Nothing Then Exit Sub
    If Target.Worksheet.Name <> wsEdit.Name Then Exit Sub

    warekiCol = FindHeaderColumn(wsEdit, GetLastUsedCol(wsEdit), GetStep2HeaderCandidates("年度（和暦）"))
    saveTermCol = FindHeaderColumn(wsEdit, GetLastUsedCol(wsEdit), GetStep2HeaderCandidates("保存期間"))
    haikiCol = FindHeaderColumn(wsEdit, GetLastUsedCol(wsEdit), Array("廃棄年月日"))

    If warekiCol <= 0 Or saveTermCol <= 0 Or haikiCol <= 0 Then Exit Sub

    ' 監視対象（年度（和暦）列 / 保存期間列）のみを処理
    Set monitorRange = Union( _
        wsEdit.Range(wsEdit.Cells(2, warekiCol), wsEdit.Cells(wsEdit.Rows.Count, warekiCol)), _
        wsEdit.Range(wsEdit.Cells(2, saveTermCol), wsEdit.Cells(wsEdit.Rows.Count, saveTermCol)))
    Set workRange = Intersect(Target, monitorRange)
    If workRange Is Nothing Then Exit Sub

    Set rowMap = CreateObject("Scripting.Dictionary")
    For Each changedCell In workRange.Cells
        If Not rowMap.Exists(CStr(changedCell.Row)) Then
            rowMap.Add CStr(changedCell.Row), CLng(changedCell.Row)
        End If
    Next changedCell

    Application.EnableEvents = False

    For Each key In rowMap.Keys
        rowNo = CLng(rowMap(CStr(key)))
        warekiText = CStr(wsEdit.Cells(rowNo, warekiCol).Value)
        saveTermText = CStr(wsEdit.Cells(rowNo, saveTermCol).Value)

        calcResult = CalculateHaikiDateText(warekiText, saveTermText)
        wsEdit.Cells(rowNo, haikiCol).Value = calcResult
    Next key

SafeExit:
    Application.EnableEvents = prevEnableEvents

End Sub

'--------------------------------------------------------
' 廃棄年月日（R8.4.1 のような文字列）を計算して返す
' 返却条件:
' - 年度（和暦）/保存期間のいずれか空欄: 空文字
' - 保存期間が継続/永年: 空文字
' - 保存期間が随時: 年度末（翌年 3/31）
' - 変換不能: 空文字
'--------------------------------------------------------
Private Function CalculateHaikiDateText(ByVal warekiText As String, ByVal saveTermText As String) As String

    Dim eraName As String
    Dim eraYear As Long
    Dim startWesternYear As Long
    Dim saveYears As Long
    Dim isPermanent As Boolean
    Dim isZuiji As Boolean
    Dim haikiWesternYear As Long
    Dim haikiWarekiLabel As String

    CalculateHaikiDateText = ""

    If Len(NormalizeBasicText(warekiText)) = 0 Then Exit Function
    If Len(NormalizeBasicText(saveTermText)) = 0 Then Exit Function

    If Not ParseWarekiYear(warekiText, eraName, eraYear, startWesternYear) Then Exit Function
    saveYears = GetSaveTermYears(saveTermText, isPermanent, isZuiji)

    ' 継続/永年 は空欄
    If isPermanent Then Exit Function

    ' 随時 は当該年度末（翌年 3/31）
    If isZuiji Then
        haikiWesternYear = startWesternYear + 1
        haikiWarekiLabel = WesternYearToWarekiLabel(haikiWesternYear)
        If Len(haikiWarekiLabel) = 0 Then Exit Function
        CalculateHaikiDateText = haikiWarekiLabel & ".3.31"
        Exit Function
    End If

    If saveYears <= 0 Then Exit Function

    ' ルール: 廃棄年度 = 元年度 + 保存期間年数 + 1（次年度初日 4/1）
    haikiWesternYear = startWesternYear + saveYears + 1
    haikiWarekiLabel = WesternYearToWarekiLabel(haikiWesternYear)
    If Len(haikiWarekiLabel) = 0 Then Exit Function

    CalculateHaikiDateText = haikiWarekiLabel & ".4.1"

End Function

'--------------------------------------------------------
' 年度（和暦）文字列を解析し、元号・年数・西暦開始年を返す
' 対応入力例:
' - 6 / 06 / R6 / r6 / R06 / 令和6 / 令和6年度
' - H27 / h27 / H27年度 / 平成27 / 平成27年度
' 数字のみは令和として解釈
'--------------------------------------------------------
Private Function ParseWarekiYear( _
    ByVal warekiText As String, _
    ByRef eraName As String, _
    ByRef eraYear As Long, _
    ByRef westernYear As Long) As Boolean

    Dim s As String
    Dim numberPart As String
    Dim leading As String

    ParseWarekiYear = False
    eraName = ""
    eraYear = 0
    westernYear = 0

    s = NormalizeBasicText(warekiText)
    If Len(s) = 0 Then Exit Function

    s = Replace(s, "年度", "")

    If Left$(s, 2) = "令和" Then
        eraName = "R"
        numberPart = Mid$(s, 3)
    ElseIf Left$(s, 2) = "平成" Then
        eraName = "H"
        numberPart = Mid$(s, 3)
    Else
        leading = UCase$(Left$(s, 1))
        If leading = "R" Or leading = "H" Then
            eraName = leading
            numberPart = Mid$(s, 2)
        ElseIf IsDigitsOnly(s) Then
            ' 数字のみ入力は令和として解釈
            eraName = "R"
            numberPart = s
        Else
            Exit Function
        End If
    End If

    numberPart = ExtractDigits(numberPart)
    If Len(numberPart) = 0 Then Exit Function

    eraYear = CLng(numberPart)
    If eraYear <= 0 Then Exit Function

    Select Case eraName
        Case "R"
            westernYear = 2018 + eraYear
        Case "H"
            westernYear = 1988 + eraYear
        Case Else
            Exit Function
    End Select

    ParseWarekiYear = True

End Function

'--------------------------------------------------------
' 西暦開始年を和暦ラベル（R8 / H27）へ変換する
'--------------------------------------------------------
Private Function WesternYearToWarekiLabel(ByVal westernYear As Long) As String

    If westernYear >= 2019 Then
        WesternYearToWarekiLabel = "R" & CStr(westernYear - 2018)
    ElseIf westernYear >= 1989 And westernYear <= 2018 Then
        WesternYearToWarekiLabel = "H" & CStr(westernYear - 1988)
    Else
        WesternYearToWarekiLabel = ""
    End If

End Function

'--------------------------------------------------------
' 保存期間表記を年数へ変換する
' 戻り値:
' - 1/3/5/10 -> 年数
' - 継続/永年 -> 0（isPermanent=True）
' - 随時 -> 0（isZuiji=True）
' - 変換不能 -> -1
'--------------------------------------------------------
Private Function GetSaveTermYears( _
    ByVal saveTermText As String, _
    ByRef isPermanent As Boolean, _
    ByRef isZuiji As Boolean) As Long

    Dim s As String
    Dim digits As String
    Dim yearsValue As Long

    isPermanent = False
    isZuiji = False
    GetSaveTermYears = -1

    s = NormalizeBasicText(saveTermText)
    If Len(s) = 0 Then
        GetSaveTermYears = 0
        Exit Function
    End If

    If InStr(1, s, "継続", vbTextCompare) > 0 Or InStr(1, s, "永年", vbTextCompare) > 0 Then
        isPermanent = True
        GetSaveTermYears = 0
        Exit Function
    End If

    If InStr(1, s, "随時", vbTextCompare) > 0 Then
        isZuiji = True
        GetSaveTermYears = 0
        Exit Function
    End If

    s = Replace(s, "年", "")
    s = Replace(s, "度", "")
    digits = ExtractDigits(s)
    If Len(digits) = 0 Then Exit Function

    yearsValue = CLng(digits)
    Select Case yearsValue
        Case 1, 3, 5, 10
            GetSaveTermYears = yearsValue
        Case Else
            GetSaveTermYears = -1
    End Select

End Function

'--------------------------------------------------------
' 共通: 前後空白・全角空白を除去し、全角英数字を半角へ正規化
'--------------------------------------------------------
Private Function NormalizeBasicText(ByVal textValue As String) As String

    Dim s As String

    s = CStr(textValue)
    s = Trim$(s)
    s = Replace(s, " ", "")
    s = Replace(s, "　", "")
    s = ToHalfWidthAlphaNumeric(s)
    NormalizeBasicText = s

End Function

Private Function ToHalfWidthAlphaNumeric(ByVal s As String) As String

    Dim i As Long
    Dim zenkakuDigits As String
    Dim hankakuDigits As String
    Dim zenkakuUpper As String
    Dim hankakuUpper As String
    Dim zenkakuLower As String
    Dim hankakuLower As String

    zenkakuDigits = "０１２３４５６７８９"
    hankakuDigits = "0123456789"
    zenkakuUpper = "ＲＨ"
    hankakuUpper = "RH"
    zenkakuLower = "ｒｈ"
    hankakuLower = "rh"

    For i = 1 To Len(zenkakuDigits)
        s = Replace(s, Mid$(zenkakuDigits, i, 1), Mid$(hankakuDigits, i, 1))
    Next i

    For i = 1 To Len(zenkakuUpper)
        s = Replace(s, Mid$(zenkakuUpper, i, 1), Mid$(hankakuUpper, i, 1))
    Next i

    For i = 1 To Len(zenkakuLower)
        s = Replace(s, Mid$(zenkakuLower, i, 1), Mid$(hankakuLower, i, 1))
    Next i

    ToHalfWidthAlphaNumeric = s

End Function

Private Function ExtractDigits(ByVal s As String) As String

    Dim i As Long
    Dim ch As String
    Dim resultText As String

    s = ToHalfWidthAlphaNumeric(s)

    For i = 1 To Len(s)
        ch = Mid$(s, i, 1)
        If ch Like "#" Then resultText = resultText & ch
    Next i

    ExtractDigits = resultText

End Function

Private Function IsDigitsOnly(ByVal s As String) As Boolean

    Dim i As Long
    Dim ch As String

    s = ToHalfWidthAlphaNumeric(s)
    If Len(s) = 0 Then Exit Function

    For i = 1 To Len(s)
        ch = Mid$(s, i, 1)
        If Not (ch Like "#") Then
            IsDigitsOnly = False
            Exit Function
        End If
    Next i

    IsDigitsOnly = True

End Function

