'--------------------------------------------------------
' 廃棄年月日（R8.4.1 のような文字列）を計算して返す
' 返却条件:
' - 年度（和暦）/保存期間のいずれか空欄: 空文字
' - 保存期間が継続/永年: 空文字
' - 保存期間が随時: 年度末（翌年 3/31）
' - 変換不能: 空文字
'--------------------------------------------------------
Private Function CalculateHaikiDateText(ByVal warekiText As String, ByVal saveTermText As String) As String

    Dim eraName As String
    Dim eraYear As Long
    Dim startWesternYear As Long
    Dim saveYears As Long
    Dim isPermanent As Boolean
    Dim isZuiji As Boolean
    Dim haikiWesternYear As Long
    Dim haikiWarekiLabel As String

    CalculateHaikiDateText = ""

    If Len(NormalizeBasicText(warekiText)) = 0 Then Exit Function
    If Len(NormalizeBasicText(saveTermText)) = 0 Then Exit Function

    If Not ParseWarekiYear(warekiText, eraName, eraYear, startWesternYear) Then Exit Function
    saveYears = GetSaveTermYears(saveTermText, isPermanent, isZuiji)

    ' 継続/永年 は空欄
    If isPermanent Then Exit Function

    ' 随時 は当該年度末（翌年 3/31）
    If isZuiji Then
        haikiWesternYear = startWesternYear + 1
        haikiWarekiLabel = WesternYearToWarekiLabel(haikiWesternYear)
        If Len(haikiWarekiLabel) = 0 Then Exit Function
        CalculateHaikiDateText = haikiWarekiLabel & ".3.31"
        Exit Function
    End If

    If saveYears <= 0 Then Exit Function

    ' ルール: 廃棄年度 = 元年度 + 保存期間年数 + 1（次年度初日 4/1）
    haikiWesternYear = startWesternYear + saveYears + 1
    haikiWarekiLabel = WesternYearToWarekiLabel(haikiWesternYear)
    If Len(haikiWarekiLabel) = 0 Then Exit Function

    CalculateHaikiDateText = haikiWarekiLabel & ".4.1"

End Function

'--------------------------------------------------------
' 年度（和暦）文字列を解析し、元号・年数・西暦開始年を返す
' 対応入力例:
' - 6 / 06 / R6 / r6 / R06 / 令和6 / 令和6年度
' - H27 / h27 / H27年度 / 平成27 / 平成27年度
' 数字のみは令和として解釈
'--------------------------------------------------------
Private Function ParseWarekiYear( _
    ByVal warekiText As String, _
    ByRef eraName As String, _
    ByRef eraYear As Long, _
    ByRef westernYear As Long) As Boolean

    Dim s As String
    Dim numberPart As String
    Dim leading As String

    ParseWarekiYear = False
    eraName = ""
    eraYear = 0
    westernYear = 0

    s = NormalizeBasicText(warekiText)
    If Len(s) = 0 Then Exit Function

    s = Replace(s, "年度", "")

    If Left$(s, 2) = "令和" Then
        eraName = "R"
        numberPart = Mid$(s, 3)
    ElseIf Left$(s, 2) = "平成" Then
        eraName = "H"
        numberPart = Mid$(s, 3)
    Else
        leading = UCase$(Left$(s, 1))
        If leading = "R" Or leading = "H" Then
            eraName = leading
            numberPart = Mid$(s, 2)
        ElseIf IsDigitsOnly(s) Then
            ' 数字のみ入力は令和として解釈
            eraName = "R"
            numberPart = s
        Else
            Exit Function
        End If
    End If

    numberPart = ExtractDigits(numberPart)
    If Len(numberPart) = 0 Then Exit Function

    eraYear = CLng(numberPart)
    If eraYear <= 0 Then Exit Function

    Select Case eraName
        Case "R"
            westernYear = 2018 + eraYear
        Case "H"
            westernYear = 1988 + eraYear
        Case Else
            Exit Function
    End Select

    ParseWarekiYear = True

End Function

'--------------------------------------------------------
' 西暦開始年を和暦ラベル（R8 / H27）へ変換する
'--------------------------------------------------------
Private Function WesternYearToWarekiLabel(ByVal westernYear As Long) As String

    If westernYear >= 2019 Then
        WesternYearToWarekiLabel = "R" & CStr(westernYear - 2018)
    ElseIf westernYear >= 1989 And westernYear <= 2018 Then
        WesternYearToWarekiLabel = "H" & CStr(westernYear - 1988)
    Else
        WesternYearToWarekiLabel = ""
    End If

End Function

'--------------------------------------------------------
' 保存期間表記を年数へ変換する
' 戻り値:
' - 1/3/5/10 -> 年数
' - 継続/永年 -> 0（isPermanent=True）
' - 随時 -> 0（isZuiji=True）
' - 変換不能 -> -1
'--------------------------------------------------------
Private Function GetSaveTermYears( _
    ByVal saveTermText As String, _
    ByRef isPermanent As Boolean, _
    ByRef isZuiji As Boolean) As Long

    Dim s As String
    Dim digits As String
    Dim yearsValue As Long

    isPermanent = False
    isZuiji = False
    GetSaveTermYears = -1

    s = NormalizeBasicText(saveTermText)
    If Len(s) = 0 Then
        GetSaveTermYears = 0
        Exit Function
    End If

    If InStr(1, s, "継続", vbTextCompare) > 0 Or InStr(1, s, "永年", vbTextCompare) > 0 Then
        isPermanent = True
        GetSaveTermYears = 0
        Exit Function
    End If

    If InStr(1, s, "随時", vbTextCompare) > 0 Then
        isZuiji = True
        GetSaveTermYears = 0
        Exit Function
    End If

    s = Replace(s, "年", "")
    s = Replace(s, "度", "")
    digits = ExtractDigits(s)
    If Len(digits) = 0 Then Exit Function

    yearsValue = CLng(digits)
    Select Case yearsValue
        Case 1, 3, 5, 10
            GetSaveTermYears = yearsValue
        Case Else
            GetSaveTermYears = -1
    End Select

End Function

'--------------------------------------------------------
' 共通: 前後空白・全角空白を除去し、全角英数字を半角へ正規化
'--------------------------------------------------------
Private Function NormalizeBasicText(ByVal textValue As String) As String

    Dim s As String

    s = CStr(textValue)
    s = Trim$(s)
    s = Replace(s, " ", "")
    s = Replace(s, "　", "")
    s = ToHalfWidthAlphaNumeric(s)
    NormalizeBasicText = s

End Function

Private Function ToHalfWidthAlphaNumeric(ByVal s As String) As String

    Dim i As Long
    Dim zenkakuDigits As String
    Dim hankakuDigits As String
    Dim zenkakuUpper As String
    Dim hankakuUpper As String
    Dim zenkakuLower As String
    Dim hankakuLower As String

    zenkakuDigits = "０１２３４５６７８９"
    hankakuDigits = "0123456789"
    zenkakuUpper = "ＲＨ"
    hankakuUpper = "RH"
    zenkakuLower = "ｒｈ"
    hankakuLower = "rh"

    For i = 1 To Len(zenkakuDigits)
        s = Replace(s, Mid$(zenkakuDigits, i, 1), Mid$(hankakuDigits, i, 1))
    Next i

    For i = 1 To Len(zenkakuUpper)
        s = Replace(s, Mid$(zenkakuUpper, i, 1), Mid$(hankakuUpper, i, 1))
    Next i

    For i = 1 To Len(zenkakuLower)
        s = Replace(s, Mid$(zenkakuLower, i, 1), Mid$(hankakuLower, i, 1))
    Next i

    ToHalfWidthAlphaNumeric = s

End Function

Private Function ExtractDigits(ByVal s As String) As String

    Dim i As Long
    Dim ch As String
    Dim resultText As String

    s = ToHalfWidthAlphaNumeric(s)

    For i = 1 To Len(s)
        ch = Mid$(s, i, 1)
        If ch Like "#" Then resultText = resultText & ch
    Next i

    ExtractDigits = resultText

End Function

Private Function IsDigitsOnly(ByVal s As String) As Boolean

    Dim i As Long
    Dim ch As String

    s = ToHalfWidthAlphaNumeric(s)
    If Len(s) = 0 Then Exit Function

    For i = 1 To Len(s)
        ch = Mid$(s, i, 1)
        If Not (ch Like "#") Then
            IsDigitsOnly = False
            Exit Function
        End If
    Next i

    IsDigitsOnly = True

End Function

