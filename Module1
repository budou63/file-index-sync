Private Function RecalculateHaikiDateAllRows_NewFileStandard(ByVal wsEdit As Worksheet) As Long

    Dim rowMap As Object
    Dim lastRow As Long
    Dim rowNo As Long

    If wsEdit Is Nothing Then
        Set wsEdit = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    End If

    lastRow = GetLastUsedRow(wsEdit)
    If lastRow < 2 Then Exit Function

    Set rowMap = CreateObject("Scripting.Dictionary")
    For rowNo = 2 To lastRow
        rowMap.Add CStr(rowNo), rowNo
    Next rowNo

    RecalculateHaikiDateAllRows_NewFileStandard = RecalculateHaikiDateByRowMap(wsEdit, rowMap)

End Function

Private Function RecalculateHaikiDateByRowMap(ByVal wsEdit As Worksheet, ByVal rowMap As Object) As Long

    Dim warekiCol As Long
    Dim saveTermCol As Long
    Dim haikiCol As Long
    Dim key As Variant
    Dim rowNo As Long
    Dim warekiText As String
    Dim saveTermText As String
    Dim calcResult As String
    Dim prevEnableEvents As Boolean
    Dim prevScreenUpdating As Boolean
    Dim prevCalculation As XlCalculation
    Dim errNo As Long
    Dim errDesc As String

    On Error GoTo ErrorHandler

    If wsEdit Is Nothing Then Exit Function
    If rowMap Is Nothing Then Exit Function
    If rowMap.Count = 0 Then Exit Function

    warekiCol = FindHeaderColumn(wsEdit, GetLastUsedCol(wsEdit), GetStep2HeaderCandidates("年度（和暦）"))
    saveTermCol = FindHeaderColumn(wsEdit, GetLastUsedCol(wsEdit), GetStep2HeaderCandidates("保存期間"))
    haikiCol = FindHeaderColumn(wsEdit, GetLastUsedCol(wsEdit), Array("廃棄年月日"))

    If warekiCol <= 0 Or saveTermCol <= 0 Or haikiCol <= 0 Then
        Err.Raise vbObjectError + 2121, , "年度（和暦）/保存期間/廃棄年月日 の見出しが見つかりません。"
    End If

    prevCalculation = Application.Calculation
    prevEnableEvents = Application.EnableEvents
    prevScreenUpdating = Application.ScreenUpdating
    Application.Calculation = xlCalculationManual
    Application.EnableEvents = False
    Application.ScreenUpdating = False

    For Each key In rowMap.Keys
        rowNo = CLng(rowMap(CStr(key)))
        warekiText = CStr(wsEdit.Cells(rowNo, warekiCol).Value)
        saveTermText = CStr(wsEdit.Cells(rowNo, saveTermCol).Value)

        calcResult = CalculateHaikiDateText(warekiText, saveTermText)
        wsEdit.Cells(rowNo, haikiCol).Value = calcResult
        RecalculateHaikiDateByRowMap = RecalculateHaikiDateByRowMap + 1
    Next key

SafeExit:
    Application.Calculation = prevCalculation
    Application.EnableEvents = prevEnableEvents
    Application.ScreenUpdating = prevScreenUpdating
    Exit Function

ErrorHandler:
    errNo = Err.Number
    errDesc = Err.Description
    RestoreAppState prevCalculation, prevEnableEvents, prevScreenUpdating
    Err.Raise errNo, "RecalculateHaikiDateByRowMap", errDesc

End Function

