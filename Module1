Private Function ResolveRowMoveUndoCurrentStartRow(ByVal ws As Worksheet, ByVal fallbackStart As Long, ByVal rowCount As Long) As Long

    Dim lastCol As Long
    Dim serialCol As Long
    Dim lastRow As Long
    Dim rowNo As Long
    Dim bestRow As Long
    Dim bestDistance As Long
    Dim distance As Long
    Dim currentSerial As String

    ResolveRowMoveUndoCurrentStartRow = fallbackStart
    If ws Is Nothing Then Exit Function
    If rowCount <> 1 Then Exit Function
    If Len(gRowMoveUndoMovedSerial) = 0 Then Exit Function

    lastCol = GetLastUsedCol(ws)
    If lastCol <= 0 Then Exit Function
    serialCol = FindHeaderColumn(ws, lastCol, GetStep2HeaderCandidates("通し番号"))
    If serialCol <= 0 Then Exit Function

    currentSerial = GetTrimmedCell(ws, fallbackStart, serialCol)
    If StrComp(currentSerial, gRowMoveUndoMovedSerial, vbTextCompare) = 0 Then Exit Function

    lastRow = GetLastUsedRow(ws)
    bestRow = 0
    bestDistance = 0
    For rowNo = 2 To lastRow
        If StrComp(GetTrimmedCell(ws, rowNo, serialCol), gRowMoveUndoMovedSerial, vbTextCompare) = 0 Then
            distance = Abs(rowNo - fallbackStart)
            If bestRow = 0 Or distance < bestDistance Then
                bestRow = rowNo
                bestDistance = distance
            End If
        End If
    Next rowNo

    If bestRow > 0 Then
        ResolveRowMoveUndoCurrentStartRow = bestRow
    End If

End Function

