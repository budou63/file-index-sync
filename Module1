Option Explicit

Private Const SHEET_MOKUROKU_CSV As String = "目録CSV"
Private Const SHEET_NEW_FILE_STANDARD As String = "新ファイル基準表"
Private Const SHEET_CODE_MANAGEMENT As String = "コード管理CSV"
Private Const SHEET_DIFF_IMPORT As String = "差分インポートCSV"

Public Sub 新ファイル基準表生成()

    Dim oldScreenUpdating As Boolean
    Dim oldEnableEvents As Boolean
    Dim oldDisplayAlerts As Boolean

    On Error GoTo ErrorHandler

    oldScreenUpdating = Application.ScreenUpdating
    oldEnableEvents = Application.EnableEvents
    oldDisplayAlerts = Application.DisplayAlerts

    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.DisplayAlerts = False

    Call CSV取込_シンプル版
    Call 手順2_新ファイル基準表を作成する
    Call 手順3_コード管理CSVを作成する

    MsgBox "完了しました"
    GoTo Cleanup

ErrorHandler:
    MsgBox "エラーが発生しました: " & Err.Description, vbExclamation

Cleanup:
    Application.ScreenUpdating = oldScreenUpdating
    Application.EnableEvents = oldEnableEvents
    Application.DisplayAlerts = oldDisplayAlerts

End Sub

Public Sub CSV取込_シンプル版()

    Dim ws As Worksheet
    Dim filePath As Variant
    Dim wbCSV As Workbook
    Dim wsCSV As Worksheet
    Dim dstLastRow As Long
    Dim dstLastCol As Long
    Dim srcLastRow As Long
    Dim srcLastCol As Long
    Dim appendRow As Long
    Dim srcRow As Long
    Dim appendedCount As Long
    Dim skippedDuplicateCount As Long
    Dim existingHasHeader As Boolean
    Dim srcFileIdCol As Long
    Dim srcFileNoCol As Long
    Dim srcBarcodeCol As Long
    Dim dstFileIdCol As Long
    Dim dstFileNoCol As Long
    Dim dstBarcodeCol As Long
    Dim fileIdVal As String
    Dim fileNoVal As String
    Dim barcodeVal As String
    Dim key As String
    Dim existingKeyMap As Object

    On Error GoTo ErrorHandler

    ' ファイル選択
    filePath = Application.GetOpenFilename("CSV Files (*.csv), *.csv")
    
    If filePath = False Then Exit Sub
    
    ' 目録CSVシート
    Set ws = ThisWorkbook.Worksheets("目録CSV")
    Set existingKeyMap = CreateObject("Scripting.Dictionary")
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' CSVを開く
    Set wbCSV = Workbooks.Open(filePath)
    Set wsCSV = wbCSV.Sheets(1)

    srcLastRow = GetLastUsedRow(wsCSV)
    srcLastCol = GetLastUsedCol(wsCSV)
    dstLastRow = GetLastUsedRow(ws)
    dstLastCol = GetLastUsedCol(ws)
    existingHasHeader = (dstLastRow >= 1 And dstLastCol > 0 And Len(Trim$(CStr(ws.Cells(1, 1).Value))) > 0)

    If srcLastCol <= 0 Then Err.Raise vbObjectError + 2101, , "選択したCSVの見出し行が見つかりません。"

    If Not existingHasHeader Then
        ' 初回取込: 見出し含めてA1から配置
        wsCSV.UsedRange.Copy ws.Range("A1")
        NormalizeHeaderLineBreaks ws
        appendedCount = Application.Max(srcLastRow - 1, 0)
    Else
        ' 追記取込: 既存見出しを維持し、CSVのデータ部(2行目以降)だけ追記
        NormalizeHeaderLineBreaks ws

        srcFileIdCol = FindHeaderColumn(wsCSV, srcLastCol, Array("ファイルID"))
        srcFileNoCol = FindHeaderColumn(wsCSV, srcLastCol, Array("ファイル番号"))
        srcBarcodeCol = FindHeaderColumn(wsCSV, srcLastCol, Array("バーコード番号"))
        dstFileIdCol = FindHeaderColumn(ws, dstLastCol, Array("ファイルID"))
        dstFileNoCol = FindHeaderColumn(ws, dstLastCol, Array("ファイル番号"))
        dstBarcodeCol = FindHeaderColumn(ws, dstLastCol, Array("バーコード番号"))

        If dstFileIdCol > 0 And dstFileNoCol > 0 And dstBarcodeCol > 0 Then
            For srcRow = 2 To dstLastRow
                fileIdVal = GetTrimmedCell(ws, srcRow, dstFileIdCol)
                fileNoVal = GetTrimmedCell(ws, srcRow, dstFileNoCol)
                barcodeVal = GetTrimmedCell(ws, srcRow, dstBarcodeCol)
                If Not (fileIdVal = "" And fileNoVal = "" And barcodeVal = "") Then
                    key = BuildFileKey(fileIdVal, fileNoVal, barcodeVal)
                    If Not existingKeyMap.Exists(key) Then existingKeyMap.Add key, True
                End If
            Next srcRow
        End If

        appendRow = dstLastRow + 1
        For srcRow = 2 To srcLastRow
            fileIdVal = GetTrimmedCell(wsCSV, srcRow, srcFileIdCol)
            fileNoVal = GetTrimmedCell(wsCSV, srcRow, srcFileNoCol)
            barcodeVal = GetTrimmedCell(wsCSV, srcRow, srcBarcodeCol)

            If fileIdVal = "" And fileNoVal = "" And barcodeVal = "" Then
                ' 重複判定不能行はそのまま追記
            Else
                key = BuildFileKey(fileIdVal, fileNoVal, barcodeVal)
                If existingKeyMap.Exists(key) Then
                    skippedDuplicateCount = skippedDuplicateCount + 1
                    GoTo ContinueNextCsvRow
                End If
            End If

            ws.Range(ws.Cells(appendRow, 1), ws.Cells(appendRow, srcLastCol)).Value = _
                wsCSV.Range(wsCSV.Cells(srcRow, 1), wsCSV.Cells(srcRow, srcLastCol)).Value
            appendRow = appendRow + 1
            appendedCount = appendedCount + 1

            If Not (fileIdVal = "" And fileNoVal = "" And barcodeVal = "") Then
                If Not existingKeyMap.Exists(key) Then existingKeyMap.Add key, True
            End If

ContinueNextCsvRow:
        Next srcRow
    End If
    
    wbCSV.Close False
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    
    MsgBox "CSV取込完了" & vbCrLf & _
           "追記件数: " & appendedCount & " 件" & vbCrLf & _
           "重複スキップ件数: " & skippedDuplicateCount & " 件", vbInformation
    Exit Sub

ErrorHandler:
    On Error Resume Next
    If Not wbCSV Is Nothing Then wbCSV.Close False
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    On Error GoTo 0
    MsgBox "CSV取込中にエラーが発生しました: " & Err.Description, vbExclamation

End Sub

Private Sub NormalizeHeaderLineBreaks(ByVal ws As Worksheet)

    Dim lastCol As Long
    Dim c As Range

    On Error GoTo SafeExit

    lastCol = GetLastUsedCol(ws)
    If lastCol <= 0 Then Exit Sub

    For Each c In ws.Range(ws.Cells(1, 1), ws.Cells(1, lastCol))
        If Not IsEmpty(c.value) Then
            c.value = Replace(CStr(c.value), vbCrLf, "")
            c.value = Replace(CStr(c.value), vbCr, "")
            c.value = Replace(CStr(c.value), vbLf, "")
        End If
    Next c

SafeExit:
    ' 改行除去は補助処理のため、失敗しても取込本体を止めない

End Sub

Public Sub 手順4_差分インポートCSVを作成する()

    Dim wsSrc As Worksheet
    Dim wsEdit As Worksheet
    Dim wsOut As Worksheet
    Dim srcLastRow As Long
    Dim srcLastCol As Long
    Dim editLastRow As Long
    Dim editLastCol As Long
    Dim r As Long
    Dim outRow As Long
    Dim keyYearSrc As Long, keyTitleSrc As Long, keyCategory2Src As Long
    Dim keyYearEdit As Long, keyTitleEdit As Long, keyCategory2Edit As Long
    Dim compareDefs As Variant
    Dim fixedHeaders As Variant
    Dim compareSrcCols() As Long
    Dim compareEditCols() As Long
    Dim i As Long
    Dim srcDict As Object
    Dim editHeaderMap As Object
    Dim outputSourceMap As Object
    Dim key As String
    Dim isDifferent As Boolean
    Dim srcRow As Long
    Dim yearVal As String, titleVal As String, category2Val As String
    Dim isKeyBlank As Boolean

    On Error GoTo ErrorHandler

    Set wsSrc = ThisWorkbook.Worksheets(SHEET_MOKUROKU_CSV)
    Set wsEdit = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    Set wsOut = ThisWorkbook.Worksheets(SHEET_DIFF_IMPORT)
    Set srcDict = CreateObject("Scripting.Dictionary")
    Set editHeaderMap = CreateObject("Scripting.Dictionary")
    Set outputSourceMap = CreateObject("Scripting.Dictionary")

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    srcLastRow = GetLastUsedRow(wsSrc)
    srcLastCol = GetLastUsedCol(wsSrc)
    editLastRow = GetLastUsedRow(wsEdit)
    editLastCol = GetLastUsedCol(wsEdit)

    keyYearSrc = FindHeaderColumn(wsSrc, srcLastCol, GetStep2HeaderCandidates("年度（和暦）"))
    keyTitleSrc = FindHeaderColumn(wsSrc, srcLastCol, GetStep2HeaderCandidates("タイトル"))
    keyCategory2Src = FindHeaderColumn(wsSrc, srcLastCol, GetStep2HeaderCandidates("分類名２"))

    keyYearEdit = FindHeaderColumn(wsEdit, editLastCol, GetStep2HeaderCandidates("年度（和暦）"))
    keyTitleEdit = FindHeaderColumn(wsEdit, editLastCol, GetStep2HeaderCandidates("タイトル"))
    keyCategory2Edit = FindHeaderColumn(wsEdit, editLastCol, GetStep2HeaderCandidates("分類名２"))

    If keyYearSrc = 0 Or keyTitleSrc = 0 Or keyCategory2Src = 0 Then
        Err.Raise vbObjectError + 2301, , "目録CSV の差分キー列（年度（和暦）/タイトル/分類名２）が見つかりません。"
    End If
    If keyYearEdit = 0 Or keyTitleEdit = 0 Or keyCategory2Edit = 0 Then
        Err.Raise vbObjectError + 2302, , "新ファイル基準表 の差分キー列（年度（和暦）/タイトル/分類名２）が見つかりません。"
    End If

    compareDefs = Array("分類名１", "分類名３", "保存期間", "媒体種別")
    ReDim compareSrcCols(LBound(compareDefs) To UBound(compareDefs))
    ReDim compareEditCols(LBound(compareDefs) To UBound(compareDefs))

    For i = LBound(compareDefs) To UBound(compareDefs)
        compareSrcCols(i) = FindHeaderColumn(wsSrc, srcLastCol, GetStep2HeaderCandidates(CStr(compareDefs(i))))
        compareEditCols(i) = FindHeaderColumn(wsEdit, editLastCol, GetStep2HeaderCandidates(CStr(compareDefs(i))))
    Next i

    fixedHeaders = Array( _
        "通し番号", "年度", "所管所属", "所管所属名称", "タイトル", "サブタイトル", "保存期間", "保存期間満了時の措置", "保管期間", "保管期間完了予定年", _
        "分類コード１", "分類名１", "分類コード２", "分類名２", "分類コード３", "分類名３", "分類コード４", "分類名４", "分類コード５", "分類名５", _
        "毎年度利用区分", "年度暦年区分", "色", "保管媒体区分", "保存場所・箱コード１", "保存場所・箱名１", "箱サイン１", "保存場所・箱コード２", "保存場所・箱名２", "箱サイン２", _
        "保存場所・箱コード３", "保存場所・箱名３", "箱サイン３", "保存場所・箱コード４", "保存場所・箱名４", "箱サイン４", "保存場所・箱コード５", "保存場所・箱名５", "箱サイン５", _
        "ラベル種類", "背表紙用タイトル", "背表紙用サブタイトル", "公開用タイトル", "公開用サブタイトル", "公開区分", "歴史資料区分", "内容・取扱い", "備考", _
        "作成所属", "作成年度", "作成者", "機密レベル", "汎用項目１", "汎用項目２", "汎用項目３", "汎用項目４", "汎用項目５", "汎用項目６", "汎用項目７", "汎用項目８", "汎用項目９", "汎用項目１０", _
        "汎用日付項目１", "汎用日付項目２", "汎用日付項目３", "汎用日付項目４", "汎用日付項目５", _
        "汎用数値項目１", "汎用数値項目２", "汎用数値項目３", "汎用数値項目４", "汎用数値項目５", _
        "汎用選択項目１", "汎用選択項目２", "汎用選択項目３", "汎用選択項目４", "汎用選択項目５", _
        "汎用チェック項目１", "汎用チェック項目２", "汎用チェック項目３", "汎用チェック項目４", "汎用チェック項目５", _
        "ファイルラベル区分名", "ファイルラベル区分サイズ", "場所内のファイルのソート")

    ' 新ファイル基準表の見出しを辞書化（固定見出しとの同名照合で使用）
    For i = 1 To editLastCol
        If Len(Trim(CStr(wsEdit.Cells(1, i).value))) > 0 Then
            If Not editHeaderMap.Exists(Trim(CStr(wsEdit.Cells(1, i).value))) Then
                editHeaderMap.Add Trim(CStr(wsEdit.Cells(1, i).value)), i
            End If
        End If
    Next i

    ' 出力見出し -> 取得元見出し のマッピング定義
    outputSourceMap.Add "通し番号", "通し番号"
    ' 固定見出し「所管所属」は新ファイル基準表の「原課ID」から取得する
    outputSourceMap.Add "所管所属", "原課ID"
    ' 固定見出し「毎年度利用区分」は新ファイル基準表の正式見出しから取得する
    outputSourceMap.Add "毎年度利用区分", "毎年度利用区分1:毎年作成 2:単年のみ"

    ' ① 目録CSVをキー（年度（和暦）+タイトル+分類名２）で辞書化
    For r = 2 To srcLastRow
        yearVal = GetTrimmedCell(wsSrc, r, keyYearSrc)
        titleVal = GetTrimmedCell(wsSrc, r, keyTitleSrc)
        category2Val = GetTrimmedCell(wsSrc, r, keyCategory2Src)
        key = BuildHeaderBasedKey(yearVal, titleVal, category2Val)

        isKeyBlank = (yearVal = "" And titleVal = "" And category2Val = "")
        If Not isKeyBlank And titleVal <> "" Then
            If Not srcDict.Exists(key) Then srcDict.Add key, r
        End If
    Next r

    wsOut.Cells.Clear
    ' 1行目に固定見出しを厳密順で出力
    For i = LBound(fixedHeaders) To UBound(fixedHeaders)
        wsOut.Cells(1, i - LBound(fixedHeaders) + 1).value = fixedHeaders(i)
    Next i
    outRow = 2

    ' ② 新ファイル基準表を1行ずつ処理
    For r = 2 To editLastRow
        yearVal = GetTrimmedCell(wsEdit, r, keyYearEdit)
        titleVal = GetTrimmedCell(wsEdit, r, keyTitleEdit)
        category2Val = GetTrimmedCell(wsEdit, r, keyCategory2Edit)
        key = BuildHeaderBasedKey(yearVal, titleVal, category2Val)
        isKeyBlank = (yearVal = "" And titleVal = "" And category2Val = "")

        ' A. キー3項目がすべて空白 または タイトル空白 -> 無視
        If isKeyBlank Or titleVal = "" Then
            ' 何もしない

        ' B. キー一致する行が存在 -> 比較列に差異があれば更新行として出力
        ElseIf srcDict.Exists(key) Then
            srcRow = CLng(srcDict(key))
            isDifferent = False

            For i = LBound(compareDefs) To UBound(compareDefs)
                If compareSrcCols(i) > 0 And compareEditCols(i) > 0 Then
                    If GetTrimmedCell(wsSrc, srcRow, compareSrcCols(i)) <> _
                       GetTrimmedCell(wsEdit, r, compareEditCols(i)) Then
                        isDifferent = True
                        Exit For
                    End If
                End If
            Next i

            If isDifferent Then
                WriteRowByFixedLayout wsEdit, wsOut, r, outRow, fixedHeaders, editHeaderMap, outputSourceMap
                outRow = outRow + 1
            End If

        ' C. キー一致なし -> 新規行として出力
        Else
            WriteRowByFixedLayout wsEdit, wsOut, r, outRow, fixedHeaders, editHeaderMap, outputSourceMap
            outRow = outRow + 1
        End If
    Next r

    With wsOut.Range(wsOut.Cells(1, 1), wsOut.Cells(1, UBound(fixedHeaders) - LBound(fixedHeaders) + 1))
        .Font.Bold = True
        .Interior.Color = RGB(242, 242, 242)
        .AutoFilter
    End With
    wsOut.Columns(1).Resize(, UBound(fixedHeaders) - LBound(fixedHeaders) + 1).EntireColumn.AutoFit

    MsgBox "差分インポートCSV の作成が完了しました。" & vbCrLf & _
           "出力件数: " & outRow - 2 & " 件", vbInformation

SafeExit:
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Exit Sub

ErrorHandler:
    MsgBox "差分インポートCSV の作成中にエラーが発生しました: " & Err.Description, vbExclamation
    Resume SafeExit

End Sub

Private Function BuildHeaderBasedKey(ByVal yearValue As String, ByVal titleValue As String, ByVal category2Value As String) As String

    BuildHeaderBasedKey = Trim$(CStr(yearValue)) & "|" & Trim$(CStr(titleValue)) & "|" & Trim$(CStr(category2Value))

End Function

Public Sub 手順2_新ファイル基準表を作成する()

    Dim wsSrc As Worksheet
    Dim wsDst As Worksheet
    Dim srcLastRow As Long
    Dim srcLastCol As Long
    Dim dstLastCol As Long
    Dim displayHeaders As Variant
    Dim userManagedHeaders As Variant
    Dim srcToDstMap As Object
    Dim existingDstHeaders As Object
    Dim srcCol As Long
    Dim dstCol As Long
    Dim headerText As String
    Dim canonical As String
    Dim i As Long
    Dim targetCol As Long
    Dim foundCol As Long
    Dim leftFixedCount As Long
    Dim missingHeadersText As String
    Dim validationTemplateMap As Object
    Dim formatTemplateMap As Object
    Dim columnWidthMap As Object
    Dim wsValidationTemplate As Worksheet
    Dim wsFormatTemplate As Worksheet
    Dim existingLastRow As Long
    Dim appendStartRow As Long
    Dim appendEndRow As Long
    Dim srcRow As Long
    Dim appendedCount As Long
    Dim skippedDuplicateCount As Long
    Dim existingKeyMap As Object
    Dim fileIdSrcCol As Long
    Dim fileNoSrcCol As Long
    Dim barcodeSrcCol As Long
    Dim fileIdDstCol As Long
    Dim fileNoDstCol As Long
    Dim barcodeDstCol As Long
    Dim fileIdVal As String
    Dim fileNoVal As String
    Dim barcodeVal As String
    Dim key As String

    On Error GoTo ErrorHandler

    Set wsSrc = ThisWorkbook.Worksheets(SHEET_MOKUROKU_CSV)
    Set wsDst = ThisWorkbook.Worksheets(SHEET_NEW_FILE_STANDARD)
    Set srcToDstMap = CreateObject("Scripting.Dictionary")
    Set existingDstHeaders = CreateObject("Scripting.Dictionary")
    Set validationTemplateMap = CreateObject("Scripting.Dictionary")
    Set formatTemplateMap = CreateObject("Scripting.Dictionary")
    Set columnWidthMap = CreateObject("Scripting.Dictionary")
    Set existingKeyMap = CreateObject("Scripting.Dictionary")

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    srcLastCol = GetLastUsedCol(wsSrc)
    srcLastRow = GetLastUsedRow(wsSrc)
    dstLastCol = GetLastUsedCol(wsDst)

    If srcLastCol <= 0 Then Err.Raise vbObjectError + 2001, , "目録CSV の見出し行が見つかりません。"

    ' 追記: 並び替え前に既存入力規則のテンプレートを退避（見出し名ベースで復元するため）
    CreateValidationTemplateSheet wsDst, dstLastCol, validationTemplateMap, wsValidationTemplate
    ' 追記: 並び替え前に既存書式/列幅を退避（条件付き書式・列幅の崩れ防止）
    CreateFormatAndWidthTemplate wsDst, dstLastCol, formatTemplateMap, columnWidthMap, wsFormatTemplate

    displayHeaders = Array( _
        "通し番号", _
        "キャビネット番号", _
        "ｎ＋1", _
        "毎年度利用区分1:毎年作成 2:単年のみ", _
        "原課", _
        "年度（和暦）", _
        "分類名１", _
        "分類名２", _
        "2色名", _
        "分類名３", _
        "色名", _
        "作成年度（和暦）", _
        "タイトル", _
        "保存期間", _
        "媒体種別")
    userManagedHeaders = Array("通し番号", "キャビネット番号", "ｎ＋1")

    ' 1) 既存「新ファイル基準表」の見出しを辞書化（追加列保持のため）
    BuildHeaderMap wsDst, dstLastCol, existingDstHeaders

    ' 2) ユーザー管理列（CSV由来ではない3列）を確保
    For i = LBound(userManagedHeaders) To UBound(userManagedHeaders)
        EnsureColumnByHeader wsDst, existingDstHeaders, CStr(userManagedHeaders(i))
    Next i

    ' 3) CSV由来列を「見出し名ベース」で同期（不足列は追加、既存追加列は維持）
    For srcCol = 1 To srcLastCol
        headerText = Trim(CStr(wsSrc.Cells(1, srcCol).value))
        If headerText <> "" Then
            canonical = CanonicalHeaderName(headerText)
            dstCol = EnsureColumnByHeader(wsDst, existingDstHeaders, headerText)
            srcToDstMap(canonical) = dstCol
        End If
    Next srcCol

    ' 4) 既存行は保持し、目録CSV(2行目以降)を新ファイル基準表の末尾に追記する
    existingLastRow = GetLastUsedRow(wsDst)
    If existingLastRow < 1 Then existingLastRow = 1
    appendStartRow = existingLastRow + 1
    appendEndRow = appendStartRow - 1

    fileIdSrcCol = FindHeaderColumn(wsSrc, srcLastCol, Array("ファイルID"))
    fileNoSrcCol = FindHeaderColumn(wsSrc, srcLastCol, Array("ファイル番号"))
    barcodeSrcCol = FindHeaderColumn(wsSrc, srcLastCol, Array("バーコード番号"))
    fileIdDstCol = FindHeaderColumn(wsDst, GetLastUsedCol(wsDst), Array("ファイルID"))
    fileNoDstCol = FindHeaderColumn(wsDst, GetLastUsedCol(wsDst), Array("ファイル番号"))
    barcodeDstCol = FindHeaderColumn(wsDst, GetLastUsedCol(wsDst), Array("バーコード番号"))

    ' 既存行の重複判定キーを辞書化
    If fileIdDstCol > 0 And fileNoDstCol > 0 And barcodeDstCol > 0 Then
        For i = 2 To existingLastRow
            fileIdVal = GetTrimmedCell(wsDst, i, fileIdDstCol)
            fileNoVal = GetTrimmedCell(wsDst, i, fileNoDstCol)
            barcodeVal = GetTrimmedCell(wsDst, i, barcodeDstCol)
            If Not (fileIdVal = "" And fileNoVal = "" And barcodeVal = "") Then
                key = BuildFileKey(fileIdVal, fileNoVal, barcodeVal)
                If Not existingKeyMap.Exists(key) Then
                    existingKeyMap.Add key, True
                End If
            End If
        Next i
    End If

    If srcLastRow >= 2 Then
        For srcRow = 2 To srcLastRow
            fileIdVal = GetTrimmedCell(wsSrc, srcRow, fileIdSrcCol)
            fileNoVal = GetTrimmedCell(wsSrc, srcRow, fileNoSrcCol)
            barcodeVal = GetTrimmedCell(wsSrc, srcRow, barcodeSrcCol)

            If fileIdVal = "" And fileNoVal = "" And barcodeVal = "" Then
                ' 3項目すべて空欄は重複判定不能のため追記
            Else
                key = BuildFileKey(fileIdVal, fileNoVal, barcodeVal)
                If existingKeyMap.Exists(key) Then
                    skippedDuplicateCount = skippedDuplicateCount + 1
                    GoTo ContinueNextSrcRow
                End If
            End If

            appendEndRow = appendEndRow + 1
            For srcCol = 1 To srcLastCol
                headerText = Trim(CStr(wsSrc.Cells(1, srcCol).value))
                If headerText <> "" Then
                    canonical = CanonicalHeaderName(headerText)
                    If srcToDstMap.Exists(canonical) Then
                        dstCol = CLng(srcToDstMap(canonical))
                        wsDst.Cells(appendEndRow, dstCol).value = wsSrc.Cells(srcRow, srcCol).value
                    End If
                End If
            Next srcCol

            appendedCount = appendedCount + 1
            If Not (fileIdVal = "" And fileNoVal = "" And barcodeVal = "") Then
                If Not existingKeyMap.Exists(key) Then existingKeyMap.Add key, True
            End If

ContinueNextSrcRow:
        Next srcRow
    End If

    ' 5) 主要列だけ左側へ並べ直し（それ以外は削除せず後ろに残す）
    targetCol = 1
    For i = LBound(displayHeaders) To UBound(displayHeaders)
        srcLastCol = GetLastUsedCol(wsDst)
        foundCol = FindHeaderColumn(wsDst, srcLastCol, GetStep2HeaderCandidates(CStr(displayHeaders(i))))

        If foundCol > 0 Then
            If foundCol <> targetCol Then
                wsDst.Columns(foundCol).Cut
                wsDst.Columns(targetCol).Insert Shift:=xlToRight
                Application.CutCopyMode = False
            End If
            targetCol = targetCol + 1
        End If
    Next i
    leftFixedCount = targetCol - 1

    ' 6) 「毎年度利用区分」表示値変換（新規追記行のみ）
    If appendEndRow >= appendStartRow Then
        ConvertAnnualUseDivisionValues wsDst, appendEndRow, appendStartRow
        ' 追記: 2色名 = 色名 を新規追記行へ反映（見出し名ベース）
        SyncSecondColorNameFromColor wsDst, appendStartRow, appendEndRow
    End If

    ' 7) 主要列の見た目のみ整える（既存追加列の表示/非表示状態は壊さない）
    If leftFixedCount > 0 Then
        With wsDst.Range(wsDst.Cells(1, 1), wsDst.Cells(1, leftFixedCount))
            .Font.Bold = True
            .Interior.Color = RGB(242, 242, 242)
        End With
        wsDst.Range(wsDst.Columns(1), wsDst.Columns(leftFixedCount)).EntireColumn.AutoFit
    End If

    srcLastCol = GetLastUsedCol(wsDst)
    wsDst.Range(wsDst.Cells(1, 1), wsDst.Cells(1, srcLastCol)).AutoFilter

    ' 8) 指定見出しだけ表示し、それ以外を非表示にする（見出し名ベース）
    HideKeyColumnsForStep2 wsDst, displayHeaders, missingHeadersText

    ' 9) タイトルがある行だけ通し番号を再採番
    ReindexSerial_NewFileStandard wsDst

    ' 10) 入力規則を見出し名ベースで再適用（列挿入/並び替え後の列位置へ追従）
    ReapplyValidationFromTemplate wsDst, validationTemplateMap, wsValidationTemplate
    ' 追記: 条件付き書式/列幅を見出し名ベースで再適用
    ReapplyFormatAndWidthFromTemplate wsDst, formatTemplateMap, columnWidthMap, wsFormatTemplate

    If Len(missingHeadersText) > 0 Then
        MsgBox "新ファイル基準表の作成が完了しました。" & vbCrLf & _
               "追記件数: " & appendedCount & " 件" & vbCrLf & _
               "重複スキップ件数: " & skippedDuplicateCount & " 件" & vbCrLf & _
               "左側に固定した主要列数: " & leftFixedCount & " 列" & vbCrLf & vbCrLf & _
               "以下の見出しが見つからないため、表示/並び替え対象から除外しました:" & vbCrLf & _
               missingHeadersText, vbExclamation
    Else
        MsgBox "新ファイル基準表の作成が完了しました。" & vbCrLf & _
               "追記件数: " & appendedCount & " 件" & vbCrLf & _
               "重複スキップ件数: " & skippedDuplicateCount & " 件" & vbCrLf & _
               "左側に固定した主要列数: " & leftFixedCount & " 列", vbInformation
    End If

SafeExit:
    On Error Resume Next
    If Not wsValidationTemplate Is Nothing Then
        Application.DisplayAlerts = False
        wsValidationTemplate.Delete
        Application.DisplayAlerts = True
    End If
    If Not wsFormatTemplate Is Nothing Then
        Application.DisplayAlerts = False
        wsFormatTemplate.Delete
        Application.DisplayAlerts = True
    End If
    On Error GoTo 0

    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Exit Sub

ErrorHandler:
    MsgBox "新ファイル基準表の作成中にエラーが発生しました: " & Err.Description, vbCritical
    Resume SafeExit

End Sub

