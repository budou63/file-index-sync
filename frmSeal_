Private Function HasAnySingleInput(ByVal frm As Object) As Boolean

    Dim slot As Long

    For slot = 1 To 12
        If Len(Trim$(GetSerialBySlot(frm, slot))) > 0 Then
            HasAnySingleInput = True
            Exit Function
        End If
    Next slot

    HasAnySingleInput = False

End Function

