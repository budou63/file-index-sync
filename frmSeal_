Private Sub SyncMoveModeButtons()

    On Error GoTo SafeExit

    mSyncingMoveModeButtons = True

    If IsRowMoveModeActive() Then
        Me.tglMoveMode.Value = True
        Me.tglMoveMode.Caption = "移動確定"
    Else
        Me.tglMoveMode.Value = False
        Me.tglMoveMode.Caption = "移動開始"
    End If

    On Error Resume Next
    Me.Controls("cmdMoveUndo").Enabled = IsRowMoveUndoAvailable()
    On Error GoTo SafeExit

SafeExit:
    mSyncingMoveModeButtons = False

End Sub

Private Sub btnApply_Click()

    Dim bulkStartText As String
    Dim bulkEndText As String
    Dim hasSingleInput As Boolean
    Dim hasBulkStart As Boolean
    Dim hasBulkEnd As Boolean
    Dim startNo As Long
    Dim endNo As Long

    On Error GoTo ErrorHandler

    bulkStartText = GetBulkStartFromForm(Me)
    bulkEndText = GetBulkEndFromForm(Me)
    hasSingleInput = HasAnySingleInput(Me)
    hasBulkStart = (Len(bulkStartText) > 0)
    hasBulkEnd = (Len(bulkEndText) > 0)

    ' 単件 + 複数の同時入力はエラー
    If hasSingleInput And (hasBulkStart Or hasBulkEnd) Then
        MsgBox "単件用と複数用の両方に入力されています。どちらか一方だけ入力してください。", vbExclamation
        Exit Sub
    End If

    ' 複数欄の片側のみ入力はエラー
    If hasBulkStart Xor hasBulkEnd Then
        MsgBox "複数転記を行う場合は、開始番号と終了番号の両方を入力してください。", vbExclamation
        Exit Sub
    End If

    ' 複数反映モード
    If hasBulkStart And hasBulkEnd Then
        If (Not TryParseLongStrict(bulkStartText, startNo)) Or (Not TryParseLongStrict(bulkEndText, endNo)) Then
            MsgBox "開始番号と終了番号は数値で入力してください。", vbExclamation
            Exit Sub
        End If

        If startNo > endNo Then
            MsgBox "開始番号は終了番号以下にしてください。", vbExclamation
            Exit Sub
        End If

        GenerateMultiSealSheets_NewSpec startNo, endNo
        Exit Sub
    End If

    ' 単件反映モード
    If hasSingleInput Then
        ApplySingleSlots_NewSpec Me
        Exit Sub
    End If

    MsgBox "通し番号、または開始番号・終了番号を入力してください。", vbExclamation
    Exit Sub

ErrorHandler:
    MsgBox "反映処理でエラーが発生しました: " & Err.Description, vbExclamation

End Sub

Private Sub ApplySingleSlots_NewSpec(ByVal frm As Object)

    Dim wsSrc As Worksheet
    Dim wsSeal As Worksheet
    Dim serialIndex As Object
    Dim headerIndex As Object
    Dim slot As Long
    Dim serialKey As String
    Dim srcRow As Long
    Dim parsedNo(1 To 12) As Long
    Dim missingList As String

    On Error GoTo ErrorHandler

    Set wsSrc = FindSheetByCandidates(ThisWorkbook, Array("新ファイル基準表"))
    Set wsSeal = FindSheetByCandidates(ThisWorkbook, Array("個別フォルダシール", "個別フォルダーシール", "フォルダシール"))

    If wsSrc Is Nothing Then Err.Raise vbObjectError + 2201, , "転記元シート（新ファイル基準表）が見つかりません。"
    If wsSeal Is Nothing Then Err.Raise vbObjectError + 2202, , "転記先シート（個別フォルダシール）が見つかりません。"

    BuildIndexes_NewSpec wsSrc, serialIndex, headerIndex

    If serialIndex Is Nothing Or headerIndex Is Nothing Then
        Err.Raise vbObjectError + 2203, , "見出しインデックスの作成に失敗しました。"
    End If
    If CLng(headerIndex("通し番号")) = 0 Then
        Err.Raise vbObjectError + 2204, , "見出し「通し番号」が見つかりません。"
    End If

    ' 1st pass: 全入力を数値妥当性チェック（エラー時は何も反映しない）
    For slot = 1 To 12
        serialKey = GetSerialBySlot(frm, slot)
        If Len(serialKey) > 0 Then
            If Not TryParseLongStrict(serialKey, parsedNo(slot)) Then
                MsgBox "単発エリアの " & CStr(slot) & " 枠目は数値で入力してください。", vbExclamation
                Exit Sub
            End If
        End If
    Next slot

    ' 2nd pass: 入力あり枠だけ反映、未入力枠はクリア
    For slot = 1 To 12
        serialKey = GetSerialBySlot(frm, slot)

        If Len(serialKey) = 0 Then
            ClearOneSealSlot wsSeal, slot
        Else
            serialKey = CStr(parsedNo(slot))
            If serialIndex.Exists(serialKey) Then
                srcRow = CLng(serialIndex(serialKey))
                WriteOneSeal_NewSpec _
                    wsSrc, srcRow, wsSeal, slot, _
                    CLng(headerIndex("タイトル")), _
                    CLng(headerIndex("分類名2")), _
                    CLng(headerIndex("分類名3")), _
                    CLng(headerIndex("年度和暦")), _
                    CLng(headerIndex("保存期間"))
            Else
                ClearOneSealSlot wsSeal, slot
                If Len(missingList) > 0 Then missingList = missingList & " / "
                missingList = missingList & "枠" & CStr(slot) & ": " & serialKey
            End If
        End If
    Next slot

    If Len(missingList) > 0 Then
        MsgBox "個別フォルダシールへ反映しました（一部未該当は空欄）。" & vbCrLf & missingList, vbExclamation
    Else
        MsgBox "個別フォルダシールへ反映しました。", vbInformation
    End If
    Exit Sub

ErrorHandler:
    MsgBox "単発反映処理でエラーが発生しました: " & Err.Description, vbExclamation

End Sub

Private Function TryParseLongStrict(ByVal textValue As String, ByRef outValue As Long) As Boolean

    Dim normalized As String
    Dim d As Double

    normalized = Trim$(textValue)
    If Len(normalized) = 0 Then Exit Function
    If Not IsNumeric(normalized) Then Exit Function

    d = CDbl(normalized)
    If d <> Fix(d) Then Exit Function
    If d < -2147483648# Or d > 2147483647# Then Exit Function

    outValue = CLng(d)
    TryParseLongStrict = True

End Function

